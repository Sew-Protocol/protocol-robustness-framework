        "id": "setup",
        "title": "Scenario Setup",
        "explain": "Two depositors (OwnerA, OwnerB) deposit into a shared Aave v3 yield module.  OwnerA deposits 1000 USDC, OwnerB deposits 2000 USDC.",
        "commands": [
          "cat scenarios\/Y02_vault-shortfall-partial-withdraw.json"
        ]
      },
      {
        "id": "inject-shortfall",
        "title": "Inject Liquidity Shortfall",
        "explain": "Governance sets the yield module to shortfall mode with 50% available liquidity.  This simulates a DeFi liquidity crisis where only half the deposited funds are immediately redeemable.",
        "commands": []
      },
      {
        "id": "withdraw",
        "title": "Withdraw During Shortfall",
        "explain": "OwnerA requests a full withdrawal while the module is in shortfall.  The protocol fulfills 50% (500 USDC) immediately and defers the remaining 500 USDC as a claimable deferred amount.",
        "commands": []
      },
      {
        "id": "inspect",
        "title": "Inspect Outcomes",
        "explain": "Check the claimable classification to verify that deferred amounts are tracked correctly and that no funds were silently lost.",
        "commands": [
          "cat results\/test-artifacts\/claimable-classification.json"
        ]
      }
    ],
