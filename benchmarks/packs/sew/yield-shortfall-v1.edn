{:benchmark/id              :benchmark/sew-yield-shortfall-v1
  :benchmark/version         1
  :benchmark/status          :experimental
  :benchmark/coverage-status :partial
  :benchmark/experimental-reason
  "The current 15-scenario Sew workload must be rerun with the closed-form
   evaluators to establish that it emits qualifying partial-fill decision
   artifacts. Until then, allocation correctness and cap bounds are not
   active-benchmark evidence."
  :benchmark/domain          :domain/protocol-value-conservation
  :benchmark/protocol        :protocol/sew
   :benchmark/scenario-suite  :suite/sew-yield-safety-v1
  :benchmark/scenario-suite-description
  "15 Sew yield integration scenarios covering AAVE partial liquidity,
   negative yield, shortfall recovery, reorg races, and governance
   interactions with yield positions."
  :benchmark/runner-policy   :runner-policy/deterministic-local-v1
 :benchmark/evidence-policy :evidence-policy/forensic-standard-v1
  :benchmark/scoring-rule    :scoring/severity-weighted-robustness-v1
   :benchmark/property-types  #{:safety}
   :benchmark/property-claims {:safety [:claim/yield-preserved-during-shortfall
                                        :claim/no-leakage-beyond-shortfall
                                        :claim/partial-fill-decision-integrity
                                        :claim/cap-adherence]}
   :benchmark/description
  "Evaluates Sew yield shortfall behavior across 15 yield-integration
   scenarios: yield preservation, closed-form partial-fill correctness,
   cap bounds, and prevention of value leakage beyond declared shortfall
   bounds. It evaluates emitted allocation-decision artifacts, rather than
   treating scenario completion as allocation assurance. This is an
   independent benchmark (does not share a suite with the other Sew benchmarks)."
   :benchmark/concepts        [:robustness/protocol-value-conservation
                              :ecommerce/purchase
                              :event/deposit
                              :yield/yield-bearing
                              :consensus/authority
                              :consensus/evidence
                              :consensus/legitimacy
                              :concept/confidence
                              :concept/configuration]
  :benchmark/purpose
  "Evaluate Sew yield shortfall behavior: yield preservation during
   shortfall, closed-form partial-fill correctness, cap bounds, and
   prevention of value leakage beyond declared shortfall bounds."
  :benchmark/claims          [{:claim/id :claim/yield-preserved-during-shortfall
                              :claim/role :primary
                              :claim/rationale "Yield position value must not leak during shortfall events."
                              :claim/failure-meaning "Yield position lost value during shortfall."}
                             {:claim/id :claim/partial-fill-decision-integrity
                              :claim/role :primary
                              :claim/rationale "Every emitted partial-fill decision must satisfy its declared closed-form allocation checks."
                              :claim/failure-meaning "A partial-fill decision violated conservation, bounds, integrity, or its mode-specific allocation rule."}
                             {:claim/id :claim/cap-adherence
                              :claim/role :supporting
                              :claim/rationale "Every emitted allocation decision must stay within available liquidity and each requested claim bound."
                              :claim/failure-meaning "An allocation exceeded available liquidity or a declared claim bound."}
                             {:claim/id :claim/no-leakage-beyond-shortfall
                              :claim/role :supporting
                              :claim/rationale "No value should leak beyond the declared shortfall bounds."
                              :claim/failure-meaning "Value leaked beyond the shortfall boundary."}]}
