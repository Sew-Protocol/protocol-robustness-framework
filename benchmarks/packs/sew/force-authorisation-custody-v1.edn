 "Experimental bounded-claim benchmark for exceptional authorization and
  custody isolation. It does not establish governance legitimacy, external
  settlement correctness, or unrestricted protocol safety."
 :benchmark/claims
 [{:claim/id :force-authorisation-exact-scope-single-use
   :claim/role :primary
   :claim/severity :high
   :claim/rationale "A forced settlement must consume only its exact grant-time scope."
   :claim/failure-meaning "A force-authorisation was reused or drifted from its granted custody scope."}
  {:claim/id :held-custody-position-isolation
   :claim/role :primary
   :claim/severity :high
   :claim/rationale "One workflow or account must not spend another position's custody."
   :claim/failure-meaning "A materialized custody partition became negative or crossed position scope."}
  {:claim/id :forensic-authorisation-custody-linkage
   :claim/role :supporting
   :claim/severity :medium
   :claim/rationale "Forensic evidence must link grant, consumption, and custody movement."
   :claim/failure-meaning "Authorization, consumption, artifact, or evidence linkage was incomplete or inconsistent."}]}
