   replay:determinism
   {:doc "Run the minimal-runner self-test for deterministic replay. Defaults to --suite suite/reference-validation-v1.
          Accepts --suite/--scenario/--fixtures. Ignores --runs for now because the current self-test is fixed at two passes."
    :task (let [args (vec *command-line-args*)
                args-no-runs (loop [remaining args
                                    acc []]
                               (if-let [arg (first remaining)]
                                 (if (= "--runs" arg)
                                   (recur (nnext remaining) acc)
                                   (recur (next remaining) (conj acc arg)))
                                 acc))
                has-suite-or-scenario? (boolean (some #{"--suite" "--scenario" "--fixture-suite"} args-no-runs))
                final-args (if has-suite-or-scenario?
                             args-no-runs
                             (into ["--suite" "suite/reference-validation-v1"] args-no-runs))]
            (apply clojure "-M:with-sew" "-m" "resolver-sim.minimal-runner" "--self-test" final-args))}

