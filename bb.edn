  validate {:doc "Structural validation pipeline: lint + notebook namespace check"
            :task (let [ok? (fn [ok?-label ok?-f]
                              (print (str "▶ " ok?-label "... "))
                              (flush)
                              (let [ok (try (ok?-f) true (catch Exception _ false))]
                                (println (if ok "PASS" "FAIL"))
                                ok))
                          lint-ok (ok? "Lint (src:test)" (fn [] (shell "clj" "-M:lint/core")))
                          nb-ok   (ok? "Notebook namespace check" (fn [] (shell "scripts/with-test-artifact-lock.sh" "clojure" "-M:with-sew" "-e" "(require (quote [resolver-sim.notebook-support.checks])) (require (quote [notebooks.report]))")))
                         all-nb-ok (ok? "All notebooks load" (fn [] (shell "bb" "test:notebooks")))
                         speds-ok (ok? "SPEDS tests" (fn [] (shell "bb" "test:speds")))]
                     (if (and lint-ok nb-ok all-nb-ok speds-ok)
                      (println "VALIDATION PASSED")
                      (do (println "VALIDATION FAILED")
                          (System/exit 1))))}

