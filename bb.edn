  validation:artifact-registry
  {:doc "Validate an artifact registry (test-artifacts.json) and write a
         validation-root.v1 result beside it.

         Usage:
           bb validation:artifact-registry
               — validates results/test-artifacts/test-artifacts.json (default)

           bb validation:artifact-registry results/runs/<run-id>/test-artifacts.json
               — validates a per-run registry

         Output:
           <registry-dir>/artifact-registry-validation.json

         Non-blocking:
           This task is additive. Registry validation failures do not block CI.
           Operational errors (file not found, parse failure) are reported as
           skipped and do not block the caller.

         Integrated into:
           bb scenario:run — runs automatically after registry emission."
   :task (let [registry-path (or (first *command-line-args*)
                                 "results/test-artifacts/test-artifacts.json")]
           (println (str "[artifact-registry-validation] Validating " registry-path "..."))
           (try
             (apply clojure {:dir "." :extra-deps {}}
                    ["-M" "-m" "resolver-sim.validation.integration.artifact-registry" registry-path])
             (catch Exception e
               (println "[artifact-registry-validation] Skipped (operational):" (.getMessage e))))
           (println "[artifact-registry-validation] Done"))}

