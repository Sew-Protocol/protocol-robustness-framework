  notebook:focus
  {:doc "Focus the provenance notebook on a specific run-id. Usage: bb notebook:focus <run-id>"
   :task (let [run-id (first *command-line-args*)]
           (when-not (seq run-id)
             (throw (ex-info "Usage: bb notebook:focus <run-id>" {})))
           (clojure.java.io/make-parents "results/.notebook-focus")
           (spit "results/.notebook-focus" run-id)
           (println "Notebook focused on run:" run-id)
           (println "Reload the Clerk notebook to see this run."))}

  notebook:latest
  {:doc "Reset the provenance notebook to always show the latest run."
   :task (let [f (java.io.File. "results/.notebook-focus")]
           (if (.delete f)
             (println "Notebook reset to latest run.")
             (println "Already showing latest run (no focus file found).")))}

  notebook:runs
  {:doc "List all available run-ids for use with notebook:focus."
   :task (let [root (java.io.File. "results/runs")]
           (if (.exists root)
             (doseq [d (sort (.listFiles root))]
               (when (.isDirectory d)
                 (println (.getName d))))
             (println "No runs found. Run bb scenario:run <scenario> first.")))}

