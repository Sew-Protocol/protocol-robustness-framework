  {:doc "Full demo build: record + export SVG.
         Usage: bb demo:build <demo-id>
         Runs bb demo:record then bb demo:export-svg."
   :task (let [id (first *command-line-args*)]
           (if-not id
             (println "Usage: bb demo:build <id>")
             (do
               (shell "clojure" "-M" "-m" "resolver-sim.demo.recorder" id)
                (shell "clojure" "-M" "-m" "resolver-sim.demo.export" id))))}

  workspace:list
  {:doc "List available workspaces with descriptions."
   :task (let [ws-dir (java.io.File. "workspaces")]
           (if-not (.exists ws-dir)
             (println "No workspaces directory found.")
             (let [entries (sort (filter (fn [x] (.isDirectory x)) (.listFiles ws-dir)))]
               (println "Available workspaces:")
               (println "---------------------")
               (doseq [f entries]
                 (let [readme (java.io.File. f "README.md")
                       deps   (java.io.File. f "deps.edn")
                       desc   (when (.exists readme)
                                (try (let [lines (clojure.string/split-lines (slurp readme))]
                                       (first (remove empty? lines)))
                                     (catch Exception _ "")))
                       has-deps (when (.exists deps) " deps.edn ✓")]
                   (println (str "  " (.getName f))
                            (str "  " (or has-deps ""))
                            (str "  " (or desc "")))))
               (println)
               (println "External archives:")
               (println "  ~/prf-runs/<run-id>/     Forensic run output")
               (println "  ~/prf-private/<id>/      Private discovery workspace"))))}

  workspace:doctor
  {:doc "Validate workspace structure. Checks README, deps.edn, and path resolution."
   :task (let [ws-dir (java.io.File. "workspaces")]
           (if-not (.exists ws-dir)
             (println "No workspaces directory found.")
             (let [entries (sort (filter (fn [x] (.isDirectory x)) (.listFiles ws-dir)))]
               (doseq [ws entries]
                 (let [name (.getName ws)
                       readme (java.io.File. ws "README.md")
                       deps-file (java.io.File. ws "deps.edn")]
                   (println (str "▶ " name))
                   (let [readme-ok (and (.exists readme) (> (.length readme) 0))
                         msg (if readme-ok "README.md ✓" "README.md MISSING or empty")]
                     (println (str "  " msg)))
                   (if (.exists deps-file)
                     (try
                       (let [deps (slurp deps-file)]
                         (println "  deps.edn ✓")
                         (let [path-pattern (re-pattern "\"\\.\\./\\.\\./[^\"]+\"")]
                           (doseq [line (clojure.string/split-lines deps)]
                             (when-let [m (re-find path-pattern line)]
                               (let [path (subs m 1 (dec (count m)))
                                     abs (java.io.File. (.getParent deps-file) path)]
                                 (if (.exists abs)
                                   (println (str "    path " path " ✓"))
                                   (println (str "    path " path " NOT FOUND"))))))))
                       (catch Exception e
                         (println (str "  deps.edn ERROR: " (.getMessage e)))))
                     (println "  no deps.edn"))
                   (println)))
                (println "Doctor complete."))))}

  forensic:preflight
  {:doc "Run forensic preflight checks. Usage: bb forensic:preflight --run-request <path> [options]"
   :task (apply shell "python3" "scripts/forensic/preflight.py" *command-line-args*)}

  forensic:run
  {:doc "Run a forensic execution.
Usage: bb forensic:run [--run-request <path>] [--label <label>] [--private-tmpfs] [--dry-run]
Env:   PRF_SOURCE_ROOTS, PRF_RUNS_ROOT, PRF_ARTIFACT_DIR, PRF_CODE_HASH_ALGORITHM,
       PRF_EVIDENCE_USER, PRF_EVIDENCE_WORKSPACE — see docs/forensic/FORENSIC_HARDENING.md"
   :task (apply shell "bash" "scripts/forensic/run.sh" *command-line-args*)}

  forensic:verify
  {:doc "Verify a forensic run bundle. Usage: bb forensic:verify <run-dir>"
   :task (apply shell "python3" "scripts/forensic/verify.py" *command-line-args*)}

  forensic:export
  {:doc "Export a forensic run bundle as tar.gz. Usage: bb forensic:export <run-dir> [--output <path>]"
   :task (apply shell "python3" "scripts/forensic/export.py" *command-line-args*)}

  forensic:import
  {:doc "Import a forensic run bundle from tar.gz. Usage: bb forensic:import <archive> [--output <dir>]"
   :task (apply shell "python3" "scripts/forensic/import_archive.py" *command-line-args*)}

  forensic:reproduce
  {:doc "Reproduce a forensic run from its bundle and compare results. Usage: bb forensic:reproduce <run-dir>"
   :task (apply shell "python3" "scripts/forensic/reproduce.py" *command-line-args*)}

  forensic:self-test
  {:doc "Run forensic pipeline twice and compare — validates determinism. Usage: bb forensic:self-test"
   :task (apply shell "python3" "scripts/forensic/self_test.py" *command-line-args*)}

  forensic:quorum
  {:doc "Local repeated-execution quorum: run N times in parallel, compare, report agreement.
Usage: bb forensic:quorum [--suite <key>] [--runs 3] [--threshold 2] [--workers 4]"
   :task (apply shell "python3" "scripts/forensic/quorum.py" *command-line-args*)}

  forensic:consensus
  {:doc "Phase 1 local consensus coordinator: run N times, collect submissions, compare stable fields, produce consensus certificate and disagreement artifacts per RUNNER_CONSENSUS_SPEC_V1.
Usage: bb forensic:consensus [--runs 3] [--threshold 2] [--from-dirs dir1 dir2 ...] [--from-mailbox <dir> --run-request-hash <hash>]"
   :task (apply shell "python3" "scripts/forensic/consensus.py" *command-line-args*)}

  forensic:mailbox:init
  {:doc "Initialize a new forensic mailbox directory.
Usage: bb forensic:mailbox:init <dir>"
   :task (apply shell "python3" "scripts/forensic/mailbox.py" "init" *command-line-args*)}

  forensic:mailbox:publish-run
  {:doc "Publish a run request into a mailbox.
Usage: bb forensic:mailbox:publish-run <dir> <request> [--run-id <id>]"
   :task (apply shell "python3" "scripts/forensic/mailbox.py" "publish-run" *command-line-args*)}

  forensic:mailbox:publish-submission
  {:doc "Publish a runner result submission into a mailbox.
Usage: bb forensic:mailbox:publish-submission <dir> <bundle-dir> --runner-id <id> --run-request-hash <hash> [--runner-key <key-file>]"
   :task (apply shell "python3" "scripts/forensic/mailbox.py" "publish-submission" *command-line-args*)}

  forensic:mailbox:validate
  {:doc "Validate mailbox lifecycle invariants.
Usage: bb forensic:mailbox:validate <dir> [--run-request-hash <hash>] [--identity-registry <path>] [--strict] [--require-signatures] [--output report.json]"
   :task (apply shell "python3" "scripts/forensic/mailbox.py" "validate" *command-line-args*)}

  forensic:mailbox:keygen
  {:doc "Generate an Ed25519 runner keypair.
Usage: bb forensic:mailbox:keygen --runner-id <id> --out <dir>"
   :task (apply shell "python3" "scripts/forensic/mailbox.py" "keygen" *command-line-args*)}

  ;; ── Forensic hash tasks ────────────────────────────────────────────────

  hash:source
  {:doc "Compute source tree hash (git or jj VCS detection).
         bb hash:source"
   :task (clojure "-M" "-e"
          "(require 'resolver-sim.forensic.source-hash) (flush) (System/exit (resolver-sim.forensic.source-hash/hash-source))")}

  hash:deps
  {:doc "Compute dependency classpath hash (resolved JARs).
         bb hash:deps"
   :task (clojure "-M:runner/sew" "-e"
          "(require 'resolver-sim.forensic.deps-hash) (flush) (System/exit (resolver-sim.forensic.deps-hash/hash-deps))")}

  hash:corpus
  {:doc "Compute scenario corpus hash for a suite keyword.
         bb hash:corpus :sew-invariants"
   :task (clojure "-M:with-sew" "-e"
          "(require 'resolver-sim.forensic.corpus-hash) (flush) (System/exit (resolver-sim.forensic.corpus-hash/hash-corpus *command-line-args*))")}

  test:parity
  {:doc "Verify hash parity across source checkout, clojure -M:runner/sew, and java -jar.
         bb test:parity [scenario-path]"
   :task (apply shell "./scripts/hash-parity-test.sh" *command-line-args*)}

  test:reference
  {:doc "Run the sew-reference-v1 suite and verify all scenarios pass.
         bb test:reference"
   :task (clojure "-M:runner/sew" "-m" "resolver-sim.minimal-runner" "--suite" "sew-reference-v1")}

  ;; ── Forensic evidence tasks ─────────────────────────────────────────────

  evidence:pack
  {:doc "Package a run directory into a portable evidence pack.
         Usage:
           bb evidence:pack <run-id-or-dir>            — basic pack to ./evidence-pack-<name>/
           bb evidence:pack <run-id-or-dir <out>       — pack to specific directory
           bb evidence:pack <run-id-or-dir <out> --tar — also create .tar.gz"
   :task (apply clojure "-M:with-sew" "-m" "resolver-sim.scripts.evidence-pack" "pack" *command-line-args*)}

  evidence:verify
  {:doc "Verify an evidence pack's file integrity.
         Usage: bb evidence:verify <pack-dir>"
   :task (apply clojure "-M:with-sew" "-m" "resolver-sim.scripts.evidence-pack" "verify" *command-line-args*)}

  ;; ── Build ──────────────────────────────────────────────────────────────

  build:core
  {:doc "Build prf-runner-core uberjar (6 MB, no Sew, no DB).
         java -jar target/prf-runner-core-0.1.0-uber.jar -m resolver-sim.replay-core --help"
   :task (clojure "-T:build" "uberjar" ":variant" "core")}

  build:sew
  {:doc "Build prf-runner-sew uberjar (18 MB, full Sew replay).
         java -jar target/prf-runner-sew-0.1.0-uber.jar -m resolver-sim.minimal-runner --scenario <trace.json>"
   :task (clojure "-T:build" "uberjar" ":variant" "sew")}

  build:benchmarks
  {:doc "Build prf-runner-benchmarks uberjar"
   :task (clojure "-T:build" "uberjar" ":variant" "benchmarks")}

  build:cli
  {:doc "Build prf.jar — unified CLI uberjar (same deps as sew + CLI commands).
         java -jar target/prf.jar help"
   :task (clojure "-T:build" "uberjar" ":variant" "cli")}

  build
  {:doc "Build core, sew, and CLI uberjars."
   :depends [build:core build:sew build:cli]}

  sign:core
  {:doc "GPG-sign the core uberjar for distribution.
         Requires GPG key.  Produces target/*.jar.asc."
   :task (shell "gpg" "--detach-sign" "--armor"
          "target/prf-runner-core-0.1.0-uber.jar")}

  sign:sew
  {:doc "GPG-sign the sew uberjar for distribution."
   :task (shell "gpg" "--detach-sign" "--armor"
          "target/prf-runner-sew-0.1.0-uber.jar")}

  sign
  {:doc "Sign both uberjars."
   :depends [sign:core sign:sew]}

  monitor
  {:doc "Start JMX monitoring system"
   :task (shell "clojure -M:test -m resolver-sim.monitoring")}
}}
