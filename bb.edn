  shadow:check
  {:doc "Check simulation namespaces for Solidity shadow registry coverage. Flags unregistered namespaces."
   :task (clojure {:dir "." :extra-deps {}}
                  "-M:with-sew"
                  "-e" "(require (quote resolver-sim.definitions.solidity-shadow-registry))
                        (let [unregistered (resolver-sim.definitions.solidity-shadow-registry/check-shadow-coverage)]
                          (if (seq unregistered)
                            (do (println \"Unregistered namespaces:\")
                                (doseq [m unregistered]
                                  (println \"  \" (:namespace m)))
                                (println (str (count unregistered) \" unregistered namespace(s)\"))
                                (System/exit 1))
                            (println \"All simulation namespaces have shadow entries.\")))")}

