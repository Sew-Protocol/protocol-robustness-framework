  benchmark:verify-attestation {:doc "Verify an independent attestation. Usage: bb benchmark:verify-attestation <attestation-path>"
                                :task (apply clojure "-M" "-m" "resolver-sim.benchmark.cli" "--verify-attestation" *command-line-args*)}

  benchmark:history {:doc "Display local evidence run history"
                     :task (clojure "-M" "-m" "resolver-sim.benchmark.cli" "--history")}

  benchmark:list {:doc "List available benchmarks in BENCHMARKS.edn"
                  :task (clojure "-M" "-m" "resolver-sim.benchmark.cli" "--list")}

  benchmark:verify {:doc "Verify evidence bundle integrity and signature. Usage: bb benchmark:verify [bundle-path]"
                    :task (apply clojure "-M" "-m" "resolver-sim.benchmark.cli" "--verify" *command-line-args*)}

  benchmark:hash {:doc "Compute and print hash of an evidence bundle. Usage: bb benchmark:hash [bundle-path]"
                  :task (apply clojure "-M" "-m" "resolver-sim.benchmark.cli" "--hash-only" *command-line-args*)}

  evidence:registry
  {:doc "Build the evidence registry for a run directory.
         Usage: bb evidence:registry [--dir <run-dir>]
         Defaults to the focused run or latest results/test-artifacts."
   :task (let [args (vec *command-line-args*)
               dir-idx (.indexOf args "--dir")
               dir (when (<= 0 dir-idx) (nth args (inc dir-idx) nil))]
           (clojure {:dir "." :extra-deps {}}
                    "-M" "-m" "resolver-sim.scripts.evidence" "registry" (or dir "")))}

  evidence:snapshot {:doc "Generate high-resolution social card for a scenario. Usage: bb evidence:snapshot <scenario-id>"
                     :task (shell "python3 scripts/snapshot_evidence.py" (first *command-line-args*))}

  clerk-build {:doc "Build static Clerk notebooks"
               :task (clojure "-M:build-clerk")}
  clerk-watch {:doc "Watch notebooks and rebuild"
               :task (shell "find src notebooks -name '*.clj' | entr -r bb clerk-build")}

  eastwood {:doc "eastwood"
            :task (shell "clj -M:eastwood")}


  format:json
    { :doc "Pretty print all JSON files in the repository"
      :requires ([babashka.fs :as fs]
            [cheshire.core :as json])
      :task
        (doseq [f (fs/glob "." "**/*.json")]
        (let [fs-path (str f)
              parsed (try (json/parse-string (slurp fs-path)) (catch Exception e (println "Skipping non-JSON file:" fs-path "->" (.getMessage e)) nil))]
          (when parsed
            (spit fs-path
             (json/generate-string parsed {:pretty true}))
            (println "Formatted" fs-path))))}

  lint:terminal-states
  {:doc "Flag inline terminal-state set literals that should reference t/terminal-states instead.
         Scans src/ (not test/) for #{:released :refunded :resolved} patterns that are not
         the authoritative definition in types.clj or the structural transition graph."
   :task (shell "bash" "scripts/lint-terminal-states.sh")}

  check {:doc "check"
         :task (do
                 (run 'lint:terminal-states)
                 (shell "clj -M:lint")
                 (shell "clj -M:eastwood"))}

  db:setup {:doc "Truncate XTDB and seed with sample telemetry"
            :task (do
                    (clojure "-M" "-e" "(require 'resolver-sim.db.store 'resolver-sim.db.xtdb) (resolver-sim.db.store/truncate! (resolver-sim.db.xtdb/->datasource))")
                    (clojure "-M:telemetry-seed" "20"))}

  test:integration {:doc "Run DB integration tests"
                     :task (clojure "-M:test" "-e" "(require 'clojure.test 'resolver-sim.db.telemetry-integration-test) (clojure.test/run-tests 'resolver-sim.db.telemetry-integration-test)")}

  xtdb:up {:doc "Start XTDB via Docker Compose"
           :task (shell "docker compose up -d xtdb")}

  xtdb:stop {:doc "Stop XTDB container"
             :task (shell "docker compose stop xtdb")}

  xtdb:down {:doc "Stop and remove XTDB container"
             :task (shell "docker compose down xtdb")}

  xtdb:logs {:doc "Tail XTDB container logs"
             :task (shell "docker compose logs -f xtdb")}

  xtdb:ps {:doc "Check XTDB container status"
           :task (shell "docker compose ps xtdb")}

  notebook:focus
  {:doc "Focus the provenance notebook on a specific run-id. Usage: bb notebook:focus <run-id>"
   :task (let [run-id (first *command-line-args*)]
           (when-not (seq run-id)
             (throw (ex-info "Usage: bb notebook:focus <run-id>" {})))
           (clojure.java.io/make-parents "results/.notebook-focus")
           (spit "results/.notebook-focus" run-id)
           (println "Notebook focused on run:" run-id)
           (println "Reload the Clerk notebook to see this run."))}

  notebook:latest
  {:doc "Reset the provenance notebook to always show the latest run."
   :task (let [f (java.io.File. "results/.notebook-focus")]
           (if (.delete f)
             (println "Notebook reset to latest run.")
             (println "Already showing latest run (no focus file found).")))}

  notebook:runs
  {:doc "List all available run-ids for use with notebook:focus."
   :task (let [root (java.io.File. "results/runs")]
           (if (.exists root)
             (doseq [d (sort (.listFiles root))]
               (when (.isDirectory d)
                 (println (.getName d))))
             (println "No runs found. Run bb scenario:run <scenario> first.")))}

  manifest:sign
  {:doc "Sign the focused (or latest) run manifest with Ed25519. Usage: bb manifest:sign [key-path]"
   :task (let [key-path (or (first *command-line-args*) "test_key")]
           (clojure {:dir "." :extra-deps {}} "-M:sign-manifest" key-path))}

  notebook:index
  {:doc "Open the notebook navigation hub in the browser."
   :task (do
           (println "Opening: http://localhost:7777/notebooks/index")
           (shell "bash" "-c" "xdg-open http://localhost:7777/notebooks/index 2>/dev/null || open http://localhost:7777/notebooks/index 2>/dev/null || echo 'Navigate to: http://localhost:7777/notebooks/index'"))}

  notebook:security
  {:doc "Open the security validation notebook in the browser."
   :task (do
           (println "Opening: http://localhost:7777/notebooks/security_validation")
           (shell "bash" "-c" "xdg-open http://localhost:7777/notebooks/security_validation 2>/dev/null || open http://localhost:7777/notebooks/security_validation 2>/dev/null || echo 'Navigate to: http://localhost:7777/notebooks/security_validation'"))}

  notebook:check
  {:doc "Load notebook namespaces and validate data shapes."
   :task (clojure {:dir "."}
           "-M" "-e" "(require (quote [resolver-sim.notebook.checks])) (require (quote [notebooks.report])) (println (str \"Notebook namespaces loaded. Shape checks passed.\"))")}

  notebook:lint
  {:doc "Lint notebook and notebook support code with clj-kondo"
   :task (clojure {:dir "."} "-M:lint" "--lint" "src/resolver_sim/notebook")}

  notebook:ci
  {:doc "Full notebook validation: lint + load/check"
   :depends [notebook:lint notebook:check]}}}
