{:allowed-directories ["src"
                       "test"
                       "dev"
                       "notebooks"
                       "docs"
                       "resources"
                       "scripts"
                       ".clojure-mcp"
                       "deps.edn"
                       "bb.edn"
                       "AGENTS.md"
                       "README.md"]

 :write-file-guard :partial-read

 ;; Let your existing bb tasks own formatting.
 :cljfmt false

 ;; Important: do not route bash through nREPL.
 :bash-over-nrepl false

 ;; Avoid autonomous sub-agent expansion unless explicitly wanted.
 :disable-tools [:dispatch_agent
                 :architect
                 :code_critique]

 ;; Keep scratch pad memory-only unless you explicitly want files.
 :scratch-pad-load false}

