    "attack": "profit-maximizing-incorrect-resolution",
    "actors": ["resolver"],
    "victims": ["buyer"],
    "severity": "high",
    "assumptions": [
      "resolver can execute an incorrect release",
      "fraud slash can be proposed after resolution",
      "settlement keeper may execute before slash finality"
    ]
  },
