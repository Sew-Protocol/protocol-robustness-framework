    "id": "claim.resolver-profit-maximizer-unchallenged-slash",
    "statement": "A resolver should not profit from a malicious/incorrect release if fraud slashing occurs after pending settlement.",
    "falsifies-if": [
      "resolver_net_profit > 0",
      "seller_receives_funds_before_slash_finality",
      "slash_executes_after_settlement_without_recovery_path"
    ]
  },
  "expectations": {
    "terminal-state": "released",
    "must-hold": [
      "conservation_of_funds",
      "no_resolver_profit_after_fraud_slash",
      "settlement_not_irrevocably_completed_before_fraud_window"
    ],
    "metrics": {
