{:tags ["suite/dispute-resolution" "coverage/evidence"]
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000}
 :threat-tags ["dispute-resolution" "evidence" "resolver" "unavailable" "rotation"]
 :purpose "adversarial-robustness"
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000 :custom-resolver "0xresolver1"}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 2 :time 1090 :agent "seller" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xevidence-before-unavailable"}}
          {:seq 3 :time 1100 :agent "keeper" :action "set_resolver_unavailable" :params {:resolver "0xresolver1" :unavailable? true}}
          {:seq 4 :time 1120 :agent "seller" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xevidence-while-unavailable"}}
          {:seq 5 :time 1130 :agent "governance" :action "rotate_dispute_resolver" :params {:workflow-id 0 :new-resolver "0xresolver2"}}
          {:seq 6 :time 1150 :agent "resolver2" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xhash"}}
          {:seq 7 :time 1250 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}]
 :schema-version "1.0"
 :scenario-title "Unavailable resolver mid-dispute — evidence works while unavailable, then rotation + new resolver resolves"
 :scenario-author "@kilo-research"
 :scenario-id "s-dr-091-unavailable-resolver-mid-dispute"
 :scenario-purpose "Verify that evidence can be submitted while the assigned resolver is unavailable (submit_evidence only checks escrow state, not resolver availability). After rotation to a new resolver, the dispute resolves normally."
 :scenario-notes "Resolution at t=1150 creates pending settlement with deadline 1150+60=1210, settlement at t=1250 passes deadline. Evidence at t=1090 (before unavailable) and t=1120 (while unavailable) both succeed because submit_evidence only checks :disputed state. Rotation at t=1130 assigns resolver2 who resolves at t=1150. Verifies the full path: unavailable → evidence → rotation → resolution."
 :provenance {:author-id "@kilo-research" :author "Kilo Research"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver1" :address "0xresolver1" :role "resolver"}
          {:id "resolver2" :address "0xresolver2" :role "resolver"}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :initial-block-time 1000}
