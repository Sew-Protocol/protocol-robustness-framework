{:scenario-id "dr-e-002-rotate-before-resolution"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Governance rotates dispute resolver before any resolution — new resolver succeeds"
 :description "A dispute is raised on an escrow. Before the resolver submits a resolution, governance rotates to a different resolver. The new resolver then executes the resolution. Tests that governance can safely swap resolver mid-dispute when no pending settlement exists."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-29" :license "CC-BY-4.0"}
 :claim {:id "governance-rotate-before-resolution"
         :statement "Governance can rotate the dispute resolver mid-dispute before any resolution is submitted (no pending settlement). The new resolver is authorized to resolve via Priority 3 fallback."
         :falsifies-if ["Rotate fails when no resolution has been submitted" "New resolver cannot execute resolution after rotation"]}
 :expectations {:terminal-state "refunded"
                :must-hold ["dispute_level_bounded" "resolver_decision_attributable"]
                :metrics {:rotation_count {:gte 1}
                          :final_resolver {:eq "0xnew"}}}
 :threat {:family "governance-attack" :attack "resolver-rotation-pre-resolution" :severity "medium"
          :actors ["governance"]
          :assumptions ["Rotation happens before any resolution (no pending settlement)"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "oldResolver" "newResolver" "protocol"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000
                   :dispute-resolver "0xold"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "oldResolver" :address "0xold" :role "resolver"}
          {:id "newResolver" :address "0xnew" :role "resolver"}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; Governance rotates resolver BEFORE any resolution (no pending settlement exists)
          {:seq 2 :time 1080 :agent "governance" :action "rotate_dispute_resolver"
           :params {:workflow-id 0 :new-resolver "0xnew"}}
          ;; New resolver executes resolution (authorized via Priority 3: dispute-resolver = 0xnew)
          {:seq 3 :time 1100 :agent "newResolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xnewhash"}}
          {:seq 4 :time 1200 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}]}
