{:tags ["suite/dispute-resolution" "coverage/resolver-integrity"], :protocol-params {:resolver-fee-bps 150, :appeal-window-duration 0, :max-dispute-duration 2592000}, :allow-open-disputes? true, :threat-tags ["dispute-resolution" "governance" "capacity" "finding-4"], :purpose "theory-falsification", :events [{:seq 0, :time 1000, :agent "buyer", :action "create_escrow", :params {:token "USDC", :to "0xseller", :amount 5000, :custom-resolver "0xresolver"}} {:seq 1, :time 1020, :agent "seller", :action "raise_dispute", :params {:workflow-id 0}} {:seq 2, :time 1050, :agent "resolver", :action "execute_resolution", :params {:workflow-id 0, :is-release false, :resolution-hash "0xunreviewed-fraud"}} {:seq 3, :time 1150, :agent "buyer", :action "sender_cancel", :params {:workflow-id 0}}], :schema-version "1.0", :scenario-title "Governance capacity bypass — limited governance capacity gamed by value-tier-aware attacker", :scenario-author "@kilo-research", :scenario-id "s-dr-074-governance-capacity-bypass", :scenario-purpose "Bridge to Finding 4 (governance capacity scaling): a governance actor with limited review capacity (cap=3) is gamed by an attacker who selects dispute value tiers that fall below the governance review threshold. The attacker wins because low-value disputes are never reviewed.", :scenario-notes "Escrow (5000 USDC) where the seller raises a fraudulent dispute. The malicious resolver rules in seller's favour (is-release=false, refunding to seller). With limited governance capacity, this dispute may fall below the review threshold. The buyer has no recourse but sender_cancel. This bridges the Phase AA Monte Carlo result (20% attacker win-rate breaks under limited capacity) to a deterministic trace. Note: the challenge-bond-proportional invariant passes here because escrow value (5000) exceeds the default challenge bond (100).", :provenance {:author-id "@kilo-research", :author "Kilo Research"}, :agents [{:id "buyer", :address "0xbuyer", :strategy "honest"} {:id "seller", :address "0xseller", :strategy "malicious"} {:id "resolver", :address "0xresolver", :role "resolver", :strategy "malicious"}], :initial-block-time 1000}