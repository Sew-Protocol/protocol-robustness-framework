{:scenario-id "dr-o-001-resolver-overflow-basic"
 :schema-version "1.0"
 :purpose "liveness"
 :title "Resolver overflow: governance authorises failover when resolver is overcapacity"
 :description "A resolver is overcapacity with active disputes. Governance authorises a resolver-overflow, and a listed failover resolver executes a resolution under the overflow. Demonstrates the scoped failover authorisation path as an alternative to the normal resolver-authorization chain."
 :provenance {:author "@protocol-team" :created-at "2026-07-02" :license "CC-BY-4.0"}
 :claim {:id "resolver-overflow-restores-liveness"
         :statement "When the designated resolver is unavailable or overcapacity, governance can authorise a resolver-overflow and a failover resolver can resolve disputes under it."
         :falsifies-if ["An overflow-authorised resolution is rejected by the protocol"]
         :assumptions ["Governance address is configured in protocol-params"
                       "Failover resolver is listed in the overflow record"]}
 :expectations {:must-hold ["dispute_timestamp_consistency"
                            "dispute_level_bounded"
                            "no_duplicate_dispute"
                            "dispute_resolution_path"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150
                   :appeal-window-duration 120
                   :max-dispute-duration 2592000
                   :dispute-resolver "0xprimary"
                   :resolver-overflow-policy
                   {:default-duration 3600
                    :max-duration 86400
                    :default-max-workflows 100
                    :max-workflows 500
                    :failover-resolvers #{"0xfailover"}
                    :allowed-reasons #{:resolver-overcapacity}}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "governance" :address "0xgovernance" :role "governance"}
          {:id "primary" :address "0xprimary" :role "resolver"}
          {:id "failover" :address "0xfailover" :role "resolver"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute"
           :params {:workflow-id 0}}
          ;; Governance authorises resolver overflow for the primary resolver
          {:seq 2 :time 1100 :agent "governance" :action "activate_resolver_overflow"
           :params {:resolver "0xprimary"
                    :reason :resolver-overcapacity}}
          ;; Failover resolver resolves under the overflow
          {:seq 3 :time 1120 :agent "failover" :action "execute_overflow_resolution"
           :params {:workflow-id 0 :overflow-id 0 :is-release true}}
          ;; Keeper executes pending settlement after appeal window
          {:seq 4 :time 1300 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}]}
