{:scenario-id "dr-o-003-vindication-zero-stake"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Vindication with zero stake: behavior when resolver has no remaining stake"
 :description "L0 resolver registers zero stake (or has their entire stake consumed by prior slash events). L0 rules release. L1 reverses to refund (Track 1 auto-slash on L0 at 25% = 0 debited). L2 reverses to release (vindicates L0). Tests behavior when resolver has zero stake at vindication time. If the protocol invariant requires nonzero stake for resolvers, this scenario documents that precondition. If zero is valid, asserts no underflow and correct :reversed-with-credit transition."
 :provenance {:author "@dispute-researcher" :created-at "2026-07-01" :license "CC-BY-4.0"}
 :claim {:id "vindication-zero-stake"
         :statement "When a resolver with zero stake is vindicated by a higher level, the protocol either: (a) prevents zero-stake resolvers from participating (invariant), or (b) handles the credit without underflow. This scenario documents which behavior applies."
         :falsifies-if ["Underflow during zero-stake credit"
                        "Slash status transition error"
                        "Protocol crash or nil deref"]}
 ;; Note: If zero stake is invalid by protocol invariant, update
 ;; :expected/invariants to document the precondition and convert this
 ;; to an expected-fail scenario with :expected-failures.
 :expectations {:terminal-state "released"
                :must-hold ["resolver_decision_attributable"]
                :metrics {:l0_slash_status {:in #{:executed :reversed-with-credit nil}}
                          :protocol_stable? {:eq true}}}
 :expected/invariants
 [:stake/non-negative
  :resolver/balances-conserved]
 :threat {:family "economic-fairness" :attack "zero-stake-vindication" :severity "low"
          :actors ["l0resolver"]
          :assumptions ["Protocol handles zero-stake resolvers gracefully"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "l2resolver" "protocol"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500
                   :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1" :2 "0xl2"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 0}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "l2resolver" :address "0xl2" :role "resolver" :stake 10000}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l1resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l2resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 4 :time 1100 :agent "l0resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          {:seq 5 :time 1150 :agent "l1resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; L2 agrees with L0 — L0 vindicated, L1 slashed
          {:seq 6 :time 1200 :agent "l2resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl2release"}}]}
