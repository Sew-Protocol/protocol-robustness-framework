{:scenario-id "dr-e-001-rotate-mid-escalation-pending-blocked"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Governance rotate blocked when pending settlement exists"
 :description "Governance attempts to rotate the dispute resolver while a pending settlement exists (resolution has been submitted but appeal window has not expired). The rotate-dispute-resolver guard rejects with :resolution-already-pending because rotating the resolver would orphan the pending settlement."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-29" :license "CC-BY-4.0"}
 :claim {:id "rotate-blocked-during-pending-settlement"
         :statement "Governance cannot rotate a dispute resolver while a pending settlement exists. The escrow must be :disputed with no active pending settlement for rotation to proceed."
         :falsifies-if ["Resolve rotates while pending settlement exists" "Old resolver can execute resolution after rotation"]}
 :expectations {:terminal-state "released"
                :must-hold ["pending_settlement_consistent"]
                 :error-on-seq [3]
                 :expected-errors {:seq 3 :error :resolution-already-pending}}
 :threat {:family "governance-attack" :attack "rotate-with-pending-settlement" :severity "high"
          :actors ["governance"] :victims ["seller"]
          :assumptions ["Pending settlement exists on workflow"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "oldResolver" "newResolver" "protocol"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "oldResolver" :address "0xold" :role "resolver"}
          {:id "newResolver" :address "0xnew" :role "resolver"}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000 :custom-resolver "0xold"}}
          {:seq 1 :time 1060 :agent "seller" :action "raise_dispute" :params {:workflow-id 0}}
          ;; Old resolver executes resolution — creates pending settlement
          {:seq 2 :time 1100 :agent "oldResolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release true :resolution-hash "0xhash"}}
          ;; Governance tries to rotate while pending exists — blocked
          {:seq 3 :time 1120 :agent "governance" :action "rotate_dispute_resolver"
           :params {:workflow-id 0 :new-resolver "0xnew"}}
          ;; After appeal window expires, execute settlement
          {:seq 4 :time 1200 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}]}
