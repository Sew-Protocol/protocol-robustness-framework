{:scenario-id "dr-n-001-reversal-slash-appeal-lifecycle"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Reversal reviewer due process: L1 reversal slash appealed via Track 2 — upheld, reversed with credit"
 :description "Full L0→L1→L2 chain. L0 rules release. L1 reverses to refund (Track 1 auto-slash on L0, slash-id 0-reversal-0). L2 reverses back to release (Track 1 auto-slash on L1, slash-id 0-reversal-1). L0's slash is vindicated (L2 agreed with L0). L1 now has an auto-slash. L1 submits new evidence and appeals their own reversal slash via Track 2. Governance upholds the appeal: L1's slash is reversed, stake credited back. Verifies the full due-process lifecycle for a reversal reviewer — an L1 resolver who reversed L0 and was themselves reversed by L2 may appeal their own resulting slash."
 :provenance {:author "@dispute-researcher" :created-at "2026-07-01" :license "CC-BY-4.0"}
 :claim {:id "reversal-reviewer-due-process"
         :statement "An L1 resolver who reversed L0 and was subsequently reversed by L2 (receiving an auto-slash) may appeal their own reversal slash via Track 2 (submit evidence + governance appeal upheld). The slash transitions through the full lifecycle: proposed → executed → appeal/opened → appeal/resolved → reversed-with-credit."
         :falsifies-if ["L1 cannot appeal their own reversal slash"
                        "L1 slash is not reversed after upheld appeal"
                        "L1 stake is not credited back after reversal"
                        "Lifecycle does not include :reversal-slash/reversed"
                        "Appeal bond is not refunded on upheld"]}
 :expected/events
 [:reversal-slash/proposed    ;; Track 1 on L0 when L1 reverses
  :reversal-slash/executed    ;; L0 slash executed immediately
  :reversal-slash/proposed    ;; Track 1 on L1 when L2 reverses
  :reversal-slash/executed    ;; L1 slash executed immediately
  :appeal/opened              ;; L1 appeals their own slash via Track 2
  :appeal/resolved            ;; Governance rules on L1's appeal
  :reversal-slash/reversed]   ;; L1's slash reversed with credit
 :expected/not-events
 [:reversal-slash/reversed    ;; L0's slash is ALSO reversed by vindication
  nil]                        ;; (but that's a different event — L0 reversed via vindication, L1 via appeal)
 :expectations {:terminal-state "released"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable" "appeal_reversal_detectable"]
                :metrics {:l0_slash_status {:eq :reversed-with-credit}
                          :l1_slash_status {:eq :reversed-with-credit}
                          :l0_stake_recovered {:gte 1}
                          :l1_stake_recovered {:gte 1}
                          :l1_appeal_bond_refunded? {:eq true}
                          :slash_count {:eq 0}}}  ;; both reversed, no active slash
 :expected/invariants
 [:stake/non-negative
  :slash/requested-equals-debited-plus-unmet-plus-reversed
  :bounty/no-overpayment
  :resolver/balances-conserved]
 :threat {:family "economic-fairness" :attack "reversal-reviewer-due-process" :severity "high"
          :actors ["l1resolver"] :victims ["l1resolver"]
          :assumptions ["Track 2 appeal open to reversal reviewers" "Governance can uphold a slash appeal"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "l2resolver" "governance" "protocol" "slashPool" "insurance"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :appeal-bond-bps 500
                   :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1" :2 "0xl2"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "l2resolver" :address "0xl2" :role "resolver" :stake 10000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "l2resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 3 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 4 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 rules: release
          {:seq 5 :time 1100 :agent "l0resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          ;; L1 reverses to refund — Track 1 auto-slash on L0 (0-reversal-0, executed)
          {:seq 6 :time 1150 :agent "l1resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; L2 reverses back to release — Track 1 auto-slash on L1 (0-reversal-1, executed)
          ;; L0 vindicated by L2 agreement (L0 slash reversed-with-credit)
          {:seq 7 :time 1200 :agent "l2resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl2release"}}
          ;; L1 submits new evidence to support Track 2 appeal of their own slash
          {:seq 8 :time 1250 :agent "l1resolver" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xl1-justification"}}
          ;; L1 appeals their own reversal slash within window (deadline 1200+120=1320)
          {:seq 9 :time 1300 :agent "l1resolver" :action "appeal_slash" :params {:workflow-id 0 :slash-id "0-reversal-1"}}
          ;; Governance upholds L1's appeal: slash reversed, bond refunded
          {:seq 10 :time 1400 :agent "governance" :action "resolve_appeal" :params {:workflow-id 0 :slash-id "0-reversal-1" :upheld? true}}
          ;; Keeper executes pending settlement
          {:seq 11 :time 2000 :agent "keeper" :action "automate_timed_actions" :params {:workflow-id 0}}]}
