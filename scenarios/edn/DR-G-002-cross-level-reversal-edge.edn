{:scenario-id "dr-g-002-cross-level-reversal-edge"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Cross-level reversal edge case: L0 auto-slashed by L1 reversal, then L2 vindicates L0 — slash reversed"
 :description "Full L0→L1→L2 chain. L0 rules release. L1 reverses to refund (auto-slashing L0 via Track 1). L2 reverses back to release (agreeing with L0, auto-slashing L1). With the vindication fix, L0's auto-slash is now reversed (marked :reversed-with-credit) because L2 agreed with L0. L1's auto-slash remains :executed because L1 was wrong."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "irreversible-auto-slash-vulnerability"
         :statement "Auto-track (Track 1) reversal slashing is now reversible: when L2 agrees with L0's original decision (vindicating the lower resolver), the auto-slash on L0 is reversed with a credit. Only L1 (the intermediate reversing resolver) retains their slash."
         :falsifies-if ["L0 slash is not reversed when L2 agrees with L0"
                        "L1 slash is reversed (L1 made the wrong call)"
                        "L0 resolver stake is not credited back"
                        "Slash entry is not marked :reversed-with-credit"]}
 :expectations {:terminal-state "released"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:l0_slash_status {:eq :reversed-with-credit}
                          :l1_slash_status {:eq :executed}
                          :l0_stake_recovered {:gte 1}}}
 :threat {:family "economic-fairness" :attack "irreversible-auto-slash-fixed" :severity "low"
          :actors ["l0resolver"] :victims ["l0resolver"]
          :assumptions ["vindicated-by-later-level fix is applied"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "l2resolver" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1" :2 "0xl2"}
                   }
 :options {:flags {:check-invariants? false}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "l2resolver" :address "0xl2" :role "resolver" :stake 10000}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake"
           :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake"
           :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "l2resolver" :action "register_stake"
           :params {:amount 10000}}
          {:seq 3 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 10000}}
          {:seq 4 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
           ;; L0 rules: release to seller
           {:seq 5 :time 1100 :agent "l0resolver" :action "execute_resolution"
            :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
           ;; Escalate to L1
           {:seq 6 :time 1120 :agent "seller" :action "escalate_dispute" :params {:workflow-id 0}}
           ;; L1 reverses to refund — Track 1 auto-slash on L0 (slash-id "0-reversal-0", :executed)
           {:seq 7 :time 1150 :agent "l1resolver" :action "execute_resolution"
            :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
           ;; Escalate to L2
           {:seq 8 :time 1180 :agent "buyer" :action "escalate_dispute" :params {:workflow-id 0}}
           ;; L2 rules release (agrees with L0) — Track 1 auto-slash on L1 (slash-id "0-reversal-1", :executed)
           ;; L2 is final round — executes immediately (no pending settlement)
           ;; With vindication fix: L0's auto-slash is reversed, L1's auto-slash stays
           {:seq 9 :time 1200 :agent "l2resolver" :action "execute_resolution"
            :params {:workflow-id 0 :is-release true :resolution-hash "0xl2release"}}]}
