{:scenario-id "dr-fa-002-force-authorisation-expired"
 :schema-version "1.0"
 :purpose "liveness"
 :title "Force-authorisation: execution rejected after expiration window closes"
 :description "Governance grants a force-authorisation with a short duration. The executor attempts to use it after the expiration window has passed. The action is rejected with :force-authorisation-expired. Demonstrates that the time-bounded scope is enforced."
 :provenance {:author "@protocol-team" :created-at "2026-07-08" :license "CC-BY-4.0"}
 :claim {:id "force-authorisation-expiry-enforced"
         :statement "A force-authorisation with an expiration window rejects execution attempts after the window closes."
         :falsifies-if ["A force-authorised resolution succeeds after the expiration window has passed"]
         :assumptions ["Governance address is configured in protocol-params"]}
 :allow-open-disputes? true
 :expectations {:must-hold ["dispute_timestamp_consistency"
                            "dispute_level_bounded"
                            "no_duplicate_dispute"]
                :error-on-seq [3]
                :expected-errors {:seq 3 :error :force-authorisation-expired}}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150
                   :appeal-window-duration 120
                   :max-dispute-duration 2592000
                   :dispute-resolver "0xprimary"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "governance" :address "0xgovernance" :role "governance"}
          {:id "primary" :address "0xprimary" :role "resolver"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute"
           :params {:workflow-id 0}}
          ;; Governance grants force-authorisation with short duration (expires at 1150)
          {:seq 2 :time 1100 :agent "governance" :action "grant_force_authorization"
           :params {:workflow-id 0 :reason :manual-override :duration 50}}
          ;; Keeper tries to execute after expiration — rejected
          {:seq 3 :time 1200 :agent "keeper" :action "execute_force_authorized_action"
           :params {:workflow-id 0 :authorization-id "fa-0" :is-release true}}]}

