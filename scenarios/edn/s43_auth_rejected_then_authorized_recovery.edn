{"scenario-id" "s43-auth-rejected-then-authorized-recovery",
 "schema-version" "1.0",
 "scenario-author" "@grifma",
 "initial-block-time" 1000,
 "protocol-params" {"resolver-fee-bps" 150,
                    "appeal-window-duration" 0,
                    "max-dispute-duration" 2592000},
 "agents" [{"id" "buyer", "address" "0xbuyer", "strategy" "honest"}
           {"id" "seller", "address" "0xseller", "strategy" "honest"}
           {"id" "badresolver",
            "address" "0xbadresolver",
            "strategy" "malicious",
            "role" "resolver"}
           {"id" "resolver",
