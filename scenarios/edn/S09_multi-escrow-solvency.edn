{"scenario-id" "s09-multi-escrow-solvency",
 "schema-version" "1.0",
 "initial-block-time" 1000,
 "agents" [{"id" "buyer0", "address" "0xbuyer0", "strategy" "honest"}
           {"id" "buyer1", "address" "0xbuyer1", "strategy" "honest"}
           {"id" "buyer2", "address" "0xbuyer2", "strategy" "honest"}
           {"id" "seller", "address" "0xseller", "strategy" "honest"}
           {"id" "resolver",
            "address" "0xresolver",
            "role" "resolver"}],
 "protocol-params" {"resolver-fee-bps" 150,
                    "appeal-window-duration" 0,
                    "max-dispute-duration" 2592000},
 "events" [{"seq" 0,
            "time" 1000,
            "agent" "buyer0",
            "action" "create_escrow",
            "params" {"token" "USDC", "to" "0xseller", "amount" 1000}}
           {"seq" 1,
            "time" 1000,
            "agent" "buyer1",
            "action" "create_escrow",
            "params" {"token" "USDC",
                      "to" "0xseller",
                      "amount" 2000,
                      "custom-resolver" "0xresolver"}}
           {"seq" 2,
            "time" 1000,
            "agent" "buyer2",
            "action" "create_escrow",
            "params" {"token" "USDC",
                      "to" "0xseller",
                      "amount" 3000,
                      "custom-resolver" "0xresolver"}}
           {"seq" 3,
            "time" 1060,
            "agent" "buyer0",
            "action" "release",
            "params" {"workflow-id" 0}}
           {"seq" 4,
            "time" 1060,
            "agent" "buyer1",
            "action" "raise_dispute",
            "params" {"workflow-id" 1}}
           {"seq" 5,
            "time" 1060,
            "agent" "buyer2",
            "action" "raise_dispute",
            "params" {"workflow-id" 2}}
           {"seq" 6,
            "time" 1120,
            "agent" "resolver",
            "action" "execute_resolution",
            "params" {"workflow-id" 1,
                      "is-release" true,
                      "resolution-hash" "0xh1"}}
           {"seq" 7,
            "time" 1180,
            "agent" "resolver",
            "action" "execute_resolution",
            "params" {"workflow-id" 2,
                      "is-release" true,
                      "resolution-hash" "0xh2"}}],
