{:scenario-id "dr-n-002-reversal-slash-appeal-rejected"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Reversal reviewer due process: L1 reversal slash appeal rejected — slash stays executed"
 :description "Same chain as DR-N-001: L0→L1→L2. L1 reversed L0, L2 reversed L1 (L1 auto-slashed). L1 submits new evidence and appeals their own reversal slash via Track 2. Governance rejects the appeal: slash remains executed, appeal bond forfeited to insurance pool. Verifies the rejected path for reversal reviewer slash appeals."
 :provenance {:author "@dispute-researcher" :created-at "2026-07-01" :license "CC-BY-4.0"}
 :claim {:id "reversal-reviewer-appeal-rejected"
         :statement "When an L1 reversal reviewer's Track 2 appeal is rejected, their auto-slash remains executed, the appeal bond is forfeited to insurance, and the slash is not reversed."
         :falsifies-if ["L1 slash is reversed despite rejection"
                        "Appeal bond is refunded despite rejection"
                        "Slash lifecycle shows :reversal-slash/reversed"
                        "Resolver balance is not deducted"]}
 :expected/events
 [:reversal-slash/proposed
  :reversal-slash/executed
  :appeal/opened
  :appeal/resolved]
 :expected/not-events
 [:reversal-slash/reversed]
 :expectations {:terminal-state "released"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:l1_slash_status {:eq :executed}
                          :l1_stake_deducted {:gt 0}
                          :appeal_bond_forfeited? {:eq true}}}
 :expected/invariants
 [:stake/non-negative
  :slash/requested-equals-debited-plus-unmet-plus-reversed
  :resolver/balances-conserved]
 :threat {:family "economic-fairness" :attack "reversal-reviewer-appeal-rejected" :severity "high"
          :actors ["l1resolver"] :victims ["l1resolver"]
          :assumptions ["Governance can reject a reversal reviewer appeal" "Bond forfeited on rejection"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "l2resolver" "governance" "protocol" "slashPool" "insurance"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :appeal-bond-bps 500
                   :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1" :2 "0xl2"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "l2resolver" :address "0xl2" :role "resolver" :stake 10000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "l2resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 3 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 4 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 5 :time 1100 :agent "l0resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          {:seq 6 :time 1150 :agent "l1resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          {:seq 7 :time 1200 :agent "l2resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl2release"}}
          {:seq 8 :time 1250 :agent "l1resolver" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xl1-false-justification"}}
          {:seq 9 :time 1300 :agent "l1resolver" :action "appeal_slash" :params {:workflow-id 0 :slash-id {:slash-ref {:workflow-id 0 :kind :reversal :level 1}}}}
          {:seq 10 :time 1400 :agent "governance" :action "resolve_appeal" :params {:workflow-id 0 :slash-id {:slash-ref {:workflow-id 0 :kind :reversal :level 1}} :upheld? false}}
          {:seq 11 :time 2000 :agent "keeper" :action "automate_timed_actions" :params {:workflow-id 0}}]}
