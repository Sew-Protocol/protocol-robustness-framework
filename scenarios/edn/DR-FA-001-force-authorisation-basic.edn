{:scenario-id "dr-fa-001-force-authorisation-basic"
 :schema-version "1.0"
 :purpose "liveness"
 :title "Force-authorisation: governance grants scoped override and executor resolves under it"
 :description "Governance grants a force-authorisation for a disputed escrow workflow when the resolver path is unavailable. A keeper executes the force-authorised resolution, which succeeds, and the settlement is finalised. Demonstrates the full force-authorisation lifecycle: grant, execute, consume, evidence."
 :provenance {:author "@protocol-team" :created-at "2026-07-08" :license "CC-BY-4.0"}
 :claim {:id "force-authorisation-restores-liveness"
         :statement "Governance can grant a scoped, expiring, single-use force-authorisation for a specific workflow, and an executor can resolve the dispute under that authorisation."
         :falsifies-if ["A force-authorised resolution is rejected when all preconditions are met"
                        "The authorisation record is not marked consumed after execution"
                        "Evidence is not emitted for grant or execute"]
         :assumptions ["Governance address is configured in protocol-params"]}
 :expectations {:must-hold ["dispute_timestamp_consistency"
                            "dispute_level_bounded"
                            "no_duplicate_dispute"
                            "dispute_resolution_path"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150
                   :appeal-window-duration 120
                   :max-dispute-duration 2592000
                   :dispute-resolver "0xprimary"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "governance" :address "0xgovernance" :role "governance"}
          {:id "primary" :address "0xprimary" :role "resolver"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute"
           :params {:workflow-id 0}}
          ;; Governance grants force-authorisation for the disputed escrow
          {:seq 2 :time 1100 :agent "governance" :action "grant_force_authorization"
           :params {:workflow-id 0 :reason :manual-override :duration 3600}}
          ;; Keeper executes the force-authorised resolution
          {:seq 3 :time 1120 :agent "keeper" :action "execute_force_authorized_action"
           :params {:workflow-id 0 :authorization-id "fa-0" :is-release true}}
          ;; Keeper executes pending settlement after appeal window
          {:seq 4 :time 1300 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}]}

