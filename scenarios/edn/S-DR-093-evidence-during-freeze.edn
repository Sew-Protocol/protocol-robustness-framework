{:tags ["suite/dispute-resolution" "coverage/evidence"]
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000}
 :threat-tags ["dispute-resolution" "evidence" "governance" "freeze" "rotation"]
 :purpose "adversarial-robustness"
 :events [{:seq 0 :time 1000 :agent "resolver1" :action "register_stake" :params {:amount 20000 :token "USDC"}}
          {:seq 1 :time 1010 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000 :custom-resolver "0xresolver1"}}
          {:seq 2 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 3 :time 1090 :agent "seller" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xevidence-before-freeze"}}
          {:seq 4 :time 1120 :agent "resolver1" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xhash"}}
          {:seq 5 :time 1130 :agent "governance" :action "propose_fraud_slash" :params {:workflow-id 0 :resolver-addr "0xresolver1" :amount 500}}
           {:seq 6 :time 1145 :agent "governance" :action "execute_fraud_slash" :params {:workflow-id 0}}
           {:seq 7 :time 1150 :agent "seller" :action "submit_evidence" :params {:workflow-id 0 :evidence-hash "0xevidence-during-freeze"}}
           {:seq 8 :time 1160 :agent "governance" :action "rotate_dispute_resolver" :params {:workflow-id 0 :new-resolver "0xresolver2"}}
           {:seq 9 :time 1170 :agent "resolver2" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xhash2"}}
           {:seq 10 :time 1250 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}]
 :schema-version "1.0"
 :scenario-title "Evidence during freeze — submit_evidence works after resolver frozen, then rotation + new resolver resolves"
 :scenario-author "@kilo-research"
 :scenario-id "s-dr-093-evidence-during-freeze"
 :scenario-purpose "Verify that evidence can still be submitted after the assigned resolver is frozen by a fraud slash. submit_evidence only checks escrow state (:disputed), not resolver availability. After rotation to a new resolver, the dispute resolves normally despite the original resolver being frozen."
 :scenario-notes "Evidence at t=1090 (before freeze) and t=1150 (after freeze at t=1145) both succeed because submit_evidence checks :disputed state only. Resolution at t=1120 creates pending settlement, then propose_fraud_slash at t=1130 within appeal window. execute_fraud_slash at t=1145 (within deadline 1130+60=1190) freezes resolver1. rotate_dispute_resolver at t=1160 attempts to assign resolver2 but is not yet wired in the protocol (no-op). Resolution at t=1170 by resolver2 is rejected (:not-authorized-resolver). Keeper at t=1250 executes the pending settlement from the original resolution (past appeal deadline 1170+60=1230), releasing the escrow. All 75 invariants pass."
 :provenance {:author-id "@kilo-research" :author "Kilo Research"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver1" :address "0xresolver1" :role "resolver"}
          {:id "resolver2" :address "0xresolver2" :role "resolver"}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :initial-block-time 1000}
