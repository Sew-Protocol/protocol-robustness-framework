{:scenario-id "dr-q-002-challenge-bounty-no-challenger"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Challenge bounty with no challenger: no bounty paid, no funds leak"
 :description "L0 rules release (no evidence submitted by any challenger). L1 reverses to refund (Track 1 auto-slash on L0). Because no challenger was recorded before the reversal, no bounty is paid. Verifies: (a) no nil deref when challenger is absent, (b) no funds leak to keeper or protocol, (c) slash pool accounting is consistent, (d) no phantom bounty created."
 :provenance {:author "@dispute-researcher" :created-at "2026-07-01" :license "CC-BY-4.0"}
 :claim {:id "challenge-bounty-no-challenger"
         :statement "When a reversal slash occurs without a recorded challenger, no bounty is paid. The absence of a challenger does not cause a nil deref, funds leak, or phantom bounty."
         :falsifies-if ["Bounty paid when no challenger exists"
                        "Nil deref during bounty evaluation"
                        "Funds leak to keeper or protocol"
                        "Slash pool shows phantom deduction"
                        "Reversal slash fails due to missing challenger check"]}
 :expected/events
 [:reversal-slash/proposed
  :reversal-slash/executed]
 :expected/not-events
 [:bounty/paid-to-challenger
  :bounty/paid-to-keeper
  :error/missing-challenger]
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:bounty_paid? {:eq false}
                          :slash_pool_conserved? {:eq true}
                          :no_nil_deref {:eq true}
                          :keeper_balance_unchanged {:eq true}}}
 :expected/invariants
 [:slash/requested-equals-debited-plus-unmet-plus-reversed
  :resolver/balances-conserved]
 :threat {:family "economic-incentives" :attack "challenge-bounty-absent" :severity "medium"
          :actors ["protocol"]
          :assumptions ["No challenger → no bounty" "Nil challenger does not cause failure"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "keeper" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :challenge-bounty-bps 500
                   :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 rules: release (no evidence submitted by any challenger)
          {:seq 4 :time 1100 :agent "l0resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          ;; L1 reverses to refund — Track 1 auto-slash on L0; no challenger → no bounty
          {:seq 5 :time 1150 :agent "l1resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; Execute pending settlement after window
          {:seq 6 :time 1400 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}]}
