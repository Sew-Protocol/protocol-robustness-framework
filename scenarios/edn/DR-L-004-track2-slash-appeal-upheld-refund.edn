{:scenario-id "dr-l-004-track2-slash-appeal-upheld-refund"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Track 2 reversal slash: appeal upheld, slash reversed, bond refunded"
 :description "Track 2 pending reversal slash created via submit-evidence + reversal. Resolver appeals within window. Governance upholds the appeal: slash is reversed, appeal bond is refunded via claimable. Verifies the upheld path for reversal slashes with string slash-ids."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "track2-slash-appeal-upheld-reversal-slash-id"
         :statement "When governance upholds a slash appeal for a Track 2 reversal slash (with string slash-id '0-reversal-0'), the slash is reversed and the appeal bond is refunded."
         :falsifies-if ["resolve-appeal fails with correct string slash-id"
                        "Slash is not reversed after upheld appeal"
                        "Appeal bond is not refunded"]}
:expected-failures {:dr-l-004-track2-slash-appeal-upheld-refund [:no-stale-automatable-escrows]}
:expectations {:terminal-state "refunded"
               :metrics {:slash_count {:eq 0}  ;; slash reversed, not executed
                         :appeal_bond_refunded? {:eq true}}}
 :threat {:family "resolution-slashing" :attack "track2-appeal-upheld-reversal-slash-id" :severity "high"
          :actors ["resolver"] :victims ["protocol"]
          :assumptions ["Governance can uphold a slash appeal with string slash-id"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "resolver" "governance" "protocol" "claimableBalances"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :appeal-bond-bps 500
                   :dispute-resolver "0xresolver-l0"
                   :escalation-resolvers {:1 "0xresolver-l1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver-l0" :address "0xresolver-l0" :role "resolver" :stake 20000}
          {:id "resolver-l1" :address "0xresolver-l1" :role "resolver" :stake 20000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "resolver-l0" :action "register_stake"
           :params {:amount 20000}}
          {:seq 1 :time 1000 :agent "resolver-l1" :action "register_stake"
           :params {:amount 20000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "seller" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 4 :time 1120 :agent "resolver-l0" :action "execute_resolution"
           :params {:workflow-id 0 :is-release true :resolution-hash "0xrelease"}}
          {:seq 5 :time 1150 :agent "seller" :action "submit_evidence"
           :params {:workflow-id 0 :evidence-hash "0xnew-evidence"}}
          {:seq 6 :time 1160 :agent "seller" :action "escalate_dispute"
           :params {:workflow-id 0}}
          ;; L1 reverses L0: creates pending Track 2 slash (deadline = 1200+120 = 1320)
          {:seq 7 :time 1200 :agent "resolver-l1" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xreversal"}}
          ;; Resolver appeals within window
          {:seq 8 :time 1310 :agent "resolver-l0" :action "appeal_slash"
           :params {:workflow-id 0 :slash-id {:slash-ref {:workflow-id 0 :kind :reversal :level 0}}}}
           ;; Governance UPHOLDS: slash reversed, bond refunded
           {:seq 9 :time 1400 :agent "governance" :action "resolve_appeal"
            :params {:workflow-id 0 :slash-id {:slash-ref {:workflow-id 0 :kind :reversal :level 0}} :upheld? true}}
           ;; Keeper executes pending settlement (after appeal deadline + dispute deadline expired)
           {:seq 10 :time 2000 :agent "keeper" :action "automate_timed_actions"
            :params {:workflow-id 0}}]}
