{:scenario-id "Y06_multi-party-pro-rata-shortfall",
 :id "Y06",
 :schema-version "1.1",
 :title "Multi-Party Pro-Rata Shortfall Distribution",
 :purpose "functional-test",
 :scenario-author "agent-b",
 :protocol "yield-v1",
 :initial-block-time 1000000,
 :protocol-params {:yield-profile "aave-v3",
                   :token "USDC",
                   :focus-owner-id "0xAlice"},
 :agents [{:id "0xAlice", :address "0xAlice", :role "provider"}
          {:id "0xBob", :address "0xBob", :role "provider"}
          {:id "governance", :address "governance", :role "governance"}],
 :events [{:seq 0,
           :time 1000000,
           :agent "0xAlice",
           :action "yield_deposit",
           :params {:amount 1000, :token "USDC", :owner-id "0xAlice"}}
          {:seq 1,
           :time 1000000,
           :agent "0xBob",
           :action "yield_deposit",
           :params {:amount 2000, :token "USDC", :owner-id "0xBob"}}
          {:seq 2,
           :time 1100000,
           :agent "governance",
           :action "set-yield-risk",
           :params {:token "USDC",
                    :shortfall {:available-ratio 0.6,
                                :reason "liquidity-crunch"}}}
          {:seq 3,
           :time 1200000,
           :agent "0xAlice",
           :action "yield_withdraw",
           :params {:token "USDC", :owner-id "0xAlice"}}
          {:seq 4,
           :time 1300000,
           :agent "0xBob",
           :action "yield_withdraw",
           :params {:token "USDC", :owner-id "0xBob"}}],
 :expectations {:metrics [{:name "yield/positions-count", :value 2}
                          {:name "yield/total-principal", :value 3000}
                          {:name "yield/focus-principal", :value 1000}
                          {:name "yield/available-ratio", :value 0.6}]}}
