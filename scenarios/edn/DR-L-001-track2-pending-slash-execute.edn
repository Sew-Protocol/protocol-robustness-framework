{:scenario-id "dr-l-001-track2-pending-slash-execute"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Track 2 reversal slash lifecycle: submit-evidence → reversal → pending → execute-fraud-slash with correct slash-id"
 :description "New evidence submitted between L0 and L1 resolution triggers Track 2 (pending) reversal slashing. The pending slash has an appeal window. After window expires, execute-fraud-slash with correct level-scoped slash-id executes: stake deducted, resolver frozen."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "track2-pending-slash-correct-id-executes"
         :statement "Track 2 reversal slashing creates a pending slash with appeal deadline. After expiry, execute-fraud-slash with the correct string slash-id ('0-reversal-0') executes the slash: resolver stake deducted, resolver frozen."
         :falsifies-if ["execute-fraud-slash returns :no-pending-slash with correct slash-id"
                        "Resolver stake not reduced after execution"
                        "Resolver not frozen after execution"
                        "Slash status not :executed after execution"]}
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:slash_count {:eq 1}
                          :resolver_stake_deducted {:gt 0}
                          :resolver_frozen? {:eq true}}}
 :threat {:family "resolution-slashing" :attack "track2-pending-slash-lifecycle" :severity "high"
          :actors ["resolver"] :victims ["buyer"]
          :assumptions ["submit-evidence sets evidence-updated? flag"
                       "execute-fraud-slash with string slash-id works"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "resolver" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :dispute-resolver "0xresolver-l0"
                   :escalation-resolvers {:1 "0xresolver-l1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver-l0" :address "0xresolver-l0" :role "resolver" :stake 20000}
          {:id "resolver-l1" :address "0xresolver-l1" :role "resolver" :stake 20000}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "resolver-l0" :action "register_stake"
           :params {:amount 20000}}
          {:seq 1 :time 1000 :agent "resolver-l1" :action "register_stake"
           :params {:amount 20000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "seller" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 resolves: release — pending settlement created (deadline 1120+60=1180)
          {:seq 4 :time 1120 :agent "resolver-l0" :action "execute_resolution"
           :params {:workflow-id 0 :is-release true :resolution-hash "0xrelease"}}
          ;; New evidence submitted for Track 2 (manual pending path)
          {:seq 5 :time 1150 :agent "seller" :action "submit_evidence"
           :params {:workflow-id 0 :evidence-hash "0xnew-evidence"}}
          ;; Escalate to L1 before appeal deadline (1160 < 1180)
          {:seq 6 :time 1160 :agent "seller" :action "escalate_dispute"
           :params {:workflow-id 0}}
          ;; L1 reverses L0: refund — final round (no L2), escrow finalized immediately
          ;; handle-reversal-slashing creates Track 2 (pending) reversal slash (deadline 1200+60=1260)
          {:seq 7 :time 1200 :agent "resolver-l1" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xreversal"}}
          ;; After appeal deadline (1260), execute the pending reversal slash
          {:seq 8 :time 1400 :agent "keeper" :action "execute_fraud_slash"
           :params {:workflow-id 0 :slash-id {:slash-ref {:workflow-id 0 :kind :reversal :level 0}}}}]}
