{:scenario-id "dr-g-001-manual-reversal-slash-t2"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Manual-track (Track 2) reversal slashing: new evidence triggers pending slash with appeal window"
 :description "L0 resolver rules release. A participant submits new evidence, then escalates to L1. L1 reverses to refund. Because :evidence-updated? is set, Track 2 fires: the reversal slash is :pending (not :executed) with an appeal window. The slashed resolver appeals but the appeal is rejected."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "manual-track-reversal-slash-pending"
         :statement "When new evidence is submitted between L0 and L1 resolution, Track 2 reversal slashing creates a pending slash (not executed). The resolver can appeal, and governance resolves the appeal."
         :falsifies-if ["Slash is :executed instead of :pending"
                        "Appeal window not set on slash"
                        "Appeal is not possible"
                        "Resolve-appeal does not work with reversal slash-id"]}
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:slash_status {:eq :executed :slash-id "0-reversal-0"}}}
 :threat {:family "resolver-misconduct" :attack "manual-reversal-slash-lifecycle" :severity "high"
          :actors ["l0resolver"] :victims ["buyer"]
          :assumptions ["New evidence submitted creates Track 2 (pending) reversal slash"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "governance" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500 :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 resolves release
          {:seq 2 :time 1100 :agent "l0resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          ;; Submit evidence to trigger Track 2 on next reversal
          {:seq 3 :time 1120 :agent "seller" :action "submit_evidence"
           :params {:workflow-id 0 :evidence-hash "0xnewevidence"}}
          ;; Escalate to L1 (clears pending settlement)
          {:seq 4 :time 1130 :agent "seller" :action "escalate_dispute" :params {:workflow-id 0}}
          ;; L1 resolves refund (reversal) — Track 2 fires: pending slash, slash-id "0-reversal-0"
          ;; appeal-deadline = 1150 + 120 = 1270
          {:seq 5 :time 1150 :agent "l1resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; Slashed resolver appeals with explicit slash-id for reversal slash
          {:seq 6 :time 1160 :agent "l0resolver" :action "appeal_slash"
           :params {:workflow-id 0 :slash-id "0-reversal-0"}}
          ;; Governance resolves the appeal as rejected (slash stands → executed)
          {:seq 7 :time 1200 :agent "governance" :action "resolve_appeal"
           :params {:workflow-id 0 :slash-id "0-reversal-0" :appeal-upheld? false}}
          {:seq 8 :time 1300 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}]}
