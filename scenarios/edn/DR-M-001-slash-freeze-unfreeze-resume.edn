{:scenario-id "dr-m-001-slash-freeze-unfreeze-resume"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Fraud slash execution freezes resolver; governance unfreezes; resolver resumes"
 :description "A manual fraud slash is proposed and executed on a resolver, freezing them for 72h. Verifies the resolver cannot create escrows while frozen. Governance unfreezes the resolver. The resolver can then create escrows again."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "slash-freeze-unfreeze-cycle"
         :statement "After fraud slash execution, the resolver is frozen. Frozen resolvers cannot create escrows. Governance unfreeze restores the resolver's ability to create escrows."
         :falsifies-if ["Resolver is not frozen after slash execution"
                        "Frozen resolver can create escrows"
                        "Governance cannot unfreeze a resolver"
                        "Unfrozen resolver still blocked"]}
 :expectations {:terminal-state "refunded"
                :metrics {:slash_count {:eq 1}
                          :resolver_stake_deducted {:gt 0}}}
 :threat {:family "freeze-governance" :attack "slash-freeze-unfreeze" :severity "medium"
          :actors ["governance"] :victims ["resolver"]
          :assumptions ["Fraud slash execution freezes the resolver"
                       "Governance can unfreeze resolvers"
                       "Frozen resolvers cannot act"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "resolver" "governance" "protocol" "claimableBalances"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000 :fraud-slash-bps 5000 :appeal-bond-bps 500}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver" :address "0xresolver" :role "resolver" :stake 20000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
  :events [{:seq 0 :time 1000 :agent "resolver" :action "register_stake"
            :params {:amount 20000}}
           {:seq 1 :time 1000 :agent "buyer" :action "create_escrow"
            :params {:token "USDC" :to "0xseller" :amount 10000 :custom-resolver "0xresolver"}}
           {:seq 2 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
           {:seq 3 :time 1100 :agent "resolver" :action "execute_resolution"
            :params {:workflow-id 0 :is-release false :resolution-hash "0xhash"}}
           ;; Execute pending settlement (deadline 1220 passed)
           {:seq 4 :time 1300 :agent "keeper" :action "execute_pending_settlement"
            :params {:workflow-id 0}}
           ;; Governance proposes fraud slash on resolver (3000 = 15% of stake, within 20% epoch cap)
           {:seq 5 :time 1400 :agent "governance" :action "propose_fraud_slash"
            :params {:workflow-id 0 :resolver-addr "0xresolver" :amount 3000}}
           ;; Execute the fraud slash — resolver gets frozen (72h, until time 1500+259200=260700)
            {:seq 6 :time 1550 :agent "keeper" :action "execute_fraud_slash"
             :params {:workflow-id 0}}
            ;; Try to create a new escrow while frozen (freeze-until ≈ 1550+259200 = 260750)
            {:seq 7 :time 1600 :agent "resolver" :action "create_escrow"
             :params {:token "USDC" :to "0xseller" :amount 5000 :custom-resolver "0xresolver"}}
            ;; Governance unfreezes the resolver
            {:seq 8 :time 1700 :agent "governance" :action "unfreeze_resolver"
             :params {:resolver "0xresolver"}}
            ;; Resolver can now create escrows again
            {:seq 9 :time 1800 :agent "resolver" :action "create_escrow"
             :params {:token "USDC" :to "0xseller" :amount 5000 :custom-resolver "0xresolver"}}]}
