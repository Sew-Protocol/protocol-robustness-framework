{:scenario-id "dr-p-002-force-reversal-slash-idempotent"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Force reversal slash idempotency: duplicate governance action rejected"
 :description "Governance issues force-reversal-slash on L0 for a reversed decision. The first force slash is accepted and executed (no existing auto-track slash at this point). Governance immediately issues a second identical force-reversal-slash for the same resolver and workflow. The second attempt is rejected as a duplicate or no-op. Verifies that force-reversal-slash is idempotent: the second call does not create a duplicate debit or duplicate slash event."
 :provenance {:author "@dispute-researcher" :created-at "2026-07-01" :license "CC-BY-4.0"}
 :claim {:id "force-reversal-slash-idempotent"
         :statement "Duplicate force-reversal-slash for the same resolver and workflow is rejected as a no-op. The second attempt does not create a duplicate debit or slash event."
         :falsifies-if ["Second force slash creates duplicate debit"
                        "Second force slash creates additional slash event"
                        "Resolver stake deducted twice"
                        "Slash event count > 1"]}
 :expected/events
 [:reversal-slash/force-proposed
  :reversal-slash/force-executed
  :reversal-slash/force-duplicate-rejected]
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:slash_count {:eq 1}
                          :duplicate_force_rejected? {:eq true}
                          :resolver_stake_deducted_once? {:eq true}}}
 :expected/invariants
 [:stake/non-negative
  :slash/requested-equals-debited-plus-unmet-plus-reversed
  :resolver/balances-conserved]
 :threat {:family "governance-integrity" :attack "force-reversal-slash-idempotent" :severity "medium"
          :actors ["governance"]
          :assumptions ["Force-reversal-slash is idempotent" "Duplicate is rejected as no-op"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "l0resolver" "l1resolver" "governance" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000
                   :reversal-slash-bps 2500
                   :dispute-resolver "0xl0"
                   :escalation-resolvers {:0 "0xl0" :1 "0xl1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake" :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow" :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 rules: release
          {:seq 4 :time 1100 :agent "l0resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          ;; L1 reverses to refund — Track 1 auto-slash on L0 (0-reversal-0, executed)
          {:seq 5 :time 1150 :agent "l1resolver" :action "execute_resolution" :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; First force-reversal-slash — should execute (or be rejected if auto-track already exists)
          {:seq 6 :time 1200 :agent "governance" :action "force_reversal_slash" :params {:workflow-id 0 :resolver "0xl0"}}
          ;; Second identical force-reversal-slash — should be no-op
          {:seq 7 :time 1210 :agent "governance" :action "force_reversal_slash" :params {:workflow-id 0 :resolver "0xl0"}}
          ;; Execute pending settlement
          {:seq 8 :time 1400 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}]}
