{:scenario-id "dr-o-002-resolver-overflow-cap-exhaustion"
 :schema-version "1.0"
 :purpose "liveness"
 :title "Resolver overflow: max-workflows cap prevents exceeding the authorised quota"
 :description "Governance authorises a resolver-overflow with max-workflows=1. The failover resolver resolves one workflow under the overflow. A second workflow assigned to the same primary resolver is rejected because the cap is exhausted. Demonstrates that the quantity-bounded scope is enforced."
 :provenance {:author "@protocol-team" :created-at "2026-07-02" :license "CC-BY-4.0"}
 :claim {:id "resolver-overflow-cap-enforced"
         :statement "A resolver-overflow with max-workflows cap rejects resolution attempts beyond the cap."
         :falsifies-if ["A second overflow-authorised resolution succeeds after cap is exhausted"]
         :assumptions ["Governance address is configured in protocol-params"
                       "max-workflows is set to 1"]}
 :allow-open-disputes? true
 :expectations {:must-hold ["dispute_timestamp_consistency"
                            "dispute_level_bounded"
                            "no_duplicate_dispute"]
                :error-on-seq [6]
                :expected-errors {:seq 6 :error :not-authorized-resolver}}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150
                   :appeal-window-duration 120
                   :max-dispute-duration 2592000
                   :dispute-resolver "0xprimary"
                   :resolver-overflow-policy
                   {:governance-address "0xgovernance"
                    :default-duration 3600
                    :max-duration 86400
                    :default-max-workflows 1
                    :max-workflows 500
                    :failover-resolvers #{"0xfailover"}
                    :allowed-reasons #{:resolver-overcapacity}}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "buyer2" :address "0xbuyer2" :strategy "honest"}
          {:id "governance" :address "0xgovernance" :role "governance"}
          {:id "primary" :address "0xprimary" :role "resolver"}
          {:id "failover" :address "0xfailover" :role "resolver"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 1 :time 1005 :agent "buyer2" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 3000}}
          {:seq 2 :time 1060 :agent "buyer" :action "raise_dispute"
           :params {:workflow-id 0}}
          {:seq 3 :time 1065 :agent "buyer2" :action "raise_dispute"
           :params {:workflow-id 1}}
          ;; Governance activates overflow mode (max-workflows=1 from policy default)
          {:seq 4 :time 1100 :agent "governance" :action "activate_resolver_overflow"
           :params {:resolver "0xprimary"
                    :reason :resolver-overcapacity}}
          ;; Failover resolves workflow 0 — succeeds
          {:seq 5 :time 1120 :agent "failover" :action "execute_overflow_resolution"
           :params {:workflow-id 0 :overflow-id 0 :is-release true}}
          ;; Failover tries workflow 1 — rejected (cap exhausted)
          {:seq 6 :time 1130 :agent "failover" :action "execute_overflow_resolution"
           :params {:workflow-id 1 :overflow-id 0 :is-release true}}]}
