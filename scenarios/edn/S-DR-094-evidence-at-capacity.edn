 :events [{:seq 0 :time 1000 :agent "buyer1" :action "create_escrow" :params {:token "USDC" :to "0xseller1" :amount 5000 :custom-resolver "0xresolver"}}
          {:seq 1 :time 1010 :agent "buyer2" :action "create_escrow" :params {:token "USDC" :to "0xseller2" :amount 3000 :custom-resolver "0xresolver"}}
          {:seq 2 :time 1020 :agent "governance" :action "set_resolver_capacity" :params {:resolver "0xresolver" :max-concurrent 2}}
          {:seq 3 :time 1060 :agent "buyer1" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 4 :time 1065 :agent "buyer2" :action "raise_dispute" :params {:workflow-id 1}}
