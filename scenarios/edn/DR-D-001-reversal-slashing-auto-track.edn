{:scenario-id "dr-d-001-reversal-slashing-auto-track"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Reversal slashing auto-track: L0 resolver automatically slashed when L1 reverses"
 :description "L0 resolver rules release. Seller appeals to L1. L1 reverses to refund. L0's decision is reversed — since no new evidence was submitted between L0 and L1 resolution, the Track 1 (auto) reversal slashing path fires: L0 resolver's stake is slashed immediately and the slash entry is marked :executed. Verifies the automatic slash executes without need for governance action."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-29" :license "CC-BY-4.0"}
 :claim {:id "auto-reversal-slash-on-reversal-no-new-evidence"
         :statement "When a resolver's decision is reversed on appeal and no new evidence was submitted between levels, the auto-track reversal slashing fires immediately (slash status = :executed), deducting the resolver's stake."
         :falsifies-if ["Reversal slash not created" "Slash status != :executed" "Resolver stake not reduced"]}
 :expectations {:terminal-state "released"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:resolver_net_profit {:lt 0 :scope "0xl0"}
                          :slash_status {:eq :executed :slash-id "0-reversal-0"}}}
 :threat {:family "resolver-misconduct" :attack "biased-ruling-auto-slashed" :severity "high"
          :actors ["l0resolver"] :victims ["buyer"]
          :assumptions ["reversal-slash-bps > 0" "No new evidence submitted at L1"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "0xl0" "0xl1" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 60 :max-dispute-duration 2592000 :reversal-slash-bps 2500 :dispute-resolver "0xl0" :escalation-resolvers {:0 "0xl0" :1 "0xl1"}}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "l0resolver" :address "0xl0" :role "resolver" :stake 10000}
          {:id "l1resolver" :address "0xl1" :role "resolver" :stake 10000}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "l0resolver" :action "register_stake"
           :params {:amount 10000}}
          {:seq 1 :time 1000 :agent "l1resolver" :action "register_stake"
           :params {:amount 10000}}
          {:seq 2 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 3 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          ;; L0 rules: release to seller
          {:seq 4 :time 1100 :agent "l0resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release true :resolution-hash "0xl0release"}}
          ;; Seller escalates to L1
          {:seq 5 :time 1120 :agent "seller" :action "escalate_dispute" :params {:workflow-id 0}}
          ;; L1 reverses to refund — no new evidence, so auto-track (Track 1) reversal slashing on L0
          {:seq 6 :time 1150 :agent "l1resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xl1refund"}}
          ;; L1 is not final round, so pending settlement created with appeal window
          ;; Execute after window
          {:seq 7 :time 1300 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}]}
