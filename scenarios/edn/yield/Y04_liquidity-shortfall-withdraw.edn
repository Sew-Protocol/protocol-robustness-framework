{"protocol-params" {"yield-profile" "aave-v3",
                    "default-owner-id" "vault"},
 "schema-version" "1.0",
 "threat-tags" ["yield-stress"
                "shortfall-affected"
                "liquidity-shortfall"],
 "yield-config" {"modules" {"aave-v3" {"tokens" {"USDC" {"apy" 0.08,
                                                         "liquidity-mode" "available"}}}}},
 "initial-block-time" 1000,
 "expectations" {"metrics" [{"name" "yield/position-principal",
                             "op" ":=",
                             "value" 10000}
                            {"name" "yield/position-deferred",
                             "op" ":=",
                             "value" 5400}
                            {"name" "yield/loss-reason",
                             "op" ":=",
                             "value" "liquidity-shortfall"}],
                 "terminal" [{"path" ["yield-positions"
                                      "vault"
                                      "status"],
                              "equals" "unwinding"}]},
 "agents" [{"id" "vault", "address" "0xVault"}],
 "scenario-id" "y04-liquidity-shortfall-withdraw",
 "events" [{"seq" 0,
            "time" 1000,
            "agent" "vault",
            "action" "yield_deposit",
            "params" {"token" "USDC", "amount" 10000}}
           {"seq" 1,
            "time" 31537000,
            "agent" "vault",
            "action" "yield_accrue",
            "params" {"token" "USDC", "dt" 31536000}}
           {"seq" 2,
            "time" 31538000,
            "agent" "vault",
            "action" "set-yield-risk",
            "params" {"module-id" "aave-v3",
                      "token" "USDC",
                      "liquidity-mode" "shortfall",
                      "shortfall" {"available-ratio" 0.5}}}
           {"seq" 3,
            "time" 31539000,
            "agent" "vault",
            "action" "yield_withdraw",
            "params" {"token" "USDC"}}],
 "options" {"minimal" true},
 "description" "Pool enters shortfall liquidity mode after accrual; full gross withdraw is 50% fulfilled with deferred remainder."}
