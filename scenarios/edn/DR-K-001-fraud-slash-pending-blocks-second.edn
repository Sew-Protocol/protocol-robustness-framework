{:scenario-id "dr-k-001-fraud-slash-pending-blocks-second"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Fraud slash pending lifecycle: governance proposes slash, second proposal blocked while first is pending"
 :description "Governance proposes a fraud slash against a resolver for a completed escrow. Before the timelock/execution, a second slash proposal is attempted. The guard rejects with :slash-already-pending because the first slash has not been resolved or executed."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-30" :license "CC-BY-4.0"}
 :claim {:id "fraud-slash-pending-blocks-duplicate"
         :statement "While a fraud slash against a resolver is pending (or appealed), a second slash proposal for the same workflow is rejected. This prevents double-slashing and ensures orderly slash lifecycle."
         :falsifies-if ["Second slash proposal succeeds while first is pending"
                        "First slash is overwritten or lost"
                        "Resolver can be double-slashed for same offense"]}
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :error-on-seq [6]
                :expected-errors {:seq 6 :error :slash-already-pending}}
 :threat {:family "slash-integrity" :attack "duplicate-fraud-slash" :severity "high"
          :actors ["governance"]
          :assumptions ["Fraud slash proposal creates :pending entry" "Active check prevents duplicates"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "resolver" "governance" "protocol" "slashPool"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 600
                   :fraud-slash-bps 5000 :dispute-resolver "0xresolver"}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver" :address "0xresolver" :role "resolver" :stake 20000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "resolver" :action "register_stake"
           :params {:amount 20000}}
          {:seq 1 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 5000}}
          {:seq 2 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 3 :time 1100 :agent "resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xhash"}}
          ;; appeal-deadline = 1100 + 120 = 1220, execute after
          {:seq 4 :time 1300 :agent "keeper" :action "execute_pending_settlement"
           :params {:workflow-id 0}}
          ;; Governance proposes fraud slash
          {:seq 5 :time 1400 :agent "governance" :action "propose_fraud_slash"
           :params {:workflow-id 0 :resolver-addr "0xresolver" :amount 5000}}
          ;; Second proposal for same workflow — blocked
          {:seq 6 :time 1410 :agent "governance" :action "propose_fraud_slash"
           :params {:workflow-id 0 :resolver-addr "0xresolver" :amount 3000}}]}
