{:scenario-id "dr-c-002-slash-appeal-bond-lifecycle"
 :schema-version "1.0"
 :allow-open-disputes? true
 :purpose "adversarial-robustness"
 :title "Slash appeal bond lifecycle: resolver posts bond, appeal upheld, bond refunded"
 :description "A governance entity proposes a manual fraud slash on a resolver. The resolver appeals by posting an appeal bond. Governance resolves the appeal as upheld (the slash was wrong). The appeal bond is refunded to the resolver via claimable. Verifies the full lifecycle: propose → appeal (post bond) → resolve (uphold) → bond refunded."
 :provenance {:author "@dispute-researcher" :created-at "2026-06-29" :license "CC-BY-4.0"}
 :claim {:id "slash-appeal-bond-refund-on-uphold"
         :statement "When a resolver's slash appeal is upheld by governance, the posted appeal bond is refunded to the resolver and no slash occurs."
         :falsifies-if ["Bond is not refunded after upheld appeal" "Slash is executed despite upheld appeal"
                        "Appeal bond is not returned to resolver claimable"]}
 :expectations {:terminal-state "refunded"
                :must-hold ["slashable_liability_preserved" "resolver_decision_attributable"]
                :metrics {:resolver_bond_refunded {:eq true} :slash_count {:eq 0}}}
 :threat {:family "slash-appeal" :attack "bond-not-refunded" :severity "high"
          :actors ["governance"] :victims ["resolver"]
          :assumptions ["Governance correctly resolves appeals"]}
 :accounting {:unit "USDC" :decimals 6 :tracked-balances ["buyer" "seller" "resolver" "governance" "protocol" "claimableBalances"]}
 :initial-block-time 1000
 :protocol-params {:resolver-fee-bps 150 :appeal-window-duration 120 :max-dispute-duration 2592000 :fraud-slash-bps 5000 :appeal-bond-bps 500}
 :agents [{:id "buyer" :address "0xbuyer" :strategy "honest"}
          {:id "seller" :address "0xseller" :strategy "honest"}
          {:id "resolver" :address "0xresolver" :role "resolver" :stake 20000}
          {:id "governance" :address "0xgov" :role "governance"}
          {:id "keeper" :address "0xkeeper" :role "keeper"}]
 :events [{:seq 0 :time 1000 :agent "buyer" :action "create_escrow"
           :params {:token "USDC" :to "0xseller" :amount 10000 :custom-resolver "0xresolver"}}
          {:seq 1 :time 1060 :agent "buyer" :action "raise_dispute" :params {:workflow-id 0}}
          {:seq 2 :time 1100 :agent "resolver" :action "execute_resolution"
           :params {:workflow-id 0 :is-release false :resolution-hash "0xhash"}}
          {:seq 3 :time 1200 :agent "keeper" :action "execute_pending_settlement" :params {:workflow-id 0}}
          ;; Governance proposes fraud slash on resolver
          {:seq 4 :time 1300 :agent "governance" :action "propose_fraud_slash"
           :params {:workflow-id 0 :resolver-addr "0xresolver" :amount 5000}}
          ;; Resolver appeals the slash — posts appeal bond
          {:seq 5 :time 1320 :agent "resolver" :action "appeal_slash"
           :params {:workflow-id 0}}
           ;; Governance resolves appeal as upheld (slash was wrong) — bond refunded
           {:seq 6 :time 1400 :agent "governance" :action "resolve_appeal"
            :params {:workflow-id 0 :upheld? true}}]}
