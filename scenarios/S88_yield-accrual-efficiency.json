{
  "scenario-id": "s88-yield-accrual-efficiency",
  "schema-version": "1.0",
  "description": "One-year fixed-rate yield on escrow exceeds the 1.5% escrow protocol fee.",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer"
    },
    {
      "id": "seller",
      "address": "0xseller"
    }
  ],
  "protocol-params": {
    "yield-generation-module": "fixed-rate",
    "resolver-fee-bps": 150,
    "yield-protocol-fee-bps": 0,
    "appeal-window-duration": 0
  },
  "yield-config": {
    "modules": {
      "fixed-rate": {
        "tokens": {
          "USDC": {
            "apy": 0.1
          }
        }
      }
    }
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 10000,
        "yield-preset": "to-recipient"
      }
    },
    {
      "seq": 1,
      "time": 31537000,
      "agent": "buyer",
      "action": "release",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@grifma",
  "provenance": {
    "author-id": "@grifma",
    "author": "Marc Griffiths"
  }
}
