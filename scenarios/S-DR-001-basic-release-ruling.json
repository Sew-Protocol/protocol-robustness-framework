{
  "scenario-id": "s-dr-001-basic-release-ruling",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "Basic release ruling: dispute raised, resolver releases to seller",
  "scenario-purpose": "Verify the basic dispute \u2192 resolution \u2192 settlement lifecycle with a release outcome.",
  "purpose": "regression",
  "threat-tags": [
    "dispute-resolution",
    "basic-lifecycle"
  ],
  "tags": [
    "suite/dispute-resolution",
    "coverage/basic-lifecycle"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000,
    "resolver-bond-bps": 0
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 3,
      "time": 1200,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}