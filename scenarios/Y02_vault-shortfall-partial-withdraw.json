{
  "scenario-id": "Y02_vault-shortfall-partial-withdraw",
  "id": "Y02",
  "schema-version": "1.1",
  "title": "Vault Shortfall and Partial Withdrawal",
  "purpose": "functional-test",
  "scenario-author": "agent-b",
  "protocol": "yield-v1",
  "initial-block-time": 1000000,
  "protocol-params": {
    "yield-profile": "aave-v3",
    "token": "USDC",
    "focus-owner-id": "0xOwnerA"
  },
  "agents": [
    {"id": "0xOwnerA", "address": "0xOwnerA", "role": "provider"},
    {"id": "0xOwnerB", "address": "0xOwnerB", "role": "provider"},
    {"id": "governance", "address": "governance", "role": "governance"}
  ],
  "events": [
    {
      "seq": 0,
      "time": 1000000,
      "agent": "0xOwnerA",
      "action": "yield_deposit",
      "params": {
        "amount": 1000,
        "token": "USDC"
      }
    },
    {
      "seq": 1,
      "time": 1000000,
      "agent": "0xOwnerB",
      "action": "yield_deposit",
      "params": {
        "amount": 2000,
        "token": "USDC"
      }
    },
    {
      "seq": 2,
      "time": 1100000,
      "agent": "governance",
      "action": "set-yield-risk",
      "params": {
        "token": "USDC",
        "shortfall": {
          "available-ratio": 0.5,
          "reason": "liquidity-shortfall"
        }
      }
    },
    {
      "seq": 3,
      "time": 1200000,
      "agent": "0xOwnerA",
      "action": "yield_withdraw",
      "params": {
        "token": "USDC"
      }
    }
  ],
  "expectations": {
    "metrics": [
      {"name": "yield/positions-count", "value": 2},
      {"name": "yield/total-principal", "value": 3000},
      {"name": "yield/focus-principal", "value": 1000},
      {"name": "yield/focus-status", "value": "unwinding"},
      {"name": "yield/focus-deferred", "value": 1000},
      {"name": "yield/available-ratio", "value": 0.5}
    ]
  }
}
