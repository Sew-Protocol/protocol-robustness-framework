{
  "scenario-id": "s-dr-032-resolver-insufficient-stake",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "Resolver insufficient stake: resolver has minimal stake, slash partially executed",
  "scenario-purpose": "Verify that when a resolver's stake is less than the slash amount, the slash is partially executed and unmet obligation recorded.",
  "purpose": "adversarial-robustness",
  "threat-tags": [
    "dispute-resolution",
    "resolver-integrity",
    "slash"
  ],
  "tags": [
    "suite/dispute-resolution",
    "coverage/resolver-integrity"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver"
    },
    {
      "id": "governance",
      "address": "0xgov",
      "role": "governance"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000,
    "resolver-bond-bps": 0
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "resolver",
      "action": "register_stake",
      "params": {
        "amount": 100,
        "token": "USDC"
      }
    },
    {
      "seq": 1,
      "time": 1010,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 2,
      "time": 1070,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 3,
      "time": 1130,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 4,
      "time": 1200,
      "agent": "governance",
      "action": "propose_fraud_slash",
      "params": {
        "workflow-id": 0,
        "resolver-addr": "0xresolver",
        "amount": 500,
        "slash-id": "slash-001"
      }
    },
    {
      "seq": 5,
      "time": 1300,
      "agent": "governance",
      "action": "execute_fraud_slash",
      "params": {
        "workflow-id": 0,
        "slash-id": "slash-001"
      }
    },
    {
      "seq": 6,
      "time": 1350,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}