{
  "scenario-id": "s-dr-095-evidence-after-settlement-attempt-rejected",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "Evidence after premature settlement rejection \u2014 submit_evidence while escrow still disputed",
  "scenario-purpose": "Verify that evidence can still be submitted after a premature settlement attempt is rejected. The escrow remains in :disputed state when execute_pending_settlement is blocked by the appeal window, so evidence submission should succeed.",
  "purpose": "adversarial-robustness",
  "threat-tags": ["dispute-resolution", "evidence", "timing", "finality"],
  "tags": ["suite/dispute-resolution", "coverage/evidence"],
  "expected-errors": [{
    "seq": 3, "action": "execute_pending_settlement", "error": "appeal-window-not-expired"
  }],
  "agents": [{
    "id": "buyer", "address": "0xbuyer", "strategy": "honest"
  }, {
    "id": "seller", "address": "0xseller", "strategy": "honest"
  }, {
    "id": "resolver", "address": "0xresolver", "role": "resolver"
  }, {
    "id": "keeper", "address": "0xkeeper", "role": "keeper"
  }],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 3,
      "time": 1150,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 4,
      "time": 1175,
      "agent": "seller",
      "action": "submit_evidence",
      "params": {
        "workflow-id": 0,
        "evidence-hash": "0xmid-window-evidence"
      }
    },
    {
      "seq": 5,
      "time": 1220,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-notes": "Premature settlement attempt at t=1150 (30s after resolution, appeal-window=60s) is rejected with :appeal-window-not-expired. Escrow remains :disputed. Evidence submitted at t=1175 succeeds. Final settlement at t=1220 (after window expiry at 1180) succeeds. Tests that a rejected settlement does not corrupt the disputed state or block evidence.",
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}
