{
  "scenario-id": "s-dr-020-false-claimant-slashed",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "False claimant slashed: seller proposes fraud slash against buyer who raised baseless dispute",
  "scenario-purpose": "Verify that a false claimant can be slashed via propose-fraud-slash \u2192 execute-fraud-slash and the slash is reflected in resolver-slash-total.",
  "purpose": "adversarial-robustness",
  "threat-tags": [
    "dispute-resolution",
    "strategic",
    "fraud-slash"
  ],
  "tags": [
    "suite/dispute-resolution",
    "coverage/strategic"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "malicious"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    },
    {
      "id": "governance",
      "address": "0xgov",
      "role": "governance"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000,
    "resolver-bond-bps": 0
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 3,
      "time": 1200,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-notes": "After settlement, the seller could propose a fraud slash against the buyer for raising a baseless dispute. The fraud-slash actions require a slash-id and workflow-id that must reference a resolved workflow.",
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}