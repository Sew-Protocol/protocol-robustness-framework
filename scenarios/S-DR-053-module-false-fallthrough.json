{
  "scenario-id": "s-dr-053-module-false-fallthrough",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "Module false fallthrough \u2014 resolution module returns false, caller matches dispute-resolver at Priority 3",
  "scenario-purpose": "Verify that when the resolution-module returns {:authorized? false}, execution falls through to Priority 3 (dispute-resolver on EscrowTransfer). The caller is authorised if they match et.disputeResolver.",
  "purpose": "theory-falsification",
  "threat-tags": [
    "dispute-resolution",
    "resolution-module",
    "authorization",
    "fallthrough"
  ],
  "tags": [
    "suite/dispute-resolution",
    "coverage/resolver-integrity"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    },
    {
      "id": "module-resolver",
      "address": "0xmodule-only",
      "role": "resolver"
    },
    {
      "id": "dispute-resolver",
      "address": "0xdispute-only",
      "role": "resolver"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "resolution-module": "0xmodule-only",
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000,
    "resolver-bond-bps": 0
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000,
        "custom-resolver": "0xdispute-only"
      }
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "dispute-resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 3,
      "time": 1200,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-notes": "resolution-module '0xmodule-only' only authorises '0xmodule-only'. When caller = '0xdispute-only', the module returns {:authorized? false}. Execution falls through to Priority 3: caller matches custom-resolver '0xdispute-only' \u2192 authorised. This mirrors Solidity's isAuthorizedDisputeResolver: module rejection is non-fatal.",
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}