{
  "scenario-id": "Y01_vault-shared-liquidity",
  "id": "Y01",
  "schema-version": "1.1",
  "title": "Shared Vault Liquidity and Shortfall Distribution",
  "purpose": "functional-test",
  "scenario-author": "agent-b",
  "protocol": "yield-v1",
  "initial-block-time": 1000000,
  "protocol-params": {
    "yield-profile": "aave-v3",
    "token": "USDC",
    "focus-owner-id": "0xOwnerA"
  },
  "agents": [
    {"id": "0xOwnerA", "address": "0xOwnerA", "role": "provider"},
    {"id": "0xOwnerB", "address": "0xOwnerB", "role": "provider"},
    {"id": "governance", "address": "governance", "role": "governance"}
  ],
  "events": [
    {
      "seq": 0,
      "time": 1000000,
      "agent": "0xOwnerA",
      "action": "yield_deposit",
      "params": {
        "amount": 1000,
        "token": "USDC",
        "owner-id": "0xOwnerA"
      }
    },
    {
      "seq": 1,
      "time": 1000000,
      "agent": "0xOwnerB",
      "action": "yield_deposit",
      "params": {
        "amount": 2000,
        "token": "USDC",
        "owner-id": "0xOwnerB"
      }
    },
    {
      "seq": 2,
      "time": 1100000,
      "agent": "governance",
      "action": "yield_accrue",
      "params": {
        "dt": 100000,
        "token": "USDC"
      }
    },
    {
      "seq": 3,
      "time": 1100000,
      "agent": "governance",
      "action": "set-yield-risk",
      "params": {
        "token": "USDC",
        "shortfall-bps": 5000,
        "recovery-mode": "partial"
      }
    },
    {
      "seq": 4,
      "time": 1200000,
      "agent": "0xOwnerA",
      "action": "yield_withdraw",
      "params": {
        "token": "USDC",
        "owner-id": "0xOwnerA"
      }
    }
  ],
  "expectations": {
    "metrics": [
      {"name": "yield/positions-count", "value": 2},
      {"name": "yield/total-principal", "value": 3000},
      {"name": "yield/focus-principal", "value": 1000}
    ]
  }
}
