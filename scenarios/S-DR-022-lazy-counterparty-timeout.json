{
  "scenario-id": "s-dr-022-lazy-counterparty-timeout",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "scenario-title": "Lazy counterparty timeout: seller never responds, dispute times out",
  "scenario-purpose": "Verify that when the counterparty is non-responsive, the dispute times out and the keeper auto-cancels, returning funds to the buyer.",
  "purpose": "regression",
  "threat-tags": [
    "dispute-resolution",
    "strategic",
    "timeout"
  ],
  "tags": [
    "suite/dispute-resolution",
    "coverage/strategic"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "lazy"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 0,
    "max-dispute-duration": 300,
    "resolver-bond-bps": 0
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 2000
      }
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1400,
      "agent": "keeper",
      "action": "auto_cancel_disputed",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@kilo-research",
  "provenance": {
    "author-id": "@kilo-research",
    "author": "Kilo Research"
  }
}