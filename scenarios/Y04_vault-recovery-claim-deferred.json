{
  "scenario-id": "Y04_vault-recovery-claim-deferred",
  "id": "Y04",
  "schema-version": "1.1",
  "title": "Vault Recovery and Claim Deferred",
  "purpose": "functional-test",
  "scenario-author": "agent-b",
  "protocol": "yield-v1",
  "initial-block-time": 1000000,
  "protocol-params": {
    "yield-profile": "aave-v3",
    "token": "USDC",
    "focus-owner-id": "0xOwnerA"
  },
  "agents": [
    { "id": "0xOwnerA", "address": "0xOwnerA", "role": "provider" },
    { "id": "governance", "address": "governance", "role": "governance" }
  ],
  "events": [
    {
      "seq": 0,
      "time": 1000000,
      "agent": "0xOwnerA",
      "action": "yield_deposit",
      "params": {
        "amount": 1000,
        "token": "USDC"
      }
    },
    {
      "seq": 1,
      "time": 1100000,
      "agent": "governance",
      "action": "set-yield-risk",
      "params": {
        "token": "USDC",
        "shortfall": {
          "available-ratio": 0.5,
          "reason": "liquidity-shortfall"
        }
      }
    },
    {
      "seq": 2,
      "time": 1200000,
      "agent": "0xOwnerA",
      "action": "yield_withdraw",
      "params": {
        "token": "USDC"
      }
    },
    {
      "seq": 3,
      "time": 1300000,
      "agent": "governance",
      "action": "yield_recover_liquidity",
      "params": {
        "token": "USDC"
      }
    },
    {
      "seq": 4,
      "time": 1400000,
      "agent": "0xOwnerA",
      "action": "yield_claim_deferred",
      "params": {
        "token": "USDC"
      }
    }
  ],
  "expectations": {
    "metrics": [
      { "name": "yield/available-ratio", "value": 1.0 },
      { "name": "yield/focus-status", "value": "withdrawn" },
      { "name": "yield/total-reclaimed", "value": 1000 }
    ]
  }
}
