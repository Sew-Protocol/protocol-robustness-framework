{
  "scenario-id": "s84-yield-protocol-fee-mid-accrual",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer"
    },
    {
      "id": "seller",
      "address": "0xseller"
    },
    {
      "id": "governance",
      "address": "0xgovernance",
      "role": "governance"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "partial-fill-policy": {
      "unrealized-yield-treatment": "not-claimable"
    }
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 10000,
        "yield-generation-module": "aave-yield"
      }
    },
    {
      "seq": 1,
      "time": 2000,
      "agent": "governance",
      "action": "governance_update_fee",
      "params": {
        "fee-bps": 500
      }
    },
    {
      "seq": 2,
      "time": 4000,
      "agent": "buyer",
      "action": "release",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@grifma",
  "provenance": {
    "author-id": "@grifma",
    "author": "Marc Griffiths"
  }
}