{
  "protocol-params" : {
    "yield-profile" : "aave-v3",
    "default-owner-id" : "vault"
  },
  "schema-version" : "1.0",
  "threat-tags" : [ "yield-stress", "shortfall-affected", "partial-liquidity" ],
