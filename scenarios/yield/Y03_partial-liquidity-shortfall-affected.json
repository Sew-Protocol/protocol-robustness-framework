  }, {
    "seq" : 1,
    "time" : 31537000,
    "agent" : "vault",
    "action" : "yield_accrue",
    "params" : {
      "token" : "USDC",
      "dt" : 31536000
    }
  }, {
    "seq" : 2,
    "time" : 31538000,
    "agent" : "vault",
    "action" : "yield_withdraw",
    "params" : {
      "token" : "USDC"
    }
