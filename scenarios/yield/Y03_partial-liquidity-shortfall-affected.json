{
  "scenario-id": "y03-partial-liquidity-shortfall-affected",
  "schema-version": "1.0",
  "description": "Partial liquidity: yield leg stressed on withdraw; principal immediate; position unwinding with deferred.",
  "threat-tags": ["yield-stress", "shortfall-affected", "partial-liquidity"],
  "initial-block-time": 1000,
  "agents": [{"id": "vault", "address": "0xVault"}],
  "protocol-params": {"yield-profile": "aave-v3", "default-owner-id": "vault"},
  "yield-config": {
    "modules": {
      "aave-v3": {
        "tokens": {
          "USDC": {
            "apy": 0.08,
            "liquidity-mode": "available",
            "failure-modes": ["partial-liquidity"],
            "shortfall": {"available-ratio": 0.5, "reason": "liquidity-shortfall"}
          }
        }
      }
    }
  },
  "options": {"minimal": true},
  "events": [
    {"seq": 0, "time": 1000, "agent": "vault", "action": "yield_deposit", "params": {"token": "USDC", "amount": 10000}},
    {"seq": 1, "time": 31537000, "agent": "vault", "action": "yield_accrue", "params": {"token": "USDC", "dt": 31536000}},
    {"seq": 2, "time": 31538000, "agent": "vault", "action": "yield_withdraw", "params": {"token": "USDC"}}
  ],
  "expectations": {
    "metrics": [
      {"name": "yield/position-principal", "op": ":=", "value": 10000},
      {"name": "yield/position-realized", "op": ":=", "value": 400},
      {"name": "yield/position-deferred", "op": ":=", "value": 400},
      {"name": "yield/loss-reason", "op": ":=", "value": "liquidity-shortfall"}
    ],
    "terminal": [
      {"path": ["yield-positions", "vault", "status"], "equals": "unwinding"}
    ]
  }
}
