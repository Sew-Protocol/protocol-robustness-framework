{
  "scenario-id": "y05-shortfall-affected-recovery",
  "schema-version": "1.0",
  "description": "Partial-liquidity shortfall on withdraw, then liquidity restored and deferred amount claimed.",
  "threat-tags": ["yield-stress", "shortfall-affected", "partial-liquidity", "recovery"],
  "initial-block-time": 1000,
  "agents": [{"id": "vault", "address": "0xVault"}],
  "protocol-params": {"yield-profile": "aave-v3", "default-owner-id": "vault"},
  "yield-config": {
    "modules": {
      "aave-v3": {
        "tokens": {
          "USDC": {
            "apy": 0.08,
            "liquidity-mode": "available",
            "failure-modes": ["partial-liquidity"],
            "shortfall": {"available-ratio": 0.5, "reason": "liquidity-shortfall"}
          }
        }
      }
    }
  },
  "options": {"minimal": true},
  "events": [
    {"seq": 0, "time": 1000, "agent": "vault", "action": "yield_deposit", "params": {"token": "USDC", "amount": 10000}},
    {"seq": 1, "time": 31537000, "agent": "vault", "action": "yield_accrue", "params": {"token": "USDC", "dt": 31536000}},
    {"seq": 2, "time": 31538000, "agent": "vault", "action": "yield_withdraw", "params": {"token": "USDC"}},
    {"seq": 3, "time": 31539000, "agent": "vault", "action": "set-yield-risk", "params": {"module-id": "aave-v3", "token": "USDC", "liquidity-mode": "available"}},
    {"seq": 4, "time": 31540000, "agent": "vault", "action": "yield_claim_deferred", "params": {"token": "USDC"}}
  ],
  "expectations": {
    "metrics": [
      {"name": "yield/position-realized", "op": ":=", "value": 800},
      {"name": "yield/position-deferred", "op": ":=", "value": 0},
      {"name": "yield/position-reclaimed", "op": ":=", "value": 400}
    ],
    "terminal": [
      {"path": ["yield-positions", "vault", "status"], "equals": "withdrawn"}
    ]
  }
}
