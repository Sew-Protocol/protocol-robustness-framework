{
  "scenario-id": "y06-liquidity-shortage-deposit-blocked",
  "schema-version": "1.0",
  "description": "Pool in shortfall liquidity mode blocks new deposits (liquidity shortage at entry).",
  "threat-tags": ["yield-stress", "liquidity-shortage", "deposit-blocked"],
  "initial-block-time": 1000,
  "agents": [{"id": "vault", "address": "0xVault"}],
  "protocol-params": {"yield-profile": "aave-v3", "default-owner-id": "vault"},
  "yield-config": {
    "modules": {
      "aave-v3": {
        "tokens": {
          "USDC": {
            "apy": 0.05,
            "liquidity-mode": "shortfall",
            "shortfall": {"available-ratio": 0.5, "reason": "liquidity-shortfall"}
          }
        }
      }
    }
  },
  "options": {"minimal": true},
  "events": [
    {"seq": 0, "time": 1000, "agent": "vault", "action": "yield_deposit", "params": {"token": "USDC", "amount": 5000}}
  ],
  "expected-outcomes": [
    {"seq": 0, "action": "yield_deposit", "expect": "rejected"}
  ]
}
