{
  "scenario-id": "s103-negative-yield-shortfall-cascade",
  "title": "Negative Yield and Liquidity Shortfall Cascade",
  "schema-version": "1.0",
  "purpose": "yield-stress",
  "threat-tags": [
    "negative-yield",
    "shortfall",
    "deferred-recovery",
    "market-shock"
  ],
  "description": "A buyer creates an escrow backed by Aave yield (5% APY). After 6 months of normal positive accrual (~243 USDC unrealized yield), a simulated market event injects a DeFi stress condition: the liquidity index begins declining (negative yield at 3%) AND the Aave module enters a shortfall mode with only 80% of funds immediately redeemable. Two months later the seller cancels, triggering a final accrue step that partially erodes the accrued yield. On withdrawal, the shortfall mechanism defers 20% of gross funds. The buyer must claim the deferred amount once liquidity recovers.",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    }
  ],
  "protocol-params": {
    "yield-generation-module": "aave-v3",
    "resolver-fee-bps": 150
  },
  "yield-config": {
    "modules": {
      "aave-v3": {
        "tokens": {
          "USDC": {
            "apy": 0.05,
            "liquidity-mode": "available"
          }
        }
      }
    }
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "label": "buyer creates 10,000 USDC escrow backed by Aave yield",
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 10000,
        "yield-preset": "to-sender"
      }
    },
    {
      "seq": 1,
      "time": 15553000,
      "label": "6 months elapse (15,552,000 s) \u2014 positive yield accruing at 5% APY",
      "agent": "buyer",
      "action": "trigger-accrue",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 15553000,
      "label": "market shock: Aave index begins declining (-3% APY) and enters 80% shortfall liquidity mode",
      "agent": "buyer",
      "action": "set-yield-risk",
      "params": {
        "module-id": "aave-v3",
        "token": "USDC",
        "liquidity-mode": "shortfall",
        "failure-modes": [
          "negative-yield"
        ],
        "apy": 0.03,
        "shortfall": {
          "available-ratio": 0.8
        }
      }
    },
    {
      "seq": 3,
      "time": 20737000,
      "label": "seller agrees to cancel (sets recipient agree-to-cancel flag)",
      "agent": "seller",
      "action": "recipient-cancel",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 4,
      "time": 20737000,
      "label": "buyer agrees to cancel \u2014 both parties agree; escrow finalises, triggering final accrue under negative yield then shortfall withdrawal",
      "agent": "buyer",
      "action": "sender-cancel",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 5,
      "time": 20737001,
      "label": "buyer withdraws \u2014 receives fulfilled portion (80% of gross) immediately; 20% deferred in Aave",
      "agent": "buyer",
      "action": "withdraw-escrow",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 6,
      "time": 25921000,
      "label": "5 months later: Aave liquidity recovers \u2014 buyer can now claim deferred funds",
      "agent": "buyer",
      "action": "set-yield-risk",
      "params": {
        "module-id": "aave-v3",
        "token": "USDC",
        "liquidity-mode": "available",
        "failure-modes": []
      }
    },
    {
      "seq": 7,
      "time": 25921001,
      "label": "buyer claims deferred yield position",
      "agent": "buyer",
      "action": "claim-deferred-yield",
      "params": {
        "owner-id": "escrow:0"
      }
    }
  ],
  "expected-outcomes": [
    {
      "seq": 1,
      "action": "trigger-accrue",
      "expect": "ok"
    },
    {
      "seq": 2,
      "action": "set-yield-risk",
      "expect": "ok"
    },
    {
      "seq": 3,
      "action": "recipient-cancel",
      "expect": "ok"
    },
    {
      "seq": 4,
      "action": "sender-cancel",
      "expect": "ok"
    },
    {
      "seq": 5,
      "action": "withdraw-escrow",
      "expect": "ok"
    },
    {
      "seq": 6,
      "action": "set-yield-risk",
      "expect": "ok"
    },
    {
      "seq": 7,
      "action": "claim-deferred-yield",
      "expect": "ok"
    }
  ],
  "scenario-author": "@grifma",
  "provenance": {
    "author-id": "@grifma",
    "author": "Marc Griffiths"
  }
}
