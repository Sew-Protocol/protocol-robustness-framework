{
  "scenario-id": "s81-resolver-yield-accrual",
  "schema-version": "1.0",
  "initial-block-time": 1000,
  "agents": [
    {"id": "resolver", "address": "0xresolver", "role": "resolver"}
  ],
  "protocol-params": {
    "yield-generation-module": "fixed-rate",
    "resolver-fee-bps": 150
  },
  "yield-config": {
    "modules": {
      "fixed-rate": {
        "tokens": {
          "USDC": { "apy": 0.10 }
        }
      }
    }
  },
  "events": [
    {
      "seq": 0, "time": 1000, "agent": "resolver", "action": "register-stake",
      "params": { "amount": 10000, "yield-profile-id": "fixed-rate" }
    },
    {
      "seq": 1, "time": 31536000, "agent": "resolver", "action": "withdraw-stake",
      "params": { "amount": 1000 }
    }
  ]
}
