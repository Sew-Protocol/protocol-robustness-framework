{
  "scenario-id": "s108-negative-yield-mild",
  "title": "Negative Yield without Shortfall",
  "schema-version": "1.0",
  "purpose": "yield-stress",
  "threat-tags": ["negative-yield"],
  "description": "Buyer creates escrow with yield. Market shock causes minor negative yield, but total funds remain above principal. Settlement occurs without liquidity shortfall.",
  "initial-block-time": 1000,
  "agents": [{"id": "buyer", "address": "0xbuyer", "strategy": "honest"}, {"id": "seller", "address": "0xseller", "strategy": "honest"}],
  "protocol-params": {"yield-generation-module": "aave-v3"},
  "yield-config": {"modules": {"aave-v3": {"tokens": {"USDC": {"apy": 0.05, "liquidity-mode": "available"}}}}},
  "events": [
    {"seq": 0, "time": 1000, "label": "create", "agent": "buyer", "action": "create_escrow", "params": {"token": "USDC", "to": "0xseller", "amount": 10000, "yield-preset": "to-sender"}},
    {"seq": 1, "time": 5000, "label": "market shock: minor negative yield", "agent": "buyer", "action": "set-yield-risk", "params": {"module-id": "aave-v3", "token": "USDC", "liquidity-mode": "available", "apy": -0.01}},
    {"seq": 2, "time": 6000, "label": "settle", "agent": "buyer", "action": "sender-cancel", "params": {"workflow-id": 0}},
    {"seq": 3, "time": 6000, "label": "seller accepts", "agent": "seller", "action": "recipient-cancel", "params": {"workflow-id": 0}}
  ],
  "expected-outcomes": [{"seq": 1, "action": "set-yield-risk", "expect": "ok"}, {"seq": 2, "action": "sender-cancel", "expect": "ok"}, {"seq": 3, "action": "recipient-cancel", "expect": "ok"}]
}
