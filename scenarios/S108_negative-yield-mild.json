{
  "scenario-id": "s108-negative-yield-mild",
  "title": "Negative Yield without Shortfall",
  "schema-version": "1.0",
  "purpose": "yield-stress",
  "threat-tags": ["negative-yield"],
  "description": "Buyer creates escrow with yield. After one year of positive accrual, a market shock enables negative yield (mark-to-market). Settlement after a further accrual window erodes unrealized yield while gross remains at or above principal. Refund completes without liquidity shortfall.",
  "initial-block-time": 1000,
  "agents": [{"id": "buyer", "address": "0xbuyer", "strategy": "honest"}, {"id": "seller", "address": "0xseller", "strategy": "honest"}],
  "protocol-params": {"yield-generation-module": "aave-v3"},
  "yield-config": {"modules": {"aave-v3": {"tokens": {"USDC": {"apy": 0.05, "liquidity-mode": "available"}}}}},
  "events": [
    {"seq": 0, "time": 1000, "label": "create", "agent": "buyer", "action": "create_escrow", "params": {"token": "USDC", "to": "0xseller", "amount": 10000, "yield-preset": "to-sender"}},
    {"seq": 1, "time": 31536001, "label": "one year positive accrual", "agent": "buyer", "action": "trigger-accrue", "params": {"workflow-id": 0}},
    {"seq": 2, "time": 31536002, "label": "market shock: negative yield mark-to-market", "agent": "buyer", "action": "set-yield-risk", "params": {"module-id": "aave-v3", "token": "USDC", "liquidity-mode": "available", "apy": -0.01, "failure-modes": ["negative-yield"]}},
    {"seq": 3, "time": 39312002, "label": "mutual cancel after negative accrual window", "agent": "buyer", "action": "sender-cancel", "params": {"workflow-id": 0}},
    {"seq": 4, "time": 39312002, "label": "seller accepts", "agent": "seller", "action": "recipient-cancel", "params": {"workflow-id": 0}}
  ],
  "expected-outcomes": [
    {"seq": 1, "action": "trigger-accrue", "expect": "ok"},
    {"seq": 2, "action": "set-yield-risk", "expect": "ok"},
    {"seq": 3, "action": "sender-cancel", "expect": "ok"},
    {"seq": 4, "action": "recipient-cancel", "expect": "ok"}
  ],
  "expectations": {
    "metrics": [
      {"name": "yield/escrow-principal", "op": ":=", "value": 9950},
      {"name": "yield/escrow-gross", "op": ":=", "value": 9950},
      {"name": "buyer/claimable", "op": ":=", "value": 9950},
      {"name": "yield/escrow-deferred", "op": ":=", "value": 0}
    ],
    "terminal": [
      {"path": ["live-states", 0], "equals": "refunded"},
      {"path": ["escrow-transfers", 0, "escrow-state"], "equals": "refunded"}
    ],
    "step-terminal": [
      {
        "seq": 1,
        "path": ["yield-positions", ["sew/escrow", 0], "unrealized-yield"],
        "op": ":>",
        "value": 0
      },
      {
        "seq": 2,
        "path": ["yield-positions", ["sew/escrow", 0], "unrealized-yield"],
        "op": ":>",
        "value": 0
      }
    ]
  }
}
