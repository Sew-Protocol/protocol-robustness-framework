{
  "scenario-id" : "s-dr-086-evidence-after-resolver-rotation",
  "schema-version" : "1.0",
  "initial-block-time" : 1000,
  "scenario-title" : "Evidence after governance resolver rotation — submit_evidence works after resolver rotated mid-dispute",
  "scenario-purpose" : "Verify that evidence can still be submitted after governance rotates the dispute resolver mid-dispute. The escrow remains in :disputed state, so submit_evidence must succeed and the evidence must be recorded.",
  "purpose" : "adversarial-robustness",
  "threat-tags" : ["dispute-resolution", "evidence", "governance", "rotation", "timing"],
  "tags" : ["suite/dispute-resolution", "coverage/evidence"],
  "agents" : [ {
    "id" : "buyer", "address" : "0xbuyer", "strategy" : "honest"
  }, {
    "id" : "seller", "address" : "0xseller", "strategy" : "honest"
  }, {
    "id" : "resolver", "address" : "0xresolver", "role" : "resolver"
  }, {
    "id" : "new-resolver", "address" : "0xnewresolver", "role" : "resolver"
  }, {
    "id" : "governance", "address" : "0xgov", "role" : "governance"
  }, {
    "id" : "keeper", "address" : "0xkeeper", "role" : "keeper"
  } ],
  "protocol-params" : {
    "resolver-fee-bps" : 150,
    "appeal-window-duration" : 60,
    "max-dispute-duration" : 2592000
  },
  "events" : [ {
    "seq" : 0, "time" : 1000, "agent" : "buyer", "action" : "create_escrow",
    "params" : { "token" : "USDC", "to" : "0xseller", "amount" : 5000, "custom-resolver" : "0xresolver" }
  }, {
    "seq" : 1, "time" : 1060, "agent" : "buyer", "action" : "raise_dispute",
    "params" : { "workflow-id" : 0 }
  }, {
    "seq" : 2, "time" : 1090, "agent" : "governance", "action" : "rotate_dispute_resolver",
    "params" : { "workflow-id" : 0, "new-resolver" : "0xnewresolver" }
  }, {
    "seq" : 3, "time" : 1120, "agent" : "seller", "action" : "submit_evidence",
    "params" : { "workflow-id" : 0, "evidence-hash" : "0xevidence-after-rotation" }
  }, {
    "seq" : 4, "time" : 1150, "agent" : "new-resolver", "action" : "execute_resolution",
    "params" : { "workflow-id" : 0, "is-release" : true, "resolution-hash" : "0xhash" }
  }, {
    "seq" : 5, "time" : 1250, "agent" : "keeper", "action" : "execute_pending_settlement",
    "params" : { "workflow-id" : 0 }
  } ],
  "scenario-notes" : "Governance rotates resolver at t=1090 (while escrow is :disputed). Evidence is submitted at t=1120 (post-rotation) — must succeed because state is still :disputed. New resolver executes resolution at t=1150 and settlement at t=1250 (past appeal deadline 1120+60=1180). Tests that evidence operations are safe under resolver rotation.",
  "scenario-author" : "@kilo-research",
  "provenance" : { "author-id" : "@kilo-research", "author" : "Kilo Research" }
}
