{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sew-protocol/schemas/claimable-classification-v2.json",
  "title": "Claimable Classification",
  "type": "object",
  "required": ["schema_version", "shortfall_policy", "classes"],
  "properties": {
    "schema_version": {
      "const": "claimable-classification.v2"
    },
    "observations_status": {
      "type": "string",
      "enum": ["taxonomy-only", "terminal-aggregated", "single-scenario"]
    },
    "provenance": {
      "type": "object",
      "properties": {
        "producer": { "type": "string" },
        "produced_at": { "type": "string" },
        "run_id": { "type": "string" },
        "git_sha": { "type": "string" }
      },
      "additionalProperties": true
    },
    "shortfall_policy": {
      "type": "object",
      "required": ["mode", "allocation", "rounding_policy"],
      "properties": {
        "mode": { "type": "string" },
        "allocation": { "type": "string" },
        "rounding_policy": {
          "const": "floor-to-asset-decimals.v1"
        }
      },
      "additionalProperties": true
    },
    "classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "delivery_model",
          "source",
          "recipient_type",
          "risk_class",
          "claimable_v2_domains"
        ],
        "properties": {
          "delivery_model": { "type": "string" },
          "source": { "type": "string" },
          "recipient_type": { "type": "string" },
          "risk_class": { "type": "string" },
          "claimable_v2_domains": {
            "type": "array",
            "items": { "type": "string" }
          },
          "boundary_invariant": { "type": "string" },
          "v1_class": { "type": "string" },
          "shortfall_outcome": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "terminal_observations": {
      "type": ["object", "null"],
      "properties": {
        "scope": { "type": "string" },
        "scenario_count": { "type": "integer", "minimum": 0 },
        "scenarios_passed": { "type": "integer", "minimum": 0 },
        "aggregation": { "type": "string" },
        "aggregation_note": { "type": "string" },
        "by_class": { "type": "object", "additionalProperties": true },
        "by_domain": { "type": "object", "additionalProperties": true },
        "boundaries": { "type": "object", "additionalProperties": true },
        "escrow_yield_outcome_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "boundary_headroom": { "type": "object", "additionalProperties": true },
        "funds_ledger": { "type": "object", "additionalProperties": true },
        "scenario_highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "scenario_id": { "type": "string" },
              "workflows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "workflow_id": {},
                    "total_claimable": { "type": "integer" },
                    "by_domain": { "type": "object" },
                    "by_class": { "type": "object" },
                    "boundary_headroom": { "type": "object" }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
