{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Evidence v1",
  "description": "Structured evidence record for a critical simulation transition. Includes content hashes, replay coordinates, causality links, and importance classification.",
  "type": "object",
  "required": [
    "evidence/schema-version",
    "evidence/type",
    "evidence/importance",
    "evidence/hash",
    "scenario/id",
    "run/id",
    "event/seq",
    "world/before-hash",
    "world/after-hash"
  ],
  "properties": {
    "evidence/schema-version": { "type": "string", "pattern": "^event-evidence\\.v[0-9]+$" },
    "evidence/type": { "type": "string" },
    "evidence/reason": { "type": "string" },
    "evidence/importance": { "type": "string", "enum": ["core", "diagnostic", "trace"] },
    "evidence/hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "evidence/prev-hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "scenario/id": { "type": "string" },
    "run/id": { "type": "string" },
    "trial/id": { "type": "string" },
    "event/seq": { "type": "integer", "minimum": 0 },
    "transition/id": { "type": "string" },
    "actor/id": { "type": "string" },
    "action/type": { "type": "string" },
    "decision/path": { "type": "array", "items": { "type": "string" } },
    "caused-by/evidence-id": { "type": "string" },
    "caused-by/rule": { "type": "string" },
    "caused-by/action": { "type": "string" },
    "world/before-hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "world/after-hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "input/hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "output/hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "replay/seed": { "type": "integer" },
    "oracle/mode": { "type": "string" },
    "oracle/fixture-id": { "type": "string" },
    "oracle/cursor": { "type": "integer" },
    "financial/amount": { "type": "number" },
    "financial/asset": { "type": "string" },
    "observer/ns": { "type": "string" },
    "observer/fn": { "type": "string" },
    "observer/version": { "type": "string" },
    "git/commit": { "type": "string" },
    "attribution": { "type": "object" },
    "attribution/quality": { "type": "string", "enum": ["complete", "partial", "missing"] },
    "missing/attribution": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "object" },
    "pre-state": { "type": "object" },
    "post-state": { "type": "object" },
    "calculation": {}
  }
}
