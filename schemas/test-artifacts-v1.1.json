{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Artifacts Registry v1.1 [DEPRECATED — use test-artifacts-v1.2.json]",
  "description": "Legacy v1.1 schema retained for historical validation. Use test-artifacts-v1.2.json for new registries.",
  "type": "object",
  "required": ["schema_version", "artifacts"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["test-artifacts.v1.1"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "path", "sha256", "importance"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "importance": { "type": "string", "enum": ["CORE", "DIAGNOSTIC", "TRACE"] },
          "sha256": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "sha256"],
              "properties": {
                "id": { "type": "string" },
                "sha256": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
