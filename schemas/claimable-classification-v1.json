{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://sew-protocol/schemas/claimable-classification-v1.json",
  "title" : "Claimable Classification",
  "type" : "object",
  "required" : [ "schema_version", "shortfall_policy", "classes" ],
  "properties" : {
    "schema_version" : {
      "const" : "claimable-classification.v1"
    },
    "shortfall_policy" : {
      "type" : "object",
      "required" : [ "mode", "allocation", "rounding_policy" ],
      "properties" : {
        "mode" : {
          "type" : "string"
        },
        "allocation" : {
          "type" : "string"
        },
        "rounding_policy" : {
          "const" : "floor-to-asset-decimals.v1"
        }
      },
      "additionalProperties" : true
    },
    "classes" : {
      "type" : "object",
      "required" : [ "escrow_principal", "escrow_yield", "resolver_payment", "bond_refund", "protocol_fee" ],
      "additionalProperties" : {
        "type" : "object",
        "required" : [ "delivery_model", "source", "recipient_type", "risk_class" ],
        "properties" : {
          "delivery_model" : {
            "type" : "string"
          },
          "source" : {
            "type" : "string"
          },
          "recipient_type" : {
            "type" : "string"
          },
          "risk_class" : {
            "type" : "string"
          }
        },
        "additionalProperties" : true
      }
    }
  },
  "additionalProperties" : true
}