{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sew-protocol/schemas/test-run-v1.json",
  "title": "Test Run Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "framework",
    "model",
    "suite",
    "capabilities_resolved",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": "test-run.v1"},
    "contract_version": {"type": "string"},
    "produced_by": {"type": "object"},
    "run_id": {"type": "string"},
    "created_at": {"type": "string"},
    "framework": {"type": "object"},
    "model": {"type": "object"},
    "suite": {"type": "object"},
    "capabilities_resolved": {"type": "object"},
    "artifacts": {"type": "object"}
  },
  "additionalProperties": true
}