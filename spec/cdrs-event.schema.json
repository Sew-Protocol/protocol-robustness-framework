{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "title" : "CDRS Event",
  "description" : "A single step in a dispute resolution protocol execution",
  "type" : "object",
  "required" : [ "cdrs_version", "event_type", "step_type", "context_id", "actor", "timestamp", "state_bucket" ],
  "additionalProperties" : true,
  "properties" : {
    "seq" : {
      "type" : "integer",
      "description" : "Deterministic sequence number"
    },
    "timestamp" : {
      "type" : "integer",
      "description" : "Unix timestamp or sequence number"
    },
    "step_type" : {
      "type" : "string",
      "enum" : [ "protocol-transition", "economic-effect", "environmental-change" ]
    },
    "context_id" : {
      "type" : "string",
      "description" : "Unique identifier for the dispute context (e.g. wf0)"
    },
    "event_type" : {
      "type" : "string",
      "description" : "Semantic name of the action (e.g. DISPUTE_RAISED)"
    },
    "attributes" : {
      "type" : "object",
      "description" : "Flexible protocol-specific data"
    },
    "state_bucket" : {
      "type" : "string",
      "enum" : [ "IDLE", "ACTIVE", "CHALLENGED", "RECONCILING", "SETTLED" ]
    },
    "actor" : {
      "type" : "string",
      "description" : "ID or address of the acting party"
    },
    "cdrs_version" : {
      "type" : "string",
      "const" : "0.1"
    }
  }
}