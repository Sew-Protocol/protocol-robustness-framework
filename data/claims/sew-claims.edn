 {:claim/id         :force-authorisation-exact-scope-single-use
  :description      "Within the Sew model, a force-authorisation can execute at most once and only for its immutable grant-time custody scope."
  :assumptions      ["force-authorisation record and held ledger are persisted atomically"
                     "governance identity is correctly configured"
                     "registered transition and world invariants are run"]
  :validated-by     ["protocols_src/test/resolver_sim/protocols/sew/force_authorisation_test.clj"
                     "protocols_src/test/resolver_sim/protocols/sew/accounting_test.clj"
                     "benchmarks/packs/sew/force-authorisation-custody-v1.edn"]
  :falsified-if     "A trace produces a forced held adjustment with a reused authorization ID or a scope differing from its persisted grant."
  :confidence       :trace-bounded
  :status           :not-falsified
  :last-validated   nil
  :counterexamples  []}

 {:claim/id         :held-custody-position-isolation
  :description      "Within the Sew model, a custody outflow cannot use aggregate token funds from a different derived workflow, account, or position."
  :assumptions      ["all custody mutations use add-held or sub-held"
                     "reason-derived position scope is complete"
                     "registered transition and world invariants are run"]
  :validated-by     ["protocols_src/test/resolver_sim/protocols/sew/accounting_test.clj"
