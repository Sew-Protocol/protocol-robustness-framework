{
  "schema-version": "1.1",
  "id": "scenarios/s60-partial-withdraw-then-slash-ordering",
  "title": "Partial Withdraw Then Slash Ordering",
  "purpose": "regression",
  "threat-tags": [
    "stake-withdrawal",
    "slash-ordering"
  ],
  "scenario-id": "s60-partial-withdraw-then-slash-ordering",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "resolver",
      "address": "0xresolver",
      "type": "resolver"
    },
    {
      "id": "buyer",
      "address": "0xbuyer",
      "type": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "type": "honest"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "type": "resolver"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 0,
    "max-dispute-duration": 300,
    "resolver-bond-bps": 0,
    "dispute-resolver": "0xresolver"
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "resolver",
      "action": "register_stake",
      "params": {
        "amount": 5000
      }
    },
    {
      "seq": 1,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 4000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 2,
      "time": 1001,
      "agent": "resolver",
      "action": "withdraw_stake",
      "params": {
        "amount": 2000
      }
    },
    {
      "seq": 3,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 4,
      "time": 1360,
      "agent": "keeper",
      "action": "auto_cancel_disputed",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@grifma"
}
