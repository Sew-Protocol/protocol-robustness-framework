  "title": "s-auto-cancel-time-orphaned-by-dispute",
  "scenario-author": "@research",
  "purpose": "equilibrium-validation",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "type": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "type": "honest"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "type": "keeper"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 0,
    "max-dispute-duration": 600
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 2000,
        "auto-cancel-time": 1500
      }
    },
    {
      "seq": 1,
      "time": 1200,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1500,
      "agent": "keeper",
      "action": "automate_timed_actions",
      "params": {
        "workflow-id": 0
      }
    }
