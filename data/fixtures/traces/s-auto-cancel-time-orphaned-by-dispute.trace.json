  "theory": {
    "claim-id": "claims/cancellation-auto-time-orphaned-by-dispute",
    "claim": "[FIXED] A dispute raised before auto-cancel-time no longer orphans the deadline. When auto-cancel-time arrives (t=1500) on a DISPUTED escrow, automate-timed-actions now fires auto-cancel-on-disputed (NOT IN SOLIDITY). The buyer is refunded immediately at t=1500 without waiting for max-dispute-duration (1200+600=1800). This closes the griefing vector where a frivolous dispute blocked automated cancel.",
    "equilibrium-concept": [
      "cancellation-dominance"
    ],
    "mechanism-properties": [
      "budget-balance",
      "individual-rationality"
    ],
    "assumptions": [],
    "falsifies-if": []
  }
