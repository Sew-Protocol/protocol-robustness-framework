{
  "schema-version": "1.1",
  "threat-tags": [
    "same-block-ordering"
  ],
  "initial-block-time": 1000,
  "scenario-author": "@grifma",
  "expectations": {
    "terminal": [
      {
        "path": [
          "live-states",
          0
        ],
        "equals": "released"
      }
    ],
    "metrics": [
      {
        "name": "resolutions-executed",
        "op": ":=",
        "value": 1
      }
    ]
  },
  "id": "scenarios/same-block-ordering",
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "role": "buyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "role": "seller",
      "strategy": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver",
      "strategy": "honest"
    }
  ],
  "scenario-id": "same-block-ordering",
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 1000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 1,
      "time": 1000,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1000,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true
      }
    }
  ],
  "theory": {
    "claim-id": "claims/atomic-lifecycle-consistency",
    "claim": "Same-block lifecycle transitions cannot produce inconsistent state, double settlement, or fund loss.",
    "assumptions": [
      "Transactions are processed in sequence order within the replay trace"
    ],
    "falsifies-if": [
      {
        "metric": "double-settlements",
        "op": ">",
        "value": 0
      },
      {
        "metric": "invalid-state-transitions",
        "op": ">",
        "value": 0
      },
      {
        "metric": "funds-lost",
        "op": ">",
        "value": 0
      }
    ]
  },
  "title": "Same-Block Dispute and Resolution",
  "description": "Verifies that create -> dispute -> resolve in the same block works correctly.",
  "purpose": "adversarial-robustness",
  "protocol-params": {
    "resolver-bond-bps": 0
  }
}