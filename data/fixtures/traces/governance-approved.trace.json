{
  "id": "scenarios/governance-approved",
  "scenario-id": "governance-approved",
  "title": "Governance Approved Slash Execution",
  "description": "Slash is proposed first, then executed only after governance approval window and settlement timing constraints.",
  "purpose": "regression",
  "schema-version": "1.1",
  "initial-block-time": 1000,
  "threat-tags": [
    "governance-enforcement",
    "approval-gated-slashing"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "role": "buyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "role": "seller",
      "strategy": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver",
      "strategy": "malicious"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper",
      "strategy": "honest"
    },
    {
      "id": "governance",
      "address": "0xgovernance",
      "role": "governance",
      "strategy": "honest"
    }
  ],
  "expectations": {
    "terminal": [
      {
        "path": [
          "live-states",
          0
        ],
        "equals": "released"
      }
    ]
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "resolver",
      "action": "register_stake",
      "params": {
        "amount": 3000
      }
    },
    {
      "seq": 1,
      "time": 1020,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 2000,
        "custom-resolver": "0xresolver"
      }
    },
    {
      "seq": 2,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 3,
      "time": 1120,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": 0,
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 4,
      "time": 1130,
      "agent": "governance",
      "action": "propose_fraud_slash",
      "params": {
        "workflow-id": 0,
        "resolver-addr": "0xresolver",
        "amount": 1500
      }
    },
    {
      "seq": 5,
      "time": 1241,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 6,
      "time": 1250,
      "agent": "governance",
      "action": "execute_fraud_slash",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "scenario-author": "@codex"
}
