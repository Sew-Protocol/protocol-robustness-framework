{
  "scenario-id": "s118-withdraw-while-paused",
  "title": "s118-withdraw-while-paused",
  "purpose": "pause-rejection",
  "schema-version": "1.1",
  "initial-block-time": 1000,
  "id": "scenarios/s118-withdraw-while-paused",
  "threat-tags": [
    "pause-gap",
    "withdraw-while-paused"
  ],
  "scenario-author": "@kilo-automation",
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "strategy": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "strategy": "honest"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "role": "keeper"
    },
    {
      "id": "gov",
      "address": "0xgov",
      "type": "governance"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150
  },
  "strict-expected-errors?": true,
  "expected-errors": [
    {
      "seq": 4,
      "action": "withdraw_escrow",
      "error": "protocol-paused"
    }
  ],
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 5000
      }
    },
    {
      "seq": 1,
      "time": 1100,
      "agent": "buyer",
      "action": "sender_cancel",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 2,
      "time": 1150,
      "agent": "seller",
      "action": "recipient_cancel",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 3,
      "time": 1200,
      "agent": "gov",
      "action": "set_paused",
      "params": {
        "paused?": true
      }
    },
    {
      "seq": 4,
      "time": 1250,
      "agent": "buyer",
      "action": "withdraw_escrow",
      "params": {
        "workflow-id": 0
      }
    },
    {
      "seq": 5,
      "time": 1300,
      "agent": "gov",
      "action": "set_paused",
      "params": {
        "paused?": false
      }
    },
    {
      "seq": 6,
      "time": 1350,
      "agent": "buyer",
      "action": "withdraw_escrow",
      "params": {
        "workflow-id": 0
      }
    }
  ],
  "provenance": {
    "author-id": "@kilo-automation",
    "author": "Kilo automation \u2014 scenario for withdraw-while-paused"
  }
}