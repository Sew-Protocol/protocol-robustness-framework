{
  "id": "scenarios/spe-reg-v1-bounded-spe-pass-honest-resolver",
  "scenario-id": "spe-reg-v1-bounded-spe-pass-honest-resolver",
  "title": "SPE Regression — bounded-public-state-epsilon-SPE PASS (honest resolver, no ex-post regret)",
  "description": "Resolver registers stake (3000), dispute raised, execute_resolution is a proper-subgame node (all state public). Resolver is not slashed; terminal stake equals stake at decision point. bounded-public-state-epsilon-spe finds proper-subgames-checked >= 1 and max-regret = 0 → PASS.",
  "purpose": "regression",
  "schema-version": "1.1",
  "initial-block-time": 1000,
  "threat-tags": [],
  "agents": [
    {"id": "buyer",    "address": "0xbuyer",    "role": "buyer",    "strategy": "honest"},
    {"id": "seller",   "address": "0xseller",   "role": "seller",   "strategy": "honest"},
    {"id": "resolver", "address": "0xresolver", "role": "resolver", "strategy": "honest"},
    {"id": "keeper",   "address": "0xkeeper",   "role": "keeper",   "strategy": "honest"}
  ],
  "theory": {
    "claim-id": "claims/spe-reg-bounded-pass",
    "claim": "An honest resolver whose terminal stake equals their stake at the decision node satisfies the bounded-public-state-epsilon-SPE heuristic (proper subgame, no ex-post regret).",
    "equilibrium-concept": ["bounded-public-state-epsilon-spe"],
    "spe-config": {
      "regret-threshold": 0,
      "epsilon-abs": 0.0,
      "epsilon-rel": 0.0
    },
    "falsifies-if": [],
    "assumptions": ["resolver-stake-not-slashed", "single-trace-proxy"]
  },
  "expectations": {
    "terminal": [{"path": ["live-states", 0], "equals": "released"}],
    "metrics": [{"name": "total-escrows", "op": ":=", "value": 1}]
  },
  "protocol-params": {
    "appeal-window-duration": 120,
    "fee-bps": 150
  },
  "events": [
    {"seq": 0, "time": 1000, "agent": "resolver", "action": "register_stake",
     "params": {"amount": 3000}},
    {"seq": 1, "time": 1010, "agent": "buyer", "action": "create_escrow",
     "params": {"token": "USDC", "to": "0xseller", "amount": 2000, "custom-resolver": "0xresolver"},
     "save-id-as": "wf0"},
    {"seq": 2, "time": 1060, "agent": "buyer", "action": "raise_dispute",
     "params": {"workflow-id": "wf0"}},
    {"seq": 3, "time": 1120, "agent": "resolver", "action": "execute_resolution",
     "params": {"workflow-id": "wf0", "is-release": true, "resolution-hash": "0xhash"}},
    {"seq": 4, "time": 1241, "agent": "keeper", "action": "execute_pending_settlement",
     "params": {"workflow-id": "wf0"}}
  ]
