{
  "description": "L0 refunds buyer; seller escalates; L1 releases to seller \u2014 participant role does not break escalation rules.",
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 60,
    "max-dispute-duration": 2592000,
    "resolution-module": "0xkleros-proxy",
    "escalation-resolvers": {
      "0": "0xl0",
      "1": "0xl1",
      "2": "0xl2"
    }
  },
  "expected-outcome": {
    "workflow-0": "release-after-l1-reversal"
  },
  "theory": {
    "claim-id": "forking-strategist-seller-escalates",
    "claim": "Seller escalation may fork L0 refund to L1 release with correct bonds and hashes.",
    "assumptions": [
      "appeal-window-60s",
      "kleros-escalation-ladder"
    ],
    "falsifies-if": [
      {
        "metric": "funds-lost",
        "op": ">",
        "value": 0
      },
      {
        "metric": "double-settlements",
        "op": ">",
        "value": 0
      }
    ]
  },
  "threat-tags": [
    "forking-strategist",
    "appeal-escalation"
  ],
  "purpose": "adversarial-robustness",
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 6000
      },
      "save-id-as": "wf0"
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {
        "workflow-id": "wf0"
      }
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "l0resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": "wf0",
        "is-release": false,
        "resolution-hash": "0xl0hash"
      }
    },
    {
      "seq": 3,
      "time": 1130,
      "agent": "seller",
      "action": "escalate_dispute",
      "params": {
        "workflow-id": "wf0"
      }
    },
    {
      "seq": 4,
      "time": 1190,
      "agent": "l1resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": "wf0",
        "is-release": true,
        "resolution-hash": "0xl1hash"
      }
    },
    {
      "seq": 5,
      "time": 1255,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {
        "workflow-id": "wf0"
      }
    }
  ],
  "schema-version": "1.1",
  "scenario-title": "Seller-initiated L1 fork to release",
  "scenario-author": "@grifma",
  "scenario-id": "s29-forking-strategist-seller-escalates",
  "title": "Forking Strategist: Seller Escalates",
  "scenario-purpose": "Verify non-buyer participant may escalate and fork an L0 refund to release.",
  "threat-model": {
    "actor": "seller",
    "strategy": "forking-strategist",
    "goal": "Reverse L0 refund via L1 release."
  },
  "security-properties": [
    "escalation-level-monotonic",
    "appeal-window-enforcement",
    "resolution-hash-isolation",
    "claimable-balance-isolation"
  ],
  "id": "scenarios\/s29-forking-strategist-seller-escalates",
  "notes": null,
  "expectations": {
    "terminal": [
      {
        "path": [
          "live-states",
          0
        ],
        "equals": "released"
      },
      {
        "path": [
          "claimable",
          0,
          "0xseller"
        ],
        "equals": 5910
      },
      {
        "path": [
          "dispute-levels",
          0
        ],
        "equals": 1
      }
    ]
  },
  "agents": [
    {
