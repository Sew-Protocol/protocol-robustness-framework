      "type": "forking-strategist"
    },
    {
      "id": "l0resolver",
      "address": "0xl0",
      "type": "resolver"
    },
    {
      "id": "l1resolver",
      "address": "0xl1",
      "type": "resolver"
    },
    {
      "id": "keeper",
      "address": "0xkeeper",
      "type": "keeper"
    }
  ],
  "initial-block-time": 1000,
  "scenario-family": "forking-strategist"
