{:concept/id :allocation/deferred-claim
 :concept/name "Deferred claim recovery"
 :concept/type :allocation
 :concept/layer :stakeholder

 :concept/summary
 "When available value is insufficient to satisfy a valid claim in full,
  the unpaid remainder is preserved as a deferred claim so it can be
  inspected, audited, and potentially recovered later."

 :concept/stakeholder-question
 "If I cannot be paid in full now, does the protocol preserve what I am
  still owed in a way that can be verified and later recovered?"

 :concept/protocols #{:protocol/sew-v1 :protocol/prf}

 :concept/related
 [:allocation/partial-fill
  :allocation/shortfall
  :allocation/pro-rata-fairness
  :consensus/finality
  :verifiable-assurance/forensic-confidence]

 :concept/roles
 {:claimant
  {:description "Party with a valid unpaid remainder after partial settlement."
   :maps-to [:protocol.actor/sender :protocol.actor/recipient]}
  :allocation-engine
  {:description "Protocol logic that records and tracks deferred amounts."
   :maps-to [:protocol.actor/resolution-module]}
  :auditor
  {:description "Party verifying that deferred claims were recorded faithfully."
   :maps-to [:protocol.actor/verifier]}}

 :concept/entities
 {:deferred-claim
  {:description "Unpaid remainder preserved for future recovery."
   :maps-to [:protocol.entity/deferred-claim]}
  :claim-basis
  {:description "Original valid claim amount before shortfall adjustment."
   :maps-to [:protocol.entity/claim]}
  :fulfilled-amount
  {:description "Amount already paid before deferral."
   :maps-to [:protocol.entity/settlement]}
  :recovery-record
  {:description "Traceable record linking the deferred amount to later recovery."
   :maps-to [:protocol.entity/evidence]}}

 :concept/actions
 {:record-deferred-claim
  {:description "Persist the unpaid remainder after partial settlement."
   :maps-to [:protocol.action/record-deferred-claim]}
  :verify-deferred-claim
  {:description "Check that deferred amount equals valid claim minus fulfilled amount."
   :maps-to [:protocol.action/verify-allocation :protocol.action/check-invariant]}
  :recover-deferred-claim
  {:description "Apply future recovery to an existing deferred claim."
   :maps-to [:protocol.action/settle :protocol.action/partial-fill]}}

 :concept/outcomes
 {:claim-deferred
  {:description "Unpaid remainder is preserved for future recovery."
   :maps-to [:protocol.outcome/deferred]}
  :claim-recovered
  {:description "Previously deferred amount is later recovered in full or in part."
   :maps-to [:protocol.outcome/released]}
  :claim-lost
  {:description "Unpaid remainder is not preserved, blocking later recovery."
   :maps-to [:protocol.outcome/stuck]}}

 :concept/failure-modes
 [{:failure/id :deferred-claim-missing
   :failure/name "Deferred claim missing"
   :failure/summary
   "A partial fill occurs but the unpaid remainder is not recorded."
   :protocol-mechanisms [:deferred-claims :shortfall-accounting]
   :stakeholder-impact
   "Claimants lose visibility into what they are still owed."}

  {:failure/id :deferred-claim-miscalculated
   :failure/name "Deferred claim miscalculated"
   :failure/summary
   "Recorded deferred amount does not match claim basis minus fulfilled amount."
   :protocol-mechanisms [:conservation-check :allocation-engine]
   :stakeholder-impact
   "Future recovery rights become inaccurate or unfair."}

  {:failure/id :deferred-claim-unrecoverable
   :failure/name "Deferred claim unrecoverable"
   :failure/summary
   "Deferred claims are recorded but cannot be matched to later recovery paths."
   :protocol-mechanisms [:deferred-claims :evidence-linkage]
   :stakeholder-impact
   "Recorded deficits cannot be resolved transparently."}]

 :concept/metrics
 {:deferred-claim-count
  {:description "Number of claims with unpaid remainder preserved."
   :source :derived-from-world-state}
  :deferred-amount-total
  {:description "Total value still owed across deferred claims."
   :source :derived-from-world-state}
  :recovery-ratio
  {:description "Fraction of deferred value later recovered."
   :source :derived-from-trace}}

 :concept/assumptions
 ["Partial settlement can occur before full recovery is available."
  "Deferred claims remain traceable to the original valid claim."
  "Concept labels do not change protocol validity."]

 :concept/out-of-scope
 ["Legal enforceability of deferred recovery."
  "Off-chain debt collection or negotiation."
  "Priority changes imposed by external legal processes."]}
