{:concept/id :concept/confidence
 :concept/name "Confidence"
 :concept/type :framework
 :concept/layer :framework-explanation
 :concept/summary "The strength of support for a result or claim, distinct from pass/fail status."
 :concept/stakeholder-question "How strongly is this result supported?"
 :concept/protocols #{:protocol/sew-v1}
 :concept/frameworks #{:framework/prf}
  :concept/related [:verifiable-assurance/forensic-confidence :consensus/evidence :concept/coverage :concept/determinism]
 :concept/roles
 {:role/reviewer {:description "Evaluates whether benchmark results have adequate evidence, coverage, and determinism to support their claims." :maps-to []} :role/researcher {:description "Uses confidence dimensions to qualify benchmark findings and identify gaps." :maps-to []} :role/protocol-designer {:description "Uses confidence to assess whether invariant and benchmark results are trustworthy enough to inform protocol changes." :maps-to []}}
 :concept/entities
 {:entity/claim-result
  {:description "A structured outcome for a single claim tested by a scenario or benchmark."
   :maps-to [:protocol.entity/claim-result]}
  :entity/evidence-artifact
  {:description "A hash-addressed artifact that supports a claim result (replay output, attestation, registry node)."
   :maps-to [:protocol.entity/evidence]}
  :entity/benchmark-run
  {:description "A full execution of a benchmark pack producing a set of claim results with associated confidence values."
   :maps-to [:protocol.entity/benchmark-run]}}
 :concept/actions
 {:action/test-scenario
  {:description "Execute a scenario to produce a result for one or more claims."
   :maps-to [:protocol.action/run-scenario]}
  :action/evaluate-claim
  {:description "Assess a claim result against expectations and theory, producing a pass/fail verdict."
   :maps-to [:protocol.action/evaluate-claim]}
  :action/attest-result
  {:description "Produce an attestation for a claim result, linking evidence artifacts into a chain."
   :maps-to [:protocol.action/attest]}}
 :concept/outcomes
 {:outcome/high-confidence
  {:description "The claim result is supported by strong evidence, broad coverage, deterministic replay, and independent attestation."
   :maps-to [:protocol.outcome/pass]}
   :outcome/medium-confidence
   {:description "The claim result is supported but has gaps in coverage, non-deterministic elements, or missing attestation."
    :maps-to [:protocol.outcome/warn]}
  :outcome/low-confidence
  {:description "The claim result has significant evidence, coverage, or determinism gaps and should not be relied upon without further investigation."
   :maps-to [:protocol.outcome/warn]}}
 :concept/failure-modes
  [{:failure/id :failure/binary-pass-overclaim
    :failure/name "Binary-pass overclaim"
    :failure/summary "A benchmark reports pass/fail but implies broader correctness than the scenario coverage supports."
    :protocol-mechanisms [:scenario-coverage :claim-evaluation]
    :stakeholder-impact "A reviewer may trust a result more than the evidence warrants."}
   {:failure/id :failure/evidence-rich-coverage-poor
    :failure/name "Evidence-rich but coverage-poor"
    :failure/summary "The artifacts are strong but the tested scenarios are narrow, leaving edge cases unexercised."
    :protocol-mechanisms [:scenario-suite-design :coverage-mapping]
    :stakeholder-impact "A passing result may not generalise to untested configurations or adversarial conditions."}
   {:failure/id :failure/attested-but-unverified
    :failure/name "Attested but unverified"
    :failure/summary "A result is signed or anchored but its semantic correctness has not been independently checked."
    :protocol-mechanisms [:attestation :evidence-chain]
    :stakeholder-impact "An attested result may be accepted as true when the underlying computation or scenario is flawed."}
   {:failure/id :failure/confidence-label-mismatch
    :failure/name "Confidence-label mismatch"
    :failure/summary "An aggregate confidence label is assigned without computing or reporting the per-dimension scores, masking dimensional weaknesses."
    :protocol-mechanisms [:confidence-evaluation :claim-reporting]
    :stakeholder-impact "A high-confidence label assigned without dimension scoring obscures weaknesses in individual dimensions."}]
  :concept/metrics
  {:metric/evidence-integrity-score
   {:description "Proportion of required evidence artifacts present and verifiable for a claim result."
    :source "Number of artifacts in evidence-registry with verifiable hashes divided by total required artifacts for the claim. Derived from trace evidence-registry entries."}
   :metric/coverage-ratio
   {:description "Fraction of relevant mechanisms or edge cases exercised by the scenario suite for a given claim."
    :source "Count of distinct mechanisms, transition types, or edge cases exercised by the scenario suite divided by the total identified as relevant for the claim. Derived from invariant scenario results and coverage mapping."}
   :metric/determinism-hash-match
   {:description "Boolean: whether repeated execution of the same scenario produces identical result and artifact hashes."
    :source "Run the same scenario twice with identical inputs. Compare projection hashes and artifact hashes across both runs. If all match, true; else false. Derived from trace projection-hash and artifact-hash fields."}
   :metric/attestation-count
   {:description "Number of independent attestations linked to a claim result."
    :source "Count of distinct attestation entries in the evidence bundle that reference the claim result's evidence-hash. Derived from trace attestation-registry entries."}
   :metric/confidence-label
   {:description "Aggregate confidence label (high/medium/low) for a claim result."
    :source "Derived by applying the aggregation rules in :concept/aggregation to the four per-dimension metrics."}}
  :concept/aggregation
  {:method/minimum-dimension
   {:description "Each of the four confidence dimensions (evidence, coverage, determinism, attestation) is scored independently. The aggregate label is the minimum across all scored dimensions: high when all four are strong, medium when any dimension has gaps, low when any dimension is critically weak."
    :rationale "A chain is only as strong as its weakest link. High evidence integrity cannot compensate for missing coverage or non-deterministic execution."
    :steps ["Score evidence-integrity: >= 0.9 = strong, >= 0.5 = adequate, < 0.5 = weak"
            "Score coverage-ratio: >= 0.8 = strong, >= 0.4 = adequate, < 0.4 = weak"
            "Score determinism-hash-match: true = strong, false = weak"
            "Score attestation-count: >= 2 = strong, >= 1 = adequate, 0 = weak"
            "Aggregate: if any weak → low-confidence, if any adequate → medium-confidence, all strong → high-confidence"]
    :example "A claim with evidence-integrity=0.95 (strong), coverage-ratio=0.3 (weak), determinism=true (strong), attestation-count=2 (strong) → low-confidence due to weak coverage."}}
 :concept/assumptions
 ["Confidence is distinct from pass/fail. A claim can pass with low confidence if coverage is thin. A claim can fail with high confidence if the failure is deterministic and well evidenced."
  "Confidence is dimensional, not scalar. Evidence confidence, coverage confidence, determinism confidence, and attestation confidence should be reported separately before any aggregate label is derived."]
 :concept/out-of-scope
 ["This concept does not define a minimum confidence threshold for protocol acceptance."
  "This concept does not assign trust scores to individual actors or oracles."
  "This concept does not address statistical or Bayesian confidence intervals."]
 :concept/subconcepts
 [{:concept/id :concept/claim-confidence
   :concept/name "Claim confidence"
   :concept/summary "Confidence in a specific claim result based on the number, relevance, determinism, and quality of scenarios and evidence artifacts backing it."}
  {:concept/id :concept/evidence-confidence
   :concept/name "Evidence confidence"
   :concept/summary "Confidence derived from the integrity and completeness of evidence artifacts: canonical hashes present, evidence chain verifies, artifact registry complete."}
  {:concept/id :concept/coverage-confidence
   :concept/name "Coverage confidence"
   :concept/summary "Confidence that the scenario suite exercises the relevant mechanisms, edge cases, and failure modes for a claim. Important for benchmark reporting -- slashing conservation may have high evidence confidence but medium coverage confidence if reversal paths are missing."}
  {:concept/id :concept/determinism-confidence
   :concept/name "Determinism confidence"
   :concept/summary "Confidence that repeated execution of the same scenario and configuration produces identical results, artifacts, and hashes."}
  {:concept/id :concept/attestation-confidence
   :concept/name "Attestation confidence"
   :concept/summary "Confidence added by independent attestation, signature, external witness, timestamp, or on-chain anchor. Attestation increases provenance confidence, not necessarily semantic correctness."}]}
