{:concept/id :concept/configuration
 :concept/name "Configuration"
 :concept/type :framework
 :concept/layer :framework-explanation
 :concept/summary "The explicit settings under which a scenario, benchmark, or claim result is valid."
 :concept/stakeholder-question "Under what conditions does this result hold?"
 :concept/protocols #{:protocol/sew-v1}
 :concept/frameworks #{:framework/prf}
 :concept/related [:consensus/finality]
 :concept/roles
 {:role/reviewer
  {:description "Needs to know the exact configuration under which a result was produced to assess reproducibility and applicability."}
  :role/researcher
  {:description "Compares results across configurations to understand how parameter choices affect protocol behaviour."}
  :role/protocol-designer
  {:description "Uses configuration to define the conditions under which protocol properties are expected to hold."}}
 :concept/entities
 {:entity/scenario-definition
  {:description "A complete scenario map including events, agents, protocol-params, and expectations."
   :maps-to [:protocol.entity/scenario]}
  :entity/benchmark-pack
  {:description "A named collection of scenarios, scoring rules, claim sets, and configuration references."
   :maps-to [:protocol.entity/benchmark-pack]}
  :entity/execution-replay
  {:description "A deterministic replay run linked to a specific configuration hash."
   :maps-to [:protocol.entity/replay]}}
 :concept/actions
 {:action/parameterise
  {:description "Assign a configuration value to a protocol parameter, module selection, or execution option."
   :maps-to [:protocol.action/parameterise]}
  :action/hash-configuration
  {:description "Compute a canonical hash of the active configuration for reproducibility linking."
   :maps-to [:protocol.action/hash-configuration]}
  :action/detect-drift
  {:description "Compare two configuration hashes to determine whether settings have changed between runs."
   :maps-to [:protocol.action/compare-configurations]}}
 :concept/outcomes
 {:outcome/configuration-known
  {:description "The full configuration is recorded, hashed, and available in the artifact registry."
   :maps-to [:protocol.outcome/pass]}
  :outcome/configuration-gap
  {:description "Some configuration parameters are implicit, unrecorded, or inferred rather than explicit."
   :maps-to [:protocol.outcome/fail]}
  :outcome/configuration-drift
  {:description "Two related runs were executed under different configurations that were assumed to be identical."
   :maps-to [:protocol.outcome/fail]}}
 :concept/failure-modes
 [{:failure/id :failure/configuration-drift
   :failure/name "Configuration drift"
   :failure/summary "A benchmark or scenario result is compared against another result produced under different settings, but the differences are not detected or recorded."
   :protocol-mechanisms [:configuration-hash :artifact-registry]
   :stakeholder-impact "Invalid comparisons; incorrect conclusions about protocol regressions or improvements."}
  {:failure/id :failure/implicit-configuration
   :failure/name "Implicit configuration"
   :failure/summary "A result depends on settings not recorded in the artifacts, making it unreproducible."
   :protocol-mechanisms [:configuration-hash :scenario-definition]
   :stakeholder-impact "Another party cannot reproduce the result without reverse-engineering the implicit settings."}
  {:failure/id :failure/configuration-overclaim
   :failure/name "Configuration overclaim"
   :failure/summary "A result is presented as general when it only holds under a narrow or unrepresentative configuration."
   :protocol-mechanisms [:benchmark-concepts :coverage-mapping]
   :stakeholder-impact "A reviewer may apply a result outside its valid configuration scope."}
  {:failure/id :failure/stale-configuration
   :failure/name "Stale configuration"
   :failure/summary "A configuration hash or metadata points to settings that no longer match the executed scenario due to software changes or data migration."
   :protocol-mechanisms [:scenario-validation :reproducibility-check]
   :stakeholder-impact "Replayed results may differ non-deterministically from the original run."}]
 :concept/metrics
 {:metric/configuration-keys-recorded
  {:description "Count of distinct configuration parameters explicitly recorded for a run."
   :source :derived-from-world-state}
  :metric/hash-match-indicator
  {:description "Boolean: whether the reported configuration hash matches the recomputed hash from recorded parameters."
   :source :derived-from-trace}
  :metric/drift-count
  {:description "Number of detected parameter differences between two configuration snapshots."
   :source :derived-from-trace}}
 :concept/assumptions
 ["A result is valid only under the configuration that produced it. Claims of general protocol safety must be qualified by the configuration space explored."
  "Configuration includes protocol parameters, module selections, benchmark definitions, execution options, and temporal assumptions."
  "Configuration should be explicitly hashed and recorded in the artifact registry for every run that produces a claim result."]
 :concept/out-of-scope
 ["This concept does not prescribe which configuration parameters should be varied in a sensitivity analysis."
  "This concept does not define a canonical configuration for production deployment."
  "This concept does not address environmental configuration outside the protocol and execution layers (e.g., hardware, OS, network)."]
 :concept/subconcepts
 [{:concept/id :concept/protocol-configuration
   :concept/name "Protocol configuration"
   :concept/summary "Protocol-level settings that determine behaviour for a scenario or benchmark run: max-dispute-duration, appeal-window, slash-delay, resolver-overflow-policy, yield-policy, governance-mode."}
  {:concept/id :concept/module-configuration
   :concept/name "Module configuration"
   :concept/summary "Selected modules and their parameters: resolution-module, yield-module, liquidity-module, risk-module."}
  {:concept/id :concept/benchmark-configuration
   :concept/name "Benchmark configuration"
   :concept/summary "Benchmark pack, scenario suite, scoring rule, claim set, and execution registry entries for a benchmark run."}
  {:concept/id :concept/execution-configuration
   :concept/name "Execution configuration"
   :concept/summary "Runtime settings that affect how scenarios are executed but should not alter protocol semantics: parallel?, artifact-dir, evidence-enabled?, attestation-enabled?, random-seed, clock-mode."}
  {:concept/id :concept/governance-configuration
   :concept/name "Governance configuration"
   :concept/summary "Settings that determine which actors may perform governance actions and which governance modes are active: governance-mode, governance-role, resolver-overflow-policy, allowed-reasons."}
  {:concept/id :concept/temporal-configuration
   :concept/name "Temporal configuration"
   :concept/summary "Settings that define protocol time, block time, epoch boundaries, deadlines, and clock behaviour: context/time, block-time, clock/mode, max-dispute-duration."}
  {:concept/id :concept/configuration-hash
   :concept/name "Configuration hash"
   :concept/summary "A canonical hash of the configuration relevant to a scenario, benchmark, claim, or artifact, enabling reproducibility comparisons."}
  {:concept/id :concept/configuration-scope
   :concept/name "Configuration scope"
   :concept/summary "The boundary of what a configuration applies to: one workflow, one scenario, one benchmark run, one module, one epoch, or the whole protocol world."}]}
