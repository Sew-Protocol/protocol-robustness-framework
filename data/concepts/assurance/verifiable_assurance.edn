{:concept/id :verifiable-assurance/forensic-confidence
 :concept/type :assurance
 :concept/layer :framework-explanation
 :concept/name "Verifiable assurance — forensic confidence"
 :concept/summary
 "A stakeholder examines the evidence trail left by a protocol
  interaction — scenario trace, invariant results, evidence chain,
  canonical hashes — and determines whether the outcome is trustworthy.
  Confidence comes from cryptographically verifiable evidence, not from
  trust in any single actor."

 :concept/stakeholder-question
 "How can I verify that a protocol outcome was correct without
  relying on any single authority, and how can I prove correctness
  to a third party?"

 :concept/protocols #{:protocol/prf :protocol/sew-v1}

 :concept/roles
 {:observer
  {:description "Party examining the evidence trail for a specific interaction."
   :maps-to [:protocol.role/verifier]}
  :auditor
  {:description "Third party performing independent verification of protocol outcomes."
   :maps-to [:protocol.role/verifier]}
  :regulator
  {:description "Authority requiring verifiable assurance as a condition of approval."
   :maps-to [:protocol.role/verifier]}
  :participant
   {:description "Party to the original interaction who wants independent confirmation."
    :maps-to [:protocol.role/sender :protocol.role/recipient]
    :mapping/confidence :approximate
    :mapping/note "Participant role depends on their original role in the interaction"}}

 :concept/entities
 {:evidence-bundle
  {:description "Portable collection of all evidence from a single run."
   :maps-to [:protocol.entity/evidence-bundle]}
  :evidence-chain
  {:description "Linked list of evidence nodes, each hashing the previous."
   :maps-to [:protocol.entity/evidence-chain]}
  :canonical-hash
  {:description "Deterministic SHA-256 hash over canonically serialized EDN."
   :maps-to [:protocol.entity/hash]}
  :attestation
  {:description "Cryptographically signed statement linking an identity to a hash."
   :maps-to [:protocol.entity/attestation]}
  :trace-log
  {:description "Ordered sequence of protocol events from a scenario run."
   :maps-to [:protocol.entity/trace]}
  :invariant-result
  {:description "Pass, fail, or error outcome for a specific invariant check."
   :maps-to [:protocol.entity/invariant-result]}
  :bundle-manifest
  {:description "Index of all files and hashes within an evidence bundle."
   :maps-to [:protocol.entity/manifest]}}

 :concept/actions
 {:request-trace
  {:description "Ask the protocol or runner for the full trace of an interaction."
   :maps-to [:protocol.action/export-trace :protocol.action/get-evidence]}
  :verify-evidence-chain
  {:description "Walk the evidence chain and validate every hash link."
   :maps-to [:protocol.action/verify-chain :protocol.action/validate-links]}
  :replay-scenario
  {:description "Re-run a scenario to confirm deterministic output matches the recorded result."
   :maps-to [:protocol.action/replay :protocol.action/reproduce]}
  :check-invariant
  {:description "Evaluate a specific invariant against a trace independently."
   :maps-to [:protocol.action/check-invariant :protocol.action/validate-invariant]}
  :compute-hash
  {:description "Generate a canonical SHA-256 hash of a data structure."
   :maps-to [:protocol.action/canonical-hash :protocol.action/hash-bundle]}
  :verify-attestation
  {:description "Check that an attestation signature is valid for a given hash and identity."
   :maps-to [:protocol.action/verify-signature :protocol.action/validate-attestation]}
  :compare-with-attestation
  {:description "Verify that an independently computed hash matches a claimed attestation."
   :maps-to [:protocol.action/compare-hashes :protocol.action/validate-claim]}}

 :concept/outcomes
 {:outcome-verified-correct
  {:description "Evidence chain is intact, invariants pass, attestations match — outcome is trustworthy."
   :maps-to [:protocol.outcome/verified]}
  :outcome-verified-incorrect
  {:description "Evidence contradicts the claimed outcome or reveals a protocol violation."
   :maps-to [:protocol.outcome/falsified]}
  :evidence-incomplete
  {:description "Required evidence is missing, corrupted, or insufficient to reach a conclusion."
   :maps-to [:protocol.outcome/inconclusive]}
  :attestation-valid
  {:description "Attestation signature is cryptographically valid for the claimed hash."
   :maps-to [:protocol.outcome/attested]}
  :attestation-forged
  {:description "Attestation signature is invalid or does not match the claimed identity."
   :maps-to [:protocol.outcome/forged]}
  :replay-consistent
  {:description "Re-running the scenario produces bit-identical evidence."
   :maps-to [:protocol.outcome/deterministic]}
  :replay-divergent
  {:description "Re-running produces different evidence — non-determinism detected."
   :maps-to [:protocol.outcome/non-deterministic]}}

 :concept/failure-modes
 [{:failure/id :evidence-chain-broken
   :failure/name "Evidence chain integrity failure"
   :failure/summary
   "A hash link in the evidence chain does not match its predecessor,
    indicating tampering, corruption, or an incomplete export."
   :protocol-mechanisms [:canonical-hashing :chain-linking :bundle-integrity]
   :stakeholder-impact
   "Verifier cannot trust any evidence after the break point."}

  {:failure/id :hash-mismatch
   :failure/name "Canonical hash mismatch"
   :failure/summary
   "An independently computed hash does not match the hash claimed in
    the evidence bundle or attestation."
   :protocol-mechanisms [:canonical-serialization :hashing-determinism]
   :stakeholder-impact
   "Evidence bundle is rejected as non-authoritative or corrupted."}

  {:failure/id :non-deterministic-replay
   :failure/name "Non-deterministic replay"
   :failure/summary
   "Replaying a scenario with identical inputs produces different
    outputs, evidence, or hashes."
   :protocol-mechanisms [:rng-seeding :clock-synchronization :replay-mode]
   :stakeholder-impact
   "Protocol outcomes cannot be independently verified, undermining
    forensic confidence."}

  {:failure/id :attestation-missing
   :failure/name "Attestation not produced"
   :failure/summary
   "An expected attestation (runner signature, timestamp, or witness)
    was not created or is not available with the evidence bundle."
   :protocol-mechanisms [:signing :timestamping :witnessing]
   :stakeholder-impact
   "Cannot cryptographically link the evidence to a specific runner
    run or point in time, reducing non-repudiation."}

  {:failure/id :invariant-violation-suppressed
   :failure/name "Invariant violation hidden"
   :failure/summary
   "A checked invariant failed but the result was excluded from the
    evidence bundle or summary report."
   :protocol-mechanisms [:evidence-collection :result-aggregation :bundle-contents]
   :stakeholder-impact
   "Critical failures may go undetected during verification."}

  {:failure/id :bundle-manifest-incomplete
   :failure/name "Bundle manifest incomplete"
   :failure/summary
   "The evidence bundle manifest lists files or hashes that are not
    present in the bundle, or omits files that are present."
   :protocol-mechanisms [:manifest-generation :bundle-packaging]
   :stakeholder-impact
   "Verifier cannot confirm that the bundle is self-contained and
    complete."}]

 :concept/assumptions
 ["Evidence is collected and hashed using canonical EDN serialization (deterministic ordering)."
  "Attestations use Ed25519 or similar public-key signatures."
  "The verifier has access to the same scenario definitions and protocol adapter as the original run."
  "Concept labels do not change protocol validity."]

 :concept/out-of-scope
 ["Real-world identity verification or KYC."
  "Legal admissibility of cryptographic evidence."
  "Network-level security (TLS, certificate chains)."
  "Social consensus or reputation-based confidence."]}
