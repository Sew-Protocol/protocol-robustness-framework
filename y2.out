:maturity :benchmarked, :scenario-mapped? true, :scenario-mappings ["S82_shortfall-recovery-cycle" "S103_negative-yield-shortfall-cascade" "S105_policy-response-cascade" "S108_senior-coverage-consumed-by-slash" "S114_multi-escrow-pool-shortage" "S-DR-043-payout-shortfall-deferred" "S110_multi-junior-coverage" "Y04_vault-recovery-claim-deferred"]}, :ecommerce/purchase #:concept{:active-benchmark-ids [:benchmark/sew-escrow-dispute-v1 :benchmark/sew-dispute-liveness-v1 :benchmark/sew-resolver-slashing-v1], :claim-ids [:claim/no-unauthorized-release :claim/funds-conserved :claim/dispute-liveness :claim/slashing-conservation :claim/governance-non-interference :claim/solvency-status :claim/bounded-resolution-time :claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall :claim/waterfall-coverage-correct :claim/no-over-slashing :claim/appeal-bond-adequacy], :evaluator-claim-ids [:claim/no-unauthorized-release :claim/funds-conserved :claim/dispute-liveness :claim/slashing-conservation :claim/governance-non-interference :claim/solvency-status :claim/bounded-resolution-time :claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall :claim/waterfall-coverage-correct :claim/no-over-slashing :claim/appeal-bond-adequacy], :id :ecommerce/purchase, :known-gaps [], :maturity :benchmarked, :scenario-mapped? true, :scenario-mappings []}, :event/deposit #:concept{:active-benchmark-ids [:benchmark/sew-escrow-dispute-v1 :benchmark/sew-dispute-liveness-v1 :benchmark/sew-resolver-slashing-v1], :claim-ids [:claim/no-unauthorized-release :claim/funds-conserved :claim/dispute-liveness :claim/slashing-conservation :claim/governance-non-interference :claim/solvency-status :claim/bounded-resolution-time :claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall :claim/waterfall-coverage-correct :claim/no-over-slashing :claim/appeal-bond-adequacy], :evaluator-claim-ids [:claim/no-unauthorized-release :claim/funds-conserved :claim/dispute-liveness :claim/slashing-conservation :claim/governance-non-interference :claim/solvency-status :claim/bounded-resolution-time :claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall :claim/waterfall-coverage-correct :claim/no-over-slashing :claim/appeal-bond-adequacy], :id :event/deposit, :known-gaps [], :maturity :benchmarked, :scenario-mapped? true, :scenario-mappings []}, :robustness/protocol-value-conservation #:concept{:active-benchmark-ids [:benchmark/sew-resolver-slashing-v1 :benchmark/sew-reversal-slashing-v1], :claim-ids [:claim/funds-conserved :claim/slashing-conservation :claim/no-leakage-beyond-shortfall :claim/partial-fill-fairness :claim/yield-preserved-during-shortfall :claim/appeal-bond-adequacy :claim/no-over-slashing :claim/solvency-status :evidence-root-present :replay-result-present :scenario-hash-present :no-invariant-errors :all-scenarios-pass :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/waterfall-coverage-correct :claim/reversal-reviewer-due-process :claim/reversal-slash-conservation :claim/vindication-stability :claim/challenge-bounty-correctness :claim/governance-force-reversal-authorized], :evaluator-claim-ids [:claim/funds-conserved :claim/slashing-conservation :claim/no-leakage-beyond-shortfall :claim/yield-preserved-during-shortfall :claim/appeal-bond-adequacy :claim/no-over-slashing :claim/solvency-status :evidence-root-present :replay-result-present :scenario-hash-present :no-invariant-errors :all-scenarios-pass :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/waterfall-coverage-correct :claim/reversal-reviewer-due-process :claim/reversal-slash-conservation :claim/vindication-stability :claim/challenge-bounty-correctness :claim/governance-force-reversal-authorized], :id :robustness/protocol-value-conservation, :known-gaps [], :maturity :benchmarked, :scenario-mapped? true, :scenario-mappings ["settlement release/refund scenarios" "yield shortfall scenarios" "partial-fill withdrawal scenarios" "resolver slashing scenarios" "appeal and bond custody scenarios" "cancellation/finality scenarios" "S-DR-043-payout-shortfall-deferred" "S82_shortfall-recovery-cycle" "S103_negative-yield-shortfall-cascade" "S104_resolver-stake-shortfall"]}, :yield/yield-bearing #:concept{:active-benchmark-ids [], :claim-ids [:claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall], :evaluator-claim-ids [:claim/yield-preserved-during-shortfall :claim/partial-fill-decision-integrity :claim/cap-adherence :claim/no-leakage-beyond-shortfall], :id :yield/yield-bearing, :known-gaps [:not-in-active-benchmark], :maturity :evaluated, :scenario-mapped? true, :scenario-mappings []}}, :concept/section {:risk-annotations [#:concept{:failure-id :surplus-hidden-at-level, :failure-name "Surplus hidden at priority level", :failure-summary "Value remains unallocated at a higher priority level after all claims at that level are satisfied, but is not cascaded to lower priority levels.", :stakeholder-impact "Lower-priority claimants receive less recovery despite available surplus, violating the priority waterfall model."} #:concept{:failure-id :deferred-claim-subordination, :failure-name "Deferred claim subordination without declared policy", :failure-summary "Deferred claims from a prior epoch are silently subordinated to fresh claims in the current epoch without a declared ordering policy.", :stakeholder-impact "Deferred claimants face unpredictable recovery that depends on epoch timing rather than declared priority."} #:concept{:failure-id :cross-pool-boundary-violation, :failure-name "Cross-pool boundary violation", :failure-summary "Value moves between protocol pools without following declared pool-boundary rules or required governance authorisation.", :stakeholder-impact "Pool segregation is undermined, exposing one pool's claimants to risks or shortfalls from another pool."} #:concept{:failure-id :redistribution-ordering-dependent, :failure-name "Redistribution ordering-dependent", :failure-summary "The outcome of a redistribution decision changes when the order of processing (priority-level order, epoch order, pool order) is permuted.", :stakeholder-impact "Claimants receive different recovery depending on processing order rather than their claim's priority or merit."} #:concept{:failure-id :redistribution-unevidenced, :failure-name "Redistribution unevidenced", :failure-summary "A redistribution decision is executed but no evidence artifact captures the inputs, rules applied, or output allocation.", :stakeholder-impact nil} #:concept{:failure-id :merchant-controlled-resolver, :failure-name "Merchant-controlled resolver", :failure-summary "Merchant or aligned party controls dispute resolution and rules in its own favor.", :stakeholder-impact "Buyer can lose funds despite a disputed or unfulfilled order."} #:concept{:failure-id :buyer-griefing, :failure-name "Buyer griefing", :failure-summary "Buyer opens repeated or low-merit disputes to delay merchant payout.", :stakeholder-impact "Merchant liquidity is delayed or operational costs increase."} #:concept{:failure-id :fund-lock, :failure-name "Funds locked after unresolved dispute", :failure-summary "A dispute has no viable resolution path before timeout.", :stakeholder-impact "Buyer and merchant cannot access funds."} #:concept{:failure-id :collusive-fraud, :failure-name "Collusive buyer-merchant fraud", :failure-summary "Buyer and merchant collude to extract value from the escrow system.", :stakeholder-impact "Protocol reserves or resolver bonds are drained."} #:concept{:failure-id :false-attestation, :failure-name "False attestation of condition", :failure-summary "Condition authority attests that a condition was met when it was not, or vice versa.", :stakeholder-impact "Funds are released or returned incorrectly, harming one party."} #:concept{:failure-id :condition-unverifiable, :failure-name "Condition unverifiable on-chain", :failure-summary "The condition cannot be objectively verified from on-chain data, requiring trust in a third party.", :stakeholder-impact "Deposit outcome depends on subjective or off-chain judgment."} #:concept{:failure-id :premature-timeout-claim, :failure-name "Premature timeout claim", :failure-summary "Depositor claims expiry before the condition window has elapsed.", :stakeholder-impact "Beneficiary loses the opportunity to fulfill the condition."} #:concept{:failure-id :uncovered-exposure, :failure-name "Uncovered yield exposure", :failure-summary "Held balances are less than the total custody need across active yield positions.", :stakeholder-impact "Yield positions may not be fully recoverable on demand."} #:concept{:failure-id :value-leakage, :failure-name "Yield value leakage", :failure-summary "Value exits the yield position beyond the bounds of the declared shortfall.", :stakeholder-impact "Position holders lose more value than the shortfall explains."} #:concept{:failure-id :shortfall-fairness, :failure-name "Shortfall allocation unfairness", :failure-summary "When shortfall occurs, the available value is not distributed fairly among claimants.", :stakeholder-impact "Some claimants receive proportionally less than others at the same priority."} #:concept{:failure-id :yield-miscalculation, :failure-name "Yield miscalculation", :failure-summary "Accrued yield does not match the module's expected rate over the elapsed time.", :stakeholder-impact "Position holders receive incorrect yield amounts."} #:concept{:failure-id :resolver-capture, :failure-name "Resolver capture", :failure-summary "The resolver was controlled by or aligned with one party, producing\n    a biased decision.", :stakeholder-impact "Outcome favours one party regardless of merit."} #:concept{:failure-id :authority-without-scope, :failure-name "Authority exercised outside scope", :failure-summary "The decider ruled on matters beyond their granted authority.", :stakeholder-impact "Decision may be invalid or unenforceable."} #:concept{:failure-id :unknown-decider, :failure-name "Unknown or unregistered decider", :failure-summary "A decision was issued by an entity not registered as authorised.", :stakeholder-impact "Outcome cannot be attributed to a legitimate authority."} #:concept{:failure-id :module-circumvention, :failure-name "Resolution module bypassed", :failure-summary "The decider bypassed a required resolution module, circumventing programmed safeguards.", :stakeholder-impact "Module-level protections are lost."} #:concept{:failure-id :missing-critical-evidence, :failure-name "Missing critical evidence", :failure-summary "Essential evidence was never submitted, making the decision uninformed.", :stakeholder-impact "Decision may be wrong due to incomplete information."} #:concept{:failure-id :contradictory-evidence-unresolved, :failure-name "Contradictory evidence unresolved", :failure-summary "Parties submitted conflicting evidence and the decider could not or did not resolve the conflict.", :stakeholder-impact "Outcome depends on which evidence the decider weights more heavily."} #:concept{:failure-id :late-evidence-excluded, :failure-name "Late evidence excluded", :failure-summary "Pivotal evidence arrived after the deadline and was not considered.", :stakeholder-impact "Decision made without facts that could have changed the outcome."} #:concept{:failure-id :evidence-ignored, :failure-name "Available evidence ignored", :failure-summary "Timely, relevant evidence was available but the decider did not consider it.", :stakeholder-impact "Decision is uninformed despite available information."} #:concept{:failure-id :authority-deficit, :failure-name "Authority deficit", :failure-summary "The decider lacked proper authority or was captured, undermining the basis for acceptance.", :stakeholder-impact "Outcome has no legitimate claim to acceptance."} #:concept{:failure-id :procedural-failure, :failure-name "Procedural failure", :failure-summary "Required procedural steps were skipped, misordered, or executed incorrectly.", :stakeholder-impact "Outcome is procedurally invalid regardless of merit."} #:concept{:failure-id :evidentiary-failure, :failure-name "Evidentiary failure", :failure-summary "Decision was made without adequate evidence or ignored available evidence.", :stakeholder-impact "Outcome cannot be justified on the facts."} #:concept{:failure-id :remedy-unavailable, :failure-name "Remedy unavailable", :failure-summary "Even if illegitimacy is recognised, no protocol mechanism exists to remedy it.", :stakeholder-impact "Illegitimacy is observable but not actionable."} #:concept{:failure-id :failure/binary-pass-overclaim, :failure-name "Binary-pass overclaim", :failure-summary "A benchmark reports pass/fail but implies broader correctness than the scenario coverage supports.", :stakeholder-impact "A reviewer may trust a result more than the evidence warrants."} #:concept{:failure-id :failure/evidence-rich-coverage-poor, :failure-name "Evidence-rich but coverage-poor", :failure-summary "The artifacts are strong but the tested scenarios are narrow, leaving edge cases unexercised.", :stakeholder-impact "A passing result may not generalise to untested configurations or adversarial conditions."} #:concept{:failure-id :failure/attested-but-unverified, :failure-name "Attested but unverified", :failure-summary "A result is signed or anchored but its semantic correctness has not been independently checked.", :stakeholder-impact "An attested result may be accepted as true when the underlying computation or scenario is flawed."} #:concept{:failure-id :failure/confidence-label-mismatch, :failure-name "Confidence-label mismatch", :failure-summary "An aggregate confidence label is assigned without computing or reporting the per-dimension scores, masking dimensional weaknesses.", :stakeholder-impact "A high-confidence label assigned without dimension scoring obscures weaknesses in individual dimensions."} #:concept{:failure-id :failure/configuration-drift, :failure-name "Configuration drift", :failure-summary "A benchmark or scenario result is compared against another result produced under different settings, but the differences are not detected or recorded.", :stakeholder-impact "Invalid comparisons; incorrect conclusions about protocol regressions or improvements."} #:concept{:failure-id :failure/implicit-configuration, :failure-name "Implicit configuration", :failure-summary "A result depends on settings not recorded in the artifacts, making it unreproducible.", :stakeholder-impact "Another party cannot reproduce the result without reverse-engineering the implicit settings."} #:concept{:failure-id :failure/configuration-overclaim, :failure-name "Configuration overclaim", :failure-summary "A result is presented as general when it only holds under a narrow or unrepresentative configuration.", :stakeholder-impact "A reviewer may apply a result outside its valid configuration scope."} #:concept{:failure-id :failure/stale-configuration, :failure-name "Stale configuration", :failure-summary "A configuration hash or metadata points to settings that no longer match the executed scenario due to software changes or data migration.", :stakeholder-impact "Replayed results may differ non-deterministically from the original run."}], :concept/summaries [#:concept{:assumptions ["Redistribution rules are declared and knowable before allocation begins." "Inter-temporal rules for bridging deferred claims across epochs are unambiguous." "Pool boundaries and cross-pool transfer rules are defined at the governance level." "Level cascade is ordering-independent: the same surplus cascades the same way regardless of priority-level processing sequence." "An epoch is a bounded time window or state-machine cycle within which claims accrue and settlement occurs; deferred claims bridge from one epoch to the next." "Concept labels do not change protocol validity."], :evidence nil, :id :allocation/redistribution-fairness, :known-gaps nil, :mappings #:concept{:actions {:bridge-epoch {:description "Apply current-epoch surplus to outstanding deferred claims from a prior epoch.", :maps-to [:protocol.action/settle :protocol.action/partial-fill], :mapping/status :native}, :capture-redistribution-evidence {:description "Record the inputs, rules, and outputs of each redistribution decision as verifiable evidence.", :maps-to [:protocol.action/capture-evidence], :mapping/status :native}, :cascade-level-surplus {:description "Move surplus value from a satisfied priority level to the next lower level.", :maps-to [:protocol.action/calculate-pro-rata-allocation], :mapping/status :native}, :detect-redistribution-injustice {:description "Identify when redistribution deviates from declared rules or produces ordering-dependent outcomes.", :maps-to [:protocol.action/verify-allocation], :mapping/status :native}, :transfer-cross-pool {:description "Move value from one protocol pool to another according to declared pool-boundary rules.", :maps-to [:protocol.action/governance-transfer], :mapping/status :native}, :verify-redistribution-fairness {:description "Check that redistribution followed declared policy, preserved ordering-independence, and produced auditable evidence.", :maps-to [:protocol.action/verify-allocation :protocol.action/check-invariant], :mapping/status :native}}, :entities {:epoch-transition-record {:description "Evidence linking deferred claims from a prior epoch to surplus allocated in the current epoch.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :level-cascade-record {:description "Evidence of surplus cascading from one priority level to the next, with amounts and ordering.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :pool-transfer-record {:description "Evidence of value moving from one protocol pool to another, with authorisation and justification.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :redistribution-evidence-pack {:description "Aggregated evidence of all redistribution decisions in a run, enabling post-hoc verification.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :redistribution-policy {:description "Declared rule defining how surplus, cap-excess, or deferred value is redistributed across levels, epochs, or pools.", :maps-to [:protocol.entity/policy], :mapping/status :native}}, :outcomes {:redistribution-fair {:description "All redistribution followed declared rules, was ordering-independent, and is fully evidenced.", :maps-to [:protocol.outcome/released], :mapping/status :native}, :redistribution-rule-violated {:description "A cross-pool transfer violated a declared pool boundary or lacked required authorisation.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :redistribution-unevidenced {:description "Redistribution occurred but no evidence artifact captured the decision, preventing audit.", :maps-to [:protocol.outcome/stuck], :mapping/status :native}, :redistribution-unfair {:description "Redistribution deviated from declared rules or produced ordering-dependent outcomes.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}}, :roles {:deferred-claimant {:description "Party with an unpaid remainder from a prior epoch that may be recovered from current surplus.", :maps-to [:protocol.actor/sender :protocol.actor/recipient], :mapping/status :native}, :epoch-bridge {:description "Protocol logic that links deferred claims from a prior epoch to surplus in the current epoch.", :maps-to [:protocol.actor/resolution-module], :mapping/status :native}, :level-sequencer {:description "Entity or rule that orders priority-level processing and cascades surplus between levels.", :maps-to [:protocol.actor/resolution-module], :mapping/status :native}, :pool-governor {:description "Entity that defines pool boundaries and authorises cross-pool transfers.", :maps-to [:protocol.actor/governance], :mapping/status :native}, :surplus-distributor {:description "Protocol logic that determines where surplus value flows after a priority level's claims are satisfied.", :maps-to [:protocol.actor/resolution-module], :mapping/status :native}, :verifier {:description "Party checking that redistribution was performed according to declared rules.", :maps-to [:protocol.actor/verifier], :mapping/status :native}}}, :maturity nil, :name "Redistribution fairness", :not-claimed ["This stakeholder-facing concept does not assert implementation, deployment, legal, economic-safety, or benchmark coverage." "Protocol support must be established independently through adapter capabilities, executable scenarios, benchmark claims, and deployment configuration."], :out-of-scope ["Real-world wealth redistribution, taxation, or sovereign wealth funds." "Legal receivership, bankruptcy administration, or court-ordered distribution." "Off-chain rebalancing or side agreements between claimants." "Subjective fairness beyond the protocol's declared redistribution policy."], :stakeholder-question "If I am not paid in full now, or if another claimant cannot absorb their\n  full allocation, can I trust that surplus, cap-excess, or deferred value\n  is redistributed according to known rules that treat me fairly relative\n  to other claimants at every level and across time?", :summary "When available value cannot satisfy all valid claims in a single pass,\n  the protocol redistributes surplus, cap-excess, or deferred value across\n  priority levels (cross-level cascade), across epochs (inter-temporal\n  bridge), or across protocol pools (cross-pool transfer). Redistribution\n  is fair when the rules are unambiguous, ordering-independent, consistent\n  with the claim-priority model, and transparently evidenced.\n  Redistribution within a single priority level (cap-excess redistribution\n  among same-level claimants) is covered by the pro-rata-fairness concept.", :support-status nil} #:concept{:assumptions ["A buyer and merchant are identifiable protocol actors." "The escrow balance represents the payment amount." "Concept labels do not change protocol validity."], :evidence {:benchmarks #{:benchmark/sew-dispute-liveness-v1 :benchmark/sew-escrow-dispute-v1 :benchmark/sew-resolver-slashing-v1}, :claims #{:claim/no-unauthorized-release :claim/funds-conserved :claim/bounded-resolution-time :claim/dispute-liveness :claim/appeal-bond-adequacy}, :scenarios #{}}, :id :ecommerce/purchase, :known-gaps ["Dispute-bond and appeal-bond both map to the same protocol bond primitive (:protocol.entity/bond); the protocol does not distinguish bond type by trigger action." "Governance role is defined but governance-specific actions and outcomes (rotation, override) are not modelled."], :mappings #:concept{:actions {:appeal-resolution {:description "Party challenges a resolver decision.", :maps-to [:protocol.action/appeal :protocol.action/escalate], :mapping/status :native}, :claim-non-delivery {:description "Buyer disputes fulfillment.", :maps-to [:protocol.action/dispute :protocol.action/submit-evidence], :mapping/status :native}, :confirm-delivery {:description "Buyer confirms receipt; funds are released to merchant.", :maps-to [:protocol.action/release], :mapping/status :native}, :place-order {:description "Buyer commits funds for the purchase.", :maps-to [:protocol.action/create-escrow], :mapping/status :native}, :post-appeal-bond {:description "Appealing party posts collateral to challenge a resolution; forfeited if the appeal is rejected.", :maps-to [:protocol.action/bond], :mapping/confidence :approximate, :mapping/note "Same bond primitive as dispute-bond; the context (appeal vs. dispute) differs.", :mapping/status :approximate}, :post-dispute-bond {:description "Buyer posts collateral when raising a dispute; forfeited if the dispute is deemed frivolous.", :maps-to [:protocol.action/bond], :mapping/confidence :approximate, :mapping/note "Protocol bonding may be implicit in the dispute action; this separates the bond post from the dispute initiation for clarity.", :mapping/status :approximate}, :request-refund {:description "Buyer requests cancellation before release.", :maps-to [:protocol.action/cancel], :mapping/status :native}, :resolve-claim {:description "Resolver determines who receives funds.", :maps-to [:protocol.action/resolve :protocol.action/settle], :mapping/status :native}}, :entities {:appeal-bond {:description "Collateral posted by the appealing party when escalating a resolution, forfeited if the appeal is rejected.", :maps-to [:protocol.entity/bond], :mapping/confidence :approximate, :mapping/note "Same protocol bond primitive as dispute-bond; the distinction is the triggering action (appeal vs. dispute).", :mapping/status :approximate}, :dispute {:description "A disagreement about fulfillment.", :maps-to [:protocol.entity/dispute], :mapping/status :native}, :dispute-bond {:description "Collateral posted by a party when raising a dispute, forfeited if the dispute is deemed frivolous.", :maps-to [:protocol.entity/bond], :mapping/confidence :approximate, :mapping/note "Protocol bond mechanism covers resolver bonds, dispute bonds, and appeal bonds; this entity distinguishes the dispute-specific role.", :mapping/status :approximate}, :evidence {:description "Facts submitted to support a dispute claim.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :order {:description "The commercial transaction being protected.", :maps-to [:protocol.entity/escrow], :mapping/status :native}, :payment {:description "Funds held pending release, refund, or dispute.", :maps-to [:protocol.entity/funds], :mapping/status :native}}, :outcomes {:appeal-bond-forfeited {:description "Appeal bond is forfeited because the appeal was rejected.", :maps-to [:protocol.outcome/slashed], :mapping/status :native}, :appeal-bond-returned {:description "Appeal bond is returned because the appeal succeeded.", :maps-to [:protocol.outcome/released], :mapping/confidence :approximate, :mapping/note "Bond return maps to released in a bond-specific sense; the funds flow back to the poster rather than to a counterparty.", :mapping/status :approximate}, :buyer-refunded {:description "Buyer receives funds back.", :maps-to [:protocol.outcome/refunded], :mapping/status :native}, :dispute-bond-forfeited {:description "Dispute bond is forfeited because the dispute was deemed frivolous or the posting party acted in bad faith.", :maps-to [:protocol.outcome/slashed], :mapping/status :native}, :funds-locked {:description "Neither party receives funds in expected time.", :maps-to [:protocol.outcome/stuck], :mapping/status :native}, :manipulated-resolution {:description "Authorized resolver path produces stakeholder-unfair outcome.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :merchant-paid {:description "Merchant receives payment.", :maps-to [:protocol.outcome/released], :mapping/status :native}}, :roles {:buyer {:description "Party paying for goods or services.", :maps-to [:protocol.actor/sender], :mapping/status :native}, :governance {:description "Protocol governance that can adjust rules, rotate resolvers, or intervene.", :maps-to [:protocol.actor/governance], :mapping/status :native}, :merchant {:description "Party expected to fulfill the order.", :maps-to [:protocol.actor/recipient], :mapping/status :native}, :resolver {:description "Party or module deciding disputes.", :maps-to [:protocol.actor/resolver], :mapping/status :native}}}, :maturity :illustrative, :name "Ecommerce purchase", :not-claimed ["This stakeholder-facing concept does not assert implementation, deployment, legal, economic-safety, or benchmark coverage." "Protocol support must be established independently through adapter capabilities, executable scenarios, benchmark claims, and deployment configuration." "This mapping is illustrative; it is not a production-support claim."], :out-of-scope ["Real-world shipping, delivery logistics, or product quality." "Chargebacks, fraud detection, or payment card networks." "Dispute resolution outside the protocol (courts, arbitration)."], :stakeholder-question "Can a marketplace payment flow remain fair when buyers, merchants,\n  resolvers, or governance behave strategically?", :summary "A buyer pays a merchant through escrow. Funds are released, refunded,\n  disputed, or locked depending on delivery, evidence, and resolver decisions.", :support-status :not-asserted} #:concept{:assumptions ["A condition is defined at deposit creation and is evaluable." "The condition authority is either a resolver module or an oracle." "Concept labels do not change protocol validity."], :evidence {:benchmarks #{:benchmark/sew-dispute-liveness-v1 :benchmark/sew-escrow-dispute-v1}, :claims #{:claim/no-unauthorized-release :claim/funds-conserved :claim/bounded-resolution-time :claim/dispute-liveness}, :scenarios #{}}, :id :event/deposit, :known-gaps ["Evaluation-upheld and evaluation-reversed both map to the same protocol outcome (:protocol.outcome/resolved); the protocol does not distinguish them." "Condition-authority role maps approximately to resolver or oracle — the mapping confidence is documented above." "Governance role was removed because no governance-specific behaviour is modelled in this use-case."], :mappings #:concept{:actions {:attest-condition-met {:description "Condition authority certifies that the condition is satisfied.", :maps-to [:protocol.action/resolve :protocol.action/settle], :mapping/status :native}, :claim-expiry {:description "Depositor claims return of funds because the condition window passed.", :maps-to [:protocol.action/cancel :protocol.action/timeout], :mapping/status :native}, :create-deposit {:description "Depositor commits funds and specifies the release condition.", :maps-to [:protocol.action/create-escrow], :mapping/status :native}, :dispute-condition {:description "A party challenges the condition authority's evaluation.", :maps-to [:protocol.action/dispute :protocol.action/appeal], :mapping/status :native}, :fulfill-condition {:description "Beneficiary performs the required action or provides proof.", :maps-to [:protocol.action/submit-evidence :protocol.action/release], :mapping/status :native}, :post-appeal-bond {:description "Challenging party posts collateral when disputing a condition evaluation; forfeited if the challenge is rejected.", :maps-to [:protocol.action/bond], :mapping/confidence :approximate, :mapping/note "Separates bond post from dispute initiation for clarity; protocol may combine them.", :mapping/status :approximate}}, :entities {:appeal-bond {:description "Collateral posted by the challenging party when disputing a condition evaluation; forfeited if the challenge is rejected.", :maps-to [:protocol.entity/bond], :mapping/confidence :approximate, :mapping/note "Protocol bond primitive is shared across dispute and appeal contexts.", :mapping/status :approximate}, :attestation {:description "Signed statement that a condition was met or not met.", :maps-to [:protocol.entity/evidence], :mapping/status :native}, :condition {:description "The requirement or event that triggers release.", :maps-to [:protocol.entity/condition], :mapping/status :native}, :deposit {:description "The escrowed funds and associated condition.", :maps-to [:protocol.entity/escrow], :mapping/status :native}, :dispute {:description "A challenge about whether the condition was properly evaluated.", :maps-to [:protocol.entity/dispute], :mapping/status :native}}, :outcomes {:appeal-bond-forfeited {:description "Appeal bond is forfeited because the challenge failed or was frivolous.", :maps-to [:protocol.outcome/slashed], :mapping/status :native}, :appeal-bond-returned {:description "Appeal bond is returned because the challenge succeeded.", :maps-to [:protocol.outcome/released], :mapping/confidence :approximate, :mapping/note "Bond return flows through the same protocol release mechanism as fund release.", :mapping/status :approximate}, :appeal-rejected {:description "The challenge is dismissed as invalid, out of time, or brought by an unauthorised party.", :maps-to [:protocol.outcome/rejected], :mapping/status :native}, :deposit-misattested {:description "Condition authority incorrectly attested the condition, causing wrongful release or return.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :deposit-released {:description "Beneficiary receives funds because the condition was met.", :maps-to [:protocol.outcome/released], :mapping/status :native}, :deposit-returned {:description "Depositor receives funds back because the condition failed or expired.", :maps-to [:protocol.outcome/refunded], :mapping/status :native}, :deposit-stuck {:description "Funds are locked because the condition is disputed and unresolved.", :maps-to [:protocol.outcome/stuck], :mapping/status :native}, :evaluation-reversed {:description "After challenge, the original condition evaluation is overturned.", :maps-to [:protocol.outcome/resolved], :mapping/confidence :approximate, :mapping/note "Same protocol outcome as upheld; the reversal is inferred from the fund flow direction.", :mapping/status :approximate}, :evaluation-upheld {:description "After challenge, the original condition evaluation is confirmed as correct.", :maps-to [:protocol.outcome/resolved], :mapping/confidence :approximate, :mapping/note "Protocol outcome resolved covers the terminal resolution; the 'upheld' nuance is contextual.", :mapping/status :approximate}}, :roles {:beneficiary {:description "Party entitled to receive funds if the condition is met.", :maps-to [:protocol.actor/recipient], :mapping/status :native}, :condition-authority {:description "Entity that determines whether the condition has been satisfied.", :maps-to [:protocol.actor/resolver :protocol.actor/oracle], :mapping/confidence :approximate, :mapping/note "Role may be either a resolver module or an oracle depending on deposit configuration", :mapping/status :approximate}, :depositor {:description "Party that commits funds into the deposit.", :maps-to [:protocol.actor/sender], :mapping/status :native}}}, :maturity :illustrative, :name "Event deposit", :not-claimed ["This stakeholder-facing concept does not assert implementation, deployment, legal, economic-safety, or benchmark coverage." "Protocol support must be established independently through adapter capabilities, executable scenarios, benchmark claims, and deployment configuration." "This mapping is illustrative; it is not a production-support claim."], :out-of-scope ["Real-world legal or contractual conditions." "Oracle quality, liveness, or security." "Multi-step conditional logic or dependent conditions."], :stakeholder-question "Can an escrowed deposit be released only when predefined conditions\n  are objectively met, and returned if they are not?", :summary "A depositor commits funds subject to a condition. Funds are released\n  to a beneficiary when the condition is met, or returned to the depositor\n  if the condition expires or fails. A condition authority verifies\n  whether the condition was satisfied.", :support-status :not-asserted} #:concept{:assumptions ["Yield accrual is deterministic and reproducible from world state." "Yield modules have known, bounded risk profiles." "Held balances are observable from protocol state before allocation." "Concept labels do not change protocol validity."], :evidence nil, :id :yield/yield-bearing, :known-gaps nil, :mappings #:concept{:actions {:accrue-yield {:description "Compute and record realized yield based on the module's rate and time elapsed.", :maps-to [:protocol.action/accrue-yield], :mapping/status :native}, :check-exposure {:description "Verify that held balances cover the custody need (principal + realized yield) for all positions.", :maps-to [:protocol.action/check-invariant], :mapping/status :native}, :detect-shortfall {:description "Identify when a yield position's held balance falls below its custody need.", :maps-to [:protocol.action/calculate-shortfall], :mapping/status :native}, :resolve-shortfall {:description "Apply partial fill or deferred recovery when shortfall is detected.", :maps-to [:protocol.action/settle :protocol.action/partial-fill], :mapping/status :native}}, :entities {:principal {:description "The base amount deposited into the yield position.", :maps-to [:protocol.entity/principal], :mapping/status :native}, :realized-yield {:description "Yield that has been earned and recorded.", :maps-to [:protocol.entity/realized-yield], :mapping/status :native}, :shortfall-model {:description "Parameters defining how shortfall is detected and resolved for a position.", :maps-to [:protocol.entity/shortfall-model], :mapping/status :native}, :unrealized-yield {:description "Yield that may be earned in the future based on the module's rate.", :maps-to [:protocol.entity/unrealized-yield], :mapping/status :native}, :yield-position {:description "A position with principal, realized yield, and status (active, withdrawn, etc.).", :maps-to [:protocol.entity/yield-position], :mapping/status :native}, :yield-rate {:description "Annualized yield rate for a given token.", :maps-to [:protocol.entity/yield-rate], :mapping/status :native}}, :outcomes {:principal-loss {:description "Yield position loses principal due to negative yield or module failure.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :yield-leakage {:description "Value leaks from the yield position beyond the declared shortfall bounds.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :yield-preserved {:description "Yield position value is fully covered by held balances.", :maps-to [:protocol.outcome/released], :mapping/status :native}, :yield-shortfall {:description "Held balances are insufficient — some or all yield/principal may be at risk.", :maps-to [:protocol.outcome/deferred], :mapping/status :native}}, :roles {:position-holder {:description "Party whose escrow or resolver stake is invested in a yield position.", :maps-to [:protocol.actor/sender :protocol.actor/recipient], :mapping/status :native}, :shortfall-detector {:description "Protocol logic that detects when held balance is insufficient for active positions.", :maps-to [:protocol.actor/resolution-module], :mapping/status :native}, :yield-module {:description "Protocol module that computes yield accrual and determines shortfall models.", :maps-to [:protocol.actor/yield-module], :mapping/status :native}, :yield-provider {:description "Entity that manages the yield position and receives yield proceeds.", :maps-to [:protocol.actor/recipient], :mapping/status :native}}}, :maturity nil, :name "Yield-bearing position", :not-claimed ["This stakeholder-facing concept does not assert implementation, deployment, legal, economic-safety, or benchmark coverage." "Protocol support must be established independently through adapter capabilities, executable scenarios, benchmark claims, and deployment configuration."], :out-of-scope ["Real-world APY, APR, or investment returns." "Market risk, impermanent loss, or oracle price deviations." "Tax treatment of yield as income or capital gain."], :stakeholder-question "Can my yield-bearing position be trusted to preserve its value, and what\n  happens if the protocol cannot cover all positions' principal plus\n  accrued yield?", :summary "A yield-bearing position holds principal that generates yield over time\n  according to a yield module (e.g. AAVE-like lending, fixed-rate). The\n  protocol tracks each position's principal, realized yield, and shortfall\n  status, and checks that held balances are sufficient to cover all