ription "Governance or higher authority reversed the decision.", :maps-to [:protocol.outcome/governance-override], :mapping/status :native}, :captured-decision {:description "Decider was aligned with one party or had undisclosed conflict.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :default-authority {:description "Decision was reached by default rule, not active deliberation.", :maps-to [:protocol.outcome/default-resolution], :mapping/status :native}, :independent-decision {:description "Decider was free from conflict and properly authorised.", :maps-to [:protocol.outcome/resolved], :mapping/status :native}}, :roles {:decider {:description "Entity that issues the binding decision.", :maps-to [:protocol.actor/resolver :protocol.actor/governance], :mapping/confidence :approximate, :mapping/note "Decider may be a resolver module or governance depending on context", :mapping/status :approximate}, :decision-subject {:description "Party whose outcome is decided.", :maps-to [:protocol.actor/sender :protocol.actor/recipient], :mapping/status :native}, :module {:description "Programmatic resolution logic that may override or guide the decider.", :maps-to [:protocol.actor/resolution-module], :mapping/status :native}, :oversight {:description "Entity that can review, replace, or override the decider.", :maps-to [:protocol.actor/governance], :mapping/status :native}}}, :maturity nil, :name "Consensus authority", :not-claimed ["This stakeholder-facing concept does not assert implementation, deployment, legal, economic-safety, or benchmark coverage." "Protocol support must be established independently through adapter capabilities, executable scenarios, benchmark claims, and deployment configuration."], :out-of-scope ["Real-world legal authority or jurisdiction." "Off-chain identity of the resolver." "Social or reputation-based notion of authority."], :stakeholder-question "Was the entity that decided this outcome independent, authorised, and\n  free from capture or conflict of interest?", :summary "Who has the power to decide a contested outcome? Authority may be\n  vested in a specific resolver, a resolution module, governance, or\n  a default rule. Independence of the decision-maker determines whether\n  the outcome can be trusted.", :support-status nil} #:concept{:assumptions ["Evidence is modelled as protocol events with timestamps and content hashes." "Deadlines are protocol-level parameters, not real-world legal deadlines." "Concept labels do not change protocol validity."], :evidence nil, :id :consensus/evidence, :known-gaps nil, :mappings #:concept{:actions {:evaluate-evidence {:description "Weigh submitted evidence as part of a decision.", :maps-to [:protocol.action/resolve :protocol.action/settle], :mapping/status :native}, :reject-evidence {:description "Decline to consider submitted evidence as untimely or irrelevant.", :maps-to [:protocol.action/reject-evidence], :mapping/status :native}, :request-evidence {:description "Ask a party or third party to provide evidence.", :maps-to [:protocol.action/request-evidence], :mapping/status :native}, :submit-evidence {:description "Provide a fact or claim to support a position.", :maps-to [:protocol.action/submit-evidence], :mapping/status :native}}, :entities {:evidence-deadline {:description "Time window within which evidence must be submitted.", :maps-to [:protocol.entity/deadline], :mapping/status :native}, :evidence-registry {:description "Ordered collection of all evidence for a dispute.", :maps-to [:protocol.entity/evidence-chain], :mapping/status :native}, :evidence-submission {:description "A single piece of evidence submitted by a party.", :maps-to [:protocol.entity/evidence], :mapping/status :native}}, :outcomes {:evidence-contradictory {:description "Submitted evidence conflicted and could not be reconciled.", :maps-to [:protocol.outcome/adversarial-resolution], :mapping/status :native}, :evidence-ignored {:description "Available evidence